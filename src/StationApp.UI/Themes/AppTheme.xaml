<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- Dark Theme Colors -->
    <!-- Light Theme Colors aligned with BasePageStyles -->
    <SolidColorBrush x:Key="BackgroundBrush" Color="#EAF4F2"/>
    <SolidColorBrush x:Key="SidebarBrush" Color="#203B73"/>
    <SolidColorBrush x:Key="CardBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="SubCardBrush" Color="#EAF4F2"/>
    <SolidColorBrush x:Key="ForegroundBrush" Color="#1F355C"/>
    <SolidColorBrush x:Key="AccentBrush" Color="#203B73"/>
    <SolidColorBrush x:Key="DangerBrush" Color="#E74C3C"/>
    <SolidColorBrush x:Key="WarningBrush" Color="#F1C40F"/>
    <SolidColorBrush x:Key="SuccessBrush" Color="#2ECC71"/>
    <SolidColorBrush x:Key="StableBrush" Color="#2ECC71"/>
    <SolidColorBrush x:Key="UnstableBrush" Color="#E74C3C"/>

    <!-- Nav Button -->
    <Style x:Key="NavButton" TargetType="Button">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="#B0B0D0"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="Height" Value="44"/>
        <Setter Property="HorizontalContentAlignment" Value="Left"/>
        <Setter Property="Padding" Value="24,0,0,0"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}" CornerRadius="0,8,8,0">
                        <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#2A2B4A"/>
                            <Setter Property="Foreground" Value="White"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Nav Sub Button -->
    <Style x:Key="NavSubButton" TargetType="Button" BasedOn="{StaticResource NavButton}">
        <Setter Property="Padding" Value="44,0,0,0"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="Height" Value="36"/>
        <Setter Property="Foreground" Value="#8F8FA8"/>
    </Style>

    <!-- Primary Button -->
    <Style x:Key="PrimaryButton" TargetType="Button">
        <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}" CornerRadius="8" Padding="12,6">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#00BFAA"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Background" Value="#555"/>
                            <Setter Property="Foreground" Value="#888"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Success Button -->
    <Style x:Key="SuccessButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
        <Setter Property="Background" Value="{StaticResource SuccessBrush}"/>
    </Style>

    <!-- Danger Button -->
    <Style x:Key="DangerButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
        <Setter Property="Background" Value="{StaticResource DangerBrush}"/>
    </Style>

    <!-- Search Box -->
    <Style x:Key="SearchBox" TargetType="TextBox">
        <Setter Property="Background" Value="{StaticResource SubCardBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource ForegroundBrush}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="10,6"/>
        <Setter Property="FontSize" Value="14"/>
    </Style>
</ResourceDictionary>
