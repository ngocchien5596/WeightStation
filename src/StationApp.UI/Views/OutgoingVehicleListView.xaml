<UserControl x:Class="StationApp.UI.Views.OutgoingVehicleListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/StationApp.UI;component/Themes/AppTheme.xaml"/>
                <ResourceDictionary Source="/StationApp.UI;component/Styles/ButtonStyles.xaml"/>
                <ResourceDictionary Source="/StationApp.UI;component/Styles/InputStyles.xaml"/>
                <ResourceDictionary Source="/StationApp.UI;component/Styles/BasePageStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <!-- Local style overrides to support strikethrough for cancelled (no-load) tickets -->
            <Style x:Key="GridTextCenter" TargetType="TextBlock" BasedOn="{StaticResource GridTextCenter}">
                <Setter Property="Margin" Value="10,0"/>
                <Setter Property="VerticalAlignment" Value="Center"/>
                <Style.Triggers>
                    <DataTrigger Binding="{Binding IsNoLoad}" Value="True">
                        <Setter Property="TextDecorations" Value="Strikethrough"/>
                        <Setter Property="Foreground" Value="#94A3B8"/>
                    </DataTrigger>
                </Style.Triggers>
            </Style>

            <Style x:Key="GridTextLeft" TargetType="TextBlock" BasedOn="{StaticResource GridTextLeft}">
                <Setter Property="Margin" Value="10,0"/>
                <Setter Property="VerticalAlignment" Value="Center"/>
                <Style.Triggers>
                    <DataTrigger Binding="{Binding IsNoLoad}" Value="True">
                        <Setter Property="TextDecorations" Value="Strikethrough"/>
                        <Setter Property="Foreground" Value="#94A3B8"/>
                    </DataTrigger>
                </Style.Triggers>
            </Style>

            <Style x:Key="GridTextRight" TargetType="TextBlock" BasedOn="{StaticResource GridTextRight}">
                <Setter Property="Margin" Value="10,0"/>
                <Setter Property="VerticalAlignment" Value="Center"/>
                <Style.Triggers>
                    <DataTrigger Binding="{Binding IsNoLoad}" Value="True">
                        <Setter Property="TextDecorations" Value="Strikethrough"/>
                        <Setter Property="Foreground" Value="#94A3B8"/>
                    </DataTrigger>
                </Style.Triggers>
            </Style>
        </ResourceDictionary>
    </UserControl.Resources>
    <Grid Background="#FFFFFF">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource HeaderBorder}">
            <DockPanel>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="{StaticResource Outgoing.Label.SessionNo}" Style="{StaticResource HeaderLabel}" Margin="0,0,8,0"/>
                    <TextBox Width="168"
                             Style="{StaticResource StandardTextBoxStyle}"
                             Text="{Binding SearchSessionNo, UpdateSourceTrigger=PropertyChanged}">
                        <TextBox.InputBindings>
                            <KeyBinding Key="Enter" Command="{Binding RefreshCommand}"/>
                        </TextBox.InputBindings>
                    </TextBox>

                    <TextBlock Text="{StaticResource Workflow.Label.VehiclePlate}" Style="{StaticResource HeaderLabel}" Margin="20,0,8,0"/>
                    <TextBox Width="168"
                             Style="{StaticResource StandardTextBoxStyle}"
                             Text="{Binding SearchVehiclePlate, UpdateSourceTrigger=PropertyChanged}">
                        <TextBox.InputBindings>
                            <KeyBinding Key="Enter" Command="{Binding RefreshCommand}"/>
                        </TextBox.InputBindings>
                    </TextBox>

                    <TextBlock Text="{StaticResource Outgoing.Label.CompletedDate}" Style="{StaticResource HeaderLabel}" Margin="20,0,8,0"/>
                    <DatePicker SelectedDate="{Binding SelectedCompletedDate, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                Width="168"
                                SelectedDateFormat="Short"
                                VerticalAlignment="Center"
                                Style="{StaticResource StandardDatePickerStyle}"/>

                    <Button Command="{Binding RefreshCommand}" Style="{StaticResource HeaderActionButton}" Margin="20,0,0,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE72C;" FontFamily="Segoe MDL2 Assets" FontSize="13" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBlock Text="{StaticResource Workflow.RefreshButton}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </DockPanel>
        </Border>

        <Grid Grid.Row="1" Margin="12,8,12,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center">
                <Button Content="{StaticResource Outgoing.Action.ViewDetails}" Command="{Binding ShowDetailsCommand}" Style="{StaticResource WorkflowButtonStyle}" Margin="0,0,6,0"/>
                <Button Content="IN PC" Command="{Binding PrintWeighTicketCommand}" Style="{StaticResource UtilityButtonStyle}" Margin="0,0,6,0"/>
                <Button Content="IN PGN" Command="{Binding PrintDeliveryTicketCommand}" Style="{StaticResource UtilityButtonStyle}"/>
                <Button Content="{StaticResource Weighing.Action.RelatedTickets}" Command="{Binding ShowRelatedTicketsCommand}" Style="{StaticResource NeutralButtonStyle}" Margin="6,0,0,0"/>
                <Button Content="Xem ảnh lịch sử" Command="{Binding ViewImageHistoryCommand}" Style="{StaticResource NeutralButtonStyle}" Margin="6,0,0,0"/>
            </StackPanel>

            <CheckBox Grid.Column="2"
                      Margin="18,0,0,0"
                      VerticalAlignment="Center"
                      HorizontalAlignment="Right"
                      Content="{StaticResource Outgoing.Action.BaggedActualWeightOverride}"
                      Visibility="{Binding ShowBaggedActualWeightOverride, Converter={StaticResource BoolToVis}}"
                      IsChecked="{Binding UseActualWeightForBaggedCutOrders, Mode=TwoWay}"
                      IsEnabled="{Binding CanToggleBaggedActualWeightOverride}"
                      Style="{StaticResource StandardCheckBoxStyle}"/>
        </Grid>

        <Border Grid.Row="2" Margin="12,0,12,12">
            <DataGrid ItemsSource="{Binding Vehicles}" SelectedItem="{Binding SelectedVehicle}"
                      Style="{StaticResource SystemDataGridStyle}"
                      ColumnHeaderStyle="{StaticResource SystemDataGridColumnHeaderStyle}"
                      CellStyle="{StaticResource SystemDataGridCellStyle}"
                      FrozenColumnCount="3"
                      ScrollViewer.HorizontalScrollBarVisibility="Auto">
                <DataGrid.RowStyle>
                    <Style TargetType="DataGridRow" BasedOn="{StaticResource SystemDataGridRowStyle}">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding HighlightAsSplitOverweight}" Value="True">
                                <Setter Property="Foreground" Value="#C62828"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding IsNoLoad}" Value="True">
                                <Setter Property="TextBlock.TextDecorations" Value="Strikethrough"/>
                                <Setter Property="Foreground" Value="#94A3B8"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.RowStyle>
                <DataGrid.Columns>
                    <DataGridTextColumn Header="{StaticResource Outgoing.Column.CutOrderId}" Binding="{Binding ErpCutOrderId}" Width="150" ElementStyle="{StaticResource GridTextCenter}"/>
                    <DataGridTextColumn Header="{StaticResource Outgoing.Column.VehiclePlate}" Binding="{Binding VehiclePlate}" Width="110" ElementStyle="{StaticResource GridTextCenter}"/>
                    <DataGridTextColumn Header="{StaticResource Outgoing.Column.Mooc}" Binding="{Binding MoocNumber}" Width="110" ElementStyle="{StaticResource GridTextCenter}"/>
                    <DataGridTextColumn Header="{StaticResource Outgoing.Column.DriverName}" Binding="{Binding DriverName}" Width="150" ElementStyle="{StaticResource GridTextLeft}"/>
                    <DataGridTextColumn Header="{StaticResource Outgoing.Column.CustomerName}" Binding="{Binding CustomerName}" Width="250" ElementStyle="{StaticResource GridTextLeft}"/>
                    <DataGridTextColumn Header="{StaticResource Outgoing.Column.ProductCode}" Binding="{Binding ProductCode}" Width="130" ElementStyle="{StaticResource GridTextCenter}"/>
                    <DataGridTextColumn Header="{StaticResource Outgoing.Column.ProductName}" Binding="{Binding ProductName}" Width="250" ElementStyle="{StaticResource GridTextLeft}"/>
                    <DataGridTextColumn Header="{StaticResource Outgoing.Column.PlannedWeight}" Binding="{Binding PlannedWeight, StringFormat=N0}" Width="110" ElementStyle="{StaticResource GridTextRight}"/>
                    <DataGridTextColumn Header="{StaticResource Outgoing.Column.PlannedBags}" Binding="{Binding PlannedBagCount}" Width="85" ElementStyle="{StaticResource GridTextCenter}"/>
                    <DataGridTextColumn Header="{StaticResource Outgoing.Column.ActualTon}" Binding="{Binding ActualWeightKg, StringFormat=N0}" Width="110" ElementStyle="{StaticResource GridTextRight}"/>
                    <DataGridTextColumn Header="{StaticResource Outgoing.Column.ActualBags}" Binding="{Binding ActualBagCount}" Width="85" ElementStyle="{StaticResource GridTextCenter}"/>
                    <DataGridTextColumn Header="{StaticResource Outgoing.Column.TotalTon}" Binding="{Binding TotalWeightKg, StringFormat=N0}" Width="110" ElementStyle="{StaticResource GridTextRight}"/>
                    <DataGridTextColumn Header="{StaticResource Outgoing.Column.TotalBags}" Binding="{Binding TotalBagCount}" Width="85" ElementStyle="{StaticResource GridTextCenter}"/>
                    <DataGridTextColumn Header="{StaticResource Outgoing.Column.WeighDate}" Binding="{Binding WeighDate, StringFormat='dd/MM/yyyy HH:mm'}" Width="150" ElementStyle="{StaticResource GridTextCenter}"/>
                    <DataGridTextColumn Header="{StaticResource Outgoing.Column.WeighUser}" Binding="{Binding WeighUser}" Width="130" ElementStyle="{StaticResource GridTextCenter}"/>
                    <DataGridTextColumn Header="{StaticResource Outgoing.Column.TransactionType}" Binding="{Binding TransactionType, Converter={StaticResource TransactionTypeDisplayConverter}}" Width="95" ElementStyle="{StaticResource GridTextCenter}"/>
                    <DataGridTextColumn Header="{StaticResource Outgoing.Column.TransportMethod}" Binding="{Binding TransportMethod, Converter={StaticResource TransportMethodDisplayConverter}}" Width="95" ElementStyle="{StaticResource GridTextCenter}"/>
                    <DataGridTextColumn Header="{StaticResource Outgoing.Column.WeighTicketNo}" Binding="{Binding WeighTicketNo}" Width="135" ElementStyle="{StaticResource GridTextCenter}"/>
                    <DataGridTextColumn Header="{StaticResource Outgoing.Column.DeliveryNo}" Binding="{Binding DeliveryNo}" Width="135" ElementStyle="{StaticResource GridTextCenter}"/>
                    <DataGridTextColumn Header="{StaticResource Outgoing.Column.SessionNo}" Binding="{Binding SessionNo}" Width="130" ElementStyle="{StaticResource GridTextCenter}"/>
                    <DataGridCheckBoxColumn Header="IN PC" Binding="{Binding HasPrintedWeighTicket, Mode=OneWay}" Width="70" ElementStyle="{StaticResource GridCheckBoxCenter}"/>
                    <DataGridCheckBoxColumn Header="IN PGN" Binding="{Binding HasPrintedDeliveryTicket, Mode=OneWay}" Width="75" ElementStyle="{StaticResource GridCheckBoxCenter}"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <Grid Style="{StaticResource ModalOverlayStyle}" Visibility="{Binding IsDetailsVisible, Converter={StaticResource BoolToVis}}" Grid.RowSpan="3">
            <Border Style="{StaticResource ModalShellStyle}" MaxWidth="1100" MaxHeight="680" VerticalAlignment="Center" Margin="16">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Style="{StaticResource ModalHeaderStyle}">
                        <TextBlock Text="{StaticResource Outgoing.Dialog.DetailTitle}" Style="{StaticResource ModalTitleStyle}"/>
                    </Border>

                    <Border Grid.Row="1" Style="{StaticResource ModalBodyStyle}">
                        <Border Style="{StaticResource ModalSectionCardStyle}">
                            <DataGrid ItemsSource="{Binding DetailLines}"
                                      AutoGenerateColumns="False"
                                      IsReadOnly="True"
                                      Style="{StaticResource SystemDataGridStyle}"
                                      ColumnHeaderStyle="{StaticResource SystemDataGridColumnHeaderStyle}"
                                      RowStyle="{StaticResource SystemDataGridRowStyle}"
                                      CellStyle="{StaticResource SystemDataGridCellStyle}"
                                      Background="Transparent"
                                      BorderThickness="0"
                                      ScrollViewer.HorizontalScrollBarVisibility="Auto">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="{StaticResource Weighing.Column.SequenceNo}" Binding="{Binding SequenceNo}" Width="60"/>
                                    <DataGridTextColumn Header="{StaticResource Outgoing.Column.CutOrderId}" Binding="{Binding ErpCutOrderId}" Width="150"/>
                                    <DataGridTextColumn Header="{StaticResource Outgoing.Column.CustomerName}" Binding="{Binding CustomerName}" Width="250"/>
                                    <DataGridTextColumn Header="{StaticResource Outgoing.Column.ProductName}" Binding="{Binding ProductName}" Width="250"/>
                                    <DataGridTextColumn Header="{StaticResource Outgoing.Column.PlannedWeight}" Binding="{Binding PlannedWeight, StringFormat=N0}" Width="110"/>
                                    <DataGridTextColumn Header="{StaticResource Outgoing.Column.PlannedBags}" Binding="{Binding PlannedBagCount}" Width="90"/>
                                    <DataGridTextColumn Header="{StaticResource Outgoing.Column.ActualWeight}" Binding="{Binding ActualAllocatedWeight, StringFormat=N0}" Width="120"/>
                                    <DataGridTextColumn Header="{StaticResource Outgoing.Column.ActualBags}" Binding="{Binding ActualAllocatedBagCount}" Width="90"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Border>
                    </Border>

                    <Border Grid.Row="2" Style="{StaticResource ModalFooterStyle}">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Content="{StaticResource Workflow.CloseButton}" Command="{Binding CloseDetailsCommand}" Style="{StaticResource UtilityButtonStyle}"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <Grid Style="{StaticResource ModalOverlayStyle}" Visibility="{Binding IsRelatedTicketsVisible, Converter={StaticResource BoolToVis}}" Grid.RowSpan="3">
            <Border Style="{StaticResource ModalShellStyle}" MaxWidth="1060" MaxHeight="680" VerticalAlignment="Center" Margin="16">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Style="{StaticResource ModalHeaderStyle}">
                        <TextBlock Text="{StaticResource Weighing.Dialog.RelatedTitle}" Style="{StaticResource ModalTitleStyle}"/>
                    </Border>

                    <Border Grid.Row="1" Style="{StaticResource ModalBodyStyle}">
                        <Border Style="{StaticResource ModalSectionCardStyle}">
                            <DataGrid ItemsSource="{Binding RelatedTickets}" AutoGenerateColumns="False" IsReadOnly="True"
                                      Style="{StaticResource SystemDataGridStyle}"
                                      ColumnHeaderStyle="{StaticResource SystemDataGridColumnHeaderStyle}"
                                      RowStyle="{StaticResource SystemDataGridRowStyle}"
                                      CellStyle="{StaticResource SystemDataGridCellStyle}"
                                      Background="Transparent"
                                      BorderThickness="0"
                                      ScrollViewer.HorizontalScrollBarVisibility="Auto">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="{StaticResource Weighing.Column.Type}" Binding="{Binding DocumentType}" Width="180"/>
                                    <DataGridTextColumn Header="{StaticResource Weighing.Column.WeighTicketNo}" Binding="{Binding TicketNo}" Width="140"/>
                                    <DataGridTextColumn Header="{StaticResource Weighing.Column.DeliveryNo}" Binding="{Binding DeliveryNo}" Width="140"/>
                                    <DataGridTextColumn Header="{StaticResource Weighing.Column.Role}" Binding="{Binding RecordRole, Converter={StaticResource RecordRoleDisplay}}" Width="180"/>
                                    <DataGridTextColumn Header="{StaticResource Weighing.Weight1}" Binding="{Binding Weight1, StringFormat='{}{0:N0}'}" Width="110"/>
                                    <DataGridTextColumn Header="{StaticResource Weighing.Weight2}" Binding="{Binding Weight2, StringFormat='{}{0:N0}'}" Width="110"/>
                                    <DataGridTextColumn Header="{StaticResource Weighing.Column.Net}" Binding="{Binding NetWeight, StringFormat='{}{0:N0}'}" Width="110"/>
                                    <DataGridTextColumn Header="{StaticResource Weighing.Column.CreatedAt}" Binding="{Binding CreatedAt, StringFormat='{}{0:dd/MM HH:mm}'}" Width="150"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Border>
                    </Border>

                    <Border Grid.Row="2" Style="{StaticResource ModalFooterStyle}">
                        <Button Content="{StaticResource Workflow.CloseButton}" Command="{Binding CloseRelatedTicketsCommand}" Style="{StaticResource UtilityButtonStyle}" Width="100" HorizontalAlignment="Right"/>
                    </Border>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>


