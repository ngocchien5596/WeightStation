<UserControl x:Class="StationApp.UI.Views.ExportScaleReportView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/StationApp.UI;component/Themes/AppTheme.xaml"/>
                <ResourceDictionary Source="/StationApp.UI;component/Styles/ButtonStyles.xaml"/>
                <ResourceDictionary Source="/StationApp.UI;component/Styles/InputStyles.xaml"/>
                <ResourceDictionary Source="/StationApp.UI;component/Styles/BasePageStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <Style x:Key="ReportDatePickerStyle" TargetType="DatePicker" BasedOn="{StaticResource StandardDatePickerStyle}">
                <Setter Property="Width" Value="130"/>
                <Setter Property="Height" Value="34"/>
            </Style>

            <Style x:Key="ReportLookupComboStyle" TargetType="ComboBox">
                <Setter Property="FontFamily" Value="{StaticResource AppFontFamily}"/>
                <Setter Property="FontSize" Value="13"/>
                <Setter Property="Foreground" Value="#111827"/>
                <Setter Property="Background" Value="#FFFFFF"/>
                <Setter Property="BorderBrush" Value="#9AA4AA"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="Padding" Value="6,2"/>
                <Setter Property="VerticalContentAlignment" Value="Center"/>
                <Setter Property="HorizontalContentAlignment" Value="Left"/>
                <Setter Property="MaxDropDownHeight" Value="260"/>
            </Style>

            <Style x:Key="FormBox" TargetType="TextBox" BasedOn="{StaticResource StandardTextBoxStyle}">
                <Setter Property="Margin" Value="0,2"/>
            </Style>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid Background="{DynamicResource BackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource HeaderBorder}">
            <TextBlock Text="BÁO CÁO XUẤT - XK" 
                       FontSize="18" 
                       FontWeight="SemiBold" 
                       Foreground="White" 
                       HorizontalAlignment="Center" 
                       VerticalAlignment="Center"/>
        </Border>

        <Border Grid.Row="1"
                Margin="12,12,12,8"
                Padding="12"
                Background="{DynamicResource CardBrush}"
                BorderBrush="#E2E8F0"
                BorderThickness="1"
                CornerRadius="10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Margin="0,0,12,0">
                    <TextBlock Text="C&#x1EAF;t l&#x1EC7;nh xu&#x1EA5;t kh&#x1EA9;u" FontWeight="SemiBold" Margin="0,0,0,4"/>
                    <ComboBox Height="34"
                              Style="{StaticResource ReportLookupComboStyle}"
                              IsEditable="True"
                              IsTextSearchEnabled="False"
                              StaysOpenOnEdit="True"
                              Loaded="LookupComboBox_Loaded"
                              SelectionChanged="LookupComboBox_SelectionChanged"
                              Text="{Binding CutOrderSearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                              ItemsSource="{Binding CutOrderOptionsView}"
                              SelectedItem="{Binding SelectedCutOrder, Mode=TwoWay}">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding DisplayName}" TextTrimming="CharacterEllipsis"/>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                </StackPanel>

                <StackPanel Grid.Column="1" Margin="0,0,12,0">
                    <TextBlock Text="Ng&#xE0;y b&#xE1;o c&#xE1;o ca" FontWeight="SemiBold" Margin="0,0,0,4"/>
                    <DatePicker SelectedDate="{Binding TargetDate, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource ReportDatePickerStyle}"/>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Bottom">
                    <Button Command="{Binding PreviewCommand}" Style="{StaticResource UtilityButtonStyle}" Height="34" Width="64" Margin="0,0,8,0">
                        <TextBlock Text="XEM" FontWeight="SemiBold"/>
                    </Button>
                    <Button Command="{Binding ExportCommand}" Style="{StaticResource PrimaryButtonStyle}" Height="34" Width="64">
                        <TextBlock Text="T&#x1EA2;I" FontWeight="SemiBold"/>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="2" Margin="12,0,12,12" Padding="10" Background="{DynamicResource CardBrush}" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="{Binding PreviewSummaryText}" FontWeight="SemiBold" Foreground="#0F3B66" Margin="0,0,0,8"/>
                <DataGrid Grid.Row="1" ItemsSource="{Binding PreviewRows}" AutoGenerateColumns="False" IsReadOnly="True"
                          HeadersVisibility="Column" CanUserAddRows="False" CanUserDeleteRows="False"
                          EnableRowVirtualization="True" EnableColumnVirtualization="True"
                          ScrollViewer.HorizontalScrollBarVisibility="Auto" ScrollViewer.VerticalScrollBarVisibility="Auto">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="STT" Binding="{Binding Stt}" Width="60"/>
                        <DataGridTextColumn Header="L&#x1B0;&#x1EE3;t c&#xE2;n" Binding="{Binding SessionNo}" Width="110"/>
                        <DataGridTextColumn Header="Ca" Binding="{Binding Shift}" Width="60"/>
                        <DataGridTextColumn Header="Ng&#xE0;y xu&#x1EA5;t" Binding="{Binding ExportDate, StringFormat=dd/MM/yyyy}" Width="100"/>
                        <DataGridTextColumn Header="Ph&#x1B0;&#x1A1;ng ti&#x1EC7;n" Binding="{Binding VehiclePlate}" Width="110"/>
                        <DataGridTextColumn Header="Qua c&#xE2;n (t&#x1EA5;n)" Binding="{Binding NetWeightTon, StringFormat={}{0:#,##0.###}}" Width="110"/>
                        <DataGridTextColumn Header="Qua c&#xE2;n (bao)" Binding="{Binding BagCount, StringFormat=N0}" Width="100"/>
                        <DataGridTextColumn Header="V&#x1ECF; bao (t&#x1EA5;n)" Binding="{Binding BagShellWeightTon, StringFormat={}{0:#,##0.###}}" Width="110"/>
                        <DataGridTextColumn Header="H&#x1ED3;i v&#x1EC1; (t&#x1EA5;n)" Binding="{Binding ReturnedBrokenWeightTon, StringFormat={}{0:#,##0.###}}" Width="110"/>
                        <DataGridTextColumn Header="H&#x1ED3;i v&#x1EC1; (bao)" Binding="{Binding ReturnedBrokenBagCount, StringFormat=N0}" Width="100"/>
                        <DataGridTextColumn Header="Th&#x1EF1;c xu&#x1EA5;t (t&#x1EA5;n)" Binding="{Binding ActualExportTon, StringFormat={}{0:#,##0.###}}" Width="120"/>
                        <DataGridTextColumn Header="Th&#x1EF1;c xu&#x1EA5;t (bao)" Binding="{Binding ActualExportBagCount, StringFormat=N0}" Width="110"/>
                        <DataGridTextColumn Header="L&#x1EC7;ch chuy&#x1EBF;n (kg)" Binding="{Binding DifferenceKgPerTrip, StringFormat={}{0:#,##0.###}}" Width="120"/>
                        <DataGridTextColumn Header="L&#x1EC7;ch/bao (kg)" Binding="{Binding DifferenceKgPerBag, StringFormat={}{0:#,##0.###}}" Width="110"/>
                        <DataGridTextColumn Header="Ghi ch&#xFA;" Binding="{Binding Notes}" Width="220"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>
    </Grid>
</UserControl>
