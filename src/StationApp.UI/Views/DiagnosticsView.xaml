<UserControl x:Class="StationApp.UI.Views.DiagnosticsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/StationApp.UI;component/Themes/AppTheme.xaml"/>
                <ResourceDictionary Source="/StationApp.UI;component/Styles/ButtonStyles.xaml"/>
                <ResourceDictionary Source="/StationApp.UI;component/Styles/InputStyles.xaml"/>
                <ResourceDictionary Source="/StationApp.UI;component/Styles/BasePageStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <DockPanel Margin="0,0,0,24">
            <TextBlock Text="{StaticResource Diagnostics.Title}" FontSize="24" FontWeight="Bold" Foreground="{DynamicResource ForegroundBrush}"/>
            <Button Content="{StaticResource Diagnostics.Refresh}" Command="{Binding RefreshCommand}" Style="{StaticResource UtilityButtonStyle}"
                    HorizontalAlignment="Right" DockPanel.Dock="Right"/>
        </DockPanel>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="{DynamicResource CardBrush}" CornerRadius="12" Padding="20" Margin="0,0,8,0">
                <StackPanel>
                    <TextBlock Text="{StaticResource Diagnostics.DeviceTitle}" FontWeight="Bold" FontSize="16" Foreground="{DynamicResource ForegroundBrush}" Margin="0,0,0,16"/>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <Ellipse Width="12" Height="12" Fill="{Binding DeviceConnectionBrush}" Margin="0,0,8,0"/>
                        <TextBlock Text="{Binding DeviceConnectionStatus}" FontWeight="SemiBold" Foreground="{DynamicResource ForegroundBrush}"/>
                    </StackPanel>

                    <TextBlock Text="{StaticResource Diagnostics.RawFrame}" Foreground="Gray" FontSize="12" Margin="0,0,0,4"/>
                    <Border Background="Black" CornerRadius="6" Padding="12" Margin="0,0,0,12">
                        <TextBlock Text="{Binding RawFrame}" FontFamily="Consolas" Foreground="#00FF00" FontSize="14" TextWrapping="Wrap" MinHeight="40"/>
                    </Border>

                    <TextBlock Text="{StaticResource Diagnostics.SubstringPreview}" Foreground="Gray" FontSize="12" Margin="0,0,0,4"/>
                    <Border Background="Black" CornerRadius="6" Padding="12" Margin="0,0,0,12">
                        <TextBlock Text="{Binding SubstringPreview}" FontFamily="Consolas" Foreground="#3498db" FontSize="14" TextWrapping="Wrap" MinHeight="40"/>
                    </Border>

                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="{StaticResource Diagnostics.Weight}" Foreground="Gray" FontSize="12"/>
                            <TextBlock Text="{Binding LiveWeight, StringFormat='{}{0:N0} kg'}" FontSize="24" FontWeight="Bold" Foreground="{DynamicResource AccentBrush}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="{StaticResource Diagnostics.Stable}" Foreground="Gray" FontSize="12"/>
                            <TextBlock Text="{Binding LiveIsStable}" FontSize="24" FontWeight="Bold" Foreground="{DynamicResource ForegroundBrush}"/>
                        </StackPanel>
                    </Grid>

                    <StackPanel Orientation="Horizontal" Margin="0,4">
                        <TextBlock Text="{StaticResource Diagnostics.Parser}" Foreground="Gray"/>
                        <TextBlock Text="{Binding ParserType}" FontWeight="SemiBold" Foreground="{DynamicResource ForegroundBrush}"/>
                    </StackPanel>

                    <Border Background="#33FF0000" CornerRadius="6" Padding="8" Margin="0,8,0,0"
                            Visibility="{Binding DeviceError, Converter={StaticResource StringToVis}, FallbackValue=Collapsed}">
                        <TextBlock Text="{Binding DeviceError}" Foreground="Red" TextWrapping="Wrap"/>
                    </Border>
                </StackPanel>
            </Border>

            <Border Grid.Column="1" Background="{DynamicResource CardBrush}" CornerRadius="12" Padding="20" Margin="8,0,0,0">
                <StackPanel>
                    <TextBlock Text="{StaticResource Diagnostics.SyncTitle}" FontWeight="Bold" FontSize="16" Foreground="{DynamicResource ForegroundBrush}" Margin="0,0,0,16"/>

                    <TextBlock Text="{StaticResource Diagnostics.OutboxQueue}" Foreground="Gray" FontSize="12"/>
                    <TextBlock Text="{Binding PendingSyncCount}" FontSize="48" FontWeight="Bold" Foreground="#f1c40f" Margin="0,4,0,12"/>

                    <TextBlock Text="{StaticResource Diagnostics.CentralApiUrl}" Foreground="Gray" FontSize="12" Margin="0,8,0,4"/>
                    <TextBlock Text="{Binding CentralApiUrl}" FontSize="14" Foreground="{DynamicResource ForegroundBrush}" TextWrapping="Wrap"/>

                    <TextBlock Text="{StaticResource Diagnostics.MasterDataLastSync}" Foreground="Gray" FontSize="12" Margin="0,12,0,4"/>
                    <TextBlock Text="{Binding LastMasterDataSync}" FontSize="14" Foreground="{DynamicResource ForegroundBrush}"/>

                    <TextBlock Text="{StaticResource Diagnostics.MasterDataStatus}" Foreground="Gray" FontSize="12" Margin="0,12,0,4"/>
                    <TextBlock Text="{Binding MasterDataSyncStatus}" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource ForegroundBrush}"/>
                    <Border Background="#22FFAA00" CornerRadius="6" Padding="8" Margin="0,8,0,0"
                            Visibility="{Binding MasterDataSyncError, Converter={StaticResource StringToVis}, FallbackValue=Collapsed}">
                        <TextBlock Text="{Binding MasterDataSyncError}" Foreground="#D35400" TextWrapping="Wrap"/>
                    </Border>

                    <Separator Margin="0,16"/>

                    <TextBlock Text="{Binding AppVersion, StringFormat='Version: {0}'}" Foreground="Gray" FontSize="13" Margin="0,12,0,4"/>
                    <TextBlock Text="{Binding DbStatus, StringFormat='Database: {0}'}" Foreground="Gray" FontSize="13"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
