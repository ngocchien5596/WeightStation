<UserControl x:Class="StationApp.UI.Views.CrusherWeighingView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:StationApp.UI.Controls"
             Background="{StaticResource MainContentBackground}">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/StationApp.UI;component/Themes/AppTheme.xaml"/>
                <ResourceDictionary Source="/StationApp.UI;component/Styles/ButtonStyles.xaml"/>
                <ResourceDictionary Source="/StationApp.UI;component/Styles/InputStyles.xaml"/>
                <ResourceDictionary Source="/StationApp.UI;component/Styles/BasePageStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <Style x:Key="FormLabel" TargetType="TextBlock" BasedOn="{StaticResource FieldLabelStyle}">
                <Setter Property="VerticalAlignment" Value="Center"/>
                <Setter Property="Margin" Value="0,0,8,8"/>
            </Style>
            <Style x:Key="FormBox" TargetType="TextBox" BasedOn="{StaticResource StandardTextBoxStyle}">
                <Setter Property="Margin" Value="0,0,16,8"/>
            </Style>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Style="{StaticResource HeaderBorder}">
            <DockPanel>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Số xe" Style="{StaticResource HeaderLabel}" Margin="20,0,8,0"/>
                    <TextBox x:Name="InternalVehicleSearchBox"
                             Width="180"
                             Style="{StaticResource StandardTextBoxStyle}"
                             Text="{Binding SearchVehicle, UpdateSourceTrigger=PropertyChanged}"
                             KeyDown="SessionSearchBox_KeyDown"/>

                    <TextBlock Text="Số lượt cân" Style="{StaticResource HeaderLabel}" Margin="20,0,8,0"/>
                    <TextBox x:Name="SessionSearchBox"
                             Width="180"
                             Style="{StaticResource StandardTextBoxStyle}"
                             Text="{Binding SearchSessionNo, UpdateSourceTrigger=PropertyChanged}"
                             KeyDown="SessionSearchBox_KeyDown"/>

                    <Button Command="{Binding RefreshCommand}" Style="{StaticResource HeaderActionButton}" Margin="20,0,0,0">
                        <TextBlock Text="LÀM MỚI" VerticalAlignment="Center"/>
                    </Button>
                </StackPanel>
            </DockPanel>
        </Border>

        <Grid Grid.Row="1" Margin="12,10,12,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="420"/>
            </Grid.ColumnDefinitions>

            <Border BorderBrush="#D0D3D4" BorderThickness="1" CornerRadius="4" Padding="12" Background="White">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="150"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="150"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="34"/>
                        <RowDefinition Height="34"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Xe nội bộ" Style="{StaticResource FormLabel}"/>
                    <controls:AutocompleteTextBox Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="2"
                                                  State="{Binding InternalVehiclePlateInput}"
                                                  TextBoxStyle="{StaticResource FormBox}"/>
                    <Button Grid.Row="0" Grid.Column="3"
                            Command="{Binding ConfirmInternalVehicleCommand}"
                            Style="{StaticResource PrimaryButtonStyle}"
                            MinWidth="130"
                            Visibility="Collapsed"
                            Margin="0,0,0,8">
                        <TextBlock Text="CHỌN/TẠO XE" VerticalAlignment="Center"/>
                    </Button>

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Tài xế" Style="{StaticResource FormLabel}"/>
                    <TextBox Grid.Row="1" Grid.Column="1"
                             Text="{Binding SelectedDriverName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             IsReadOnly="{Binding IsVehicleFormReadOnly}"
                             Style="{StaticResource FormBox}"/>

                    <TextBlock Grid.Row="1" Grid.Column="2" Text="Chế độ cân" Style="{StaticResource FormLabel}"/>
                    <ComboBox Grid.Row="1" Grid.Column="3"
                              ItemsSource="{Binding WeighingModeOptions}"
                              SelectedValue="{Binding SelectedWeighingMode, Mode=TwoWay}"
                              SelectedValuePath="Value"
                              Style="{StaticResource StandardComboBoxStyle}"
                              Margin="0,0,0,8"/>

                    <TextBlock Grid.Row="2" Grid.Column="0" Text="TL xe chuẩn (kg)" Style="{StaticResource FormLabel}"/>
                    <TextBox Grid.Row="2" Grid.Column="1"
                             Text="{Binding StandardTareText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             IsReadOnly="{Binding IsVehicleFormReadOnly}"
                             Style="{StaticResource FormBox}"/>

                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Ghi chú" Style="{StaticResource FormLabel}" Visibility="Collapsed"/>
                    <TextBlock Grid.Row="3" Grid.Column="1" Grid.ColumnSpan="3"
                               Text="Cân một lần: KL hàng = Cân lần 1 - Trọng lượng xe chuẩn. Cân hai lần: KL hàng = |Cân lần 2 - Cân lần 1|."
                               Foreground="#607086"
                               VerticalAlignment="Center"
                               Visibility="Collapsed"/>

                    <TextBlock Grid.Row="4" Grid.Column="1" Grid.ColumnSpan="2"
                               Text="{Binding VehicleSelectionStatusText}"
                               Foreground="#0B5394"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"
                               TextWrapping="Wrap"
                               Margin="0,0,16,8"
                               Visibility="Collapsed"/>

                    <Button Grid.Row="4" Grid.Column="3"
                            Command="{Binding UpdateVehicleMasterDataCommand}"
                            Style="{StaticResource PrimaryButtonStyle}"
                            HorizontalAlignment="Left"
                            Margin="0,0,0,0"
                            MinWidth="150"
                            Visibility="Collapsed">
                        <TextBlock Text="CẬP NHẬT MASTER DATA" VerticalAlignment="Center"/>
                    </Button>
                </Grid>
            </Border>

            <Border Grid.Column="1" Margin="12,0,0,0" BorderBrush="#D0D3D4" BorderThickness="1" CornerRadius="4" Background="White" Padding="12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="64"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,8">
                        <RadioButton Content="Cân tự động"
                                     IsChecked="{Binding CurrentCaptureMode, Converter={StaticResource StringEqToBool}, ConverterParameter='T&#x1EF0; &#x0110;&#x1ED8;NG'}"
                                     Margin="0,0,24,0"
                                     FontWeight="SemiBold"
                                     IsEnabled="True"/>
                        <RadioButton Content="Cân tay"
                                     FontWeight="SemiBold"
                                     IsChecked="{Binding CurrentCaptureMode, Converter={StaticResource StringEqToBool}, ConverterParameter='C&#x00C2;N TAY'}"
                                     IsEnabled="{Binding CanUseManualMode}"
                                     Visibility="{Binding CanUseManualMode, Converter={StaticResource BoolToVis}}"/>
                    </StackPanel>

                    <Border Grid.Row="1" BorderBrush="#F1C40F" BorderThickness="1" Background="#FFF8C4" CornerRadius="4" Margin="0,0,0,8">
                        <Grid>
                            <TextBox Text="{Binding CurrentWeight, StringFormat={}{0:0.###}, UpdateSourceTrigger=LostFocus}"
                                     IsReadOnly="{Binding IsAutoMode}"
                                     FontSize="42"
                                     FontWeight="SemiBold"
                                     FontFamily="Consolas"
                                     Foreground="#000"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     HorizontalContentAlignment="Center"
                                     VerticalContentAlignment="Center"/>
                            <Border Background="{Binding StabilityBrush}"
                                    CornerRadius="10"
                                    Padding="8,2"
                                    Margin="8"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Bottom">
                                <TextBlock Text="{Binding StabilityText}" Foreground="White" FontSize="10" FontWeight="SemiBold"/>
                            </Border>
                        </Grid>
                    </Border>

                    <Grid Margin="10,4,10,6" Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="115"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="32"/>
                            <RowDefinition Height="32"/>
                            <RowDefinition Height="32"/>
                        </Grid.RowDefinitions>

                        <TextBlock Text="Cân lần 1" Grid.Row="0" Style="{StaticResource FormLabel}" Margin="0,0,8,0"/>
                        <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding DisplayWeight1, Mode=OneWay, StringFormat={}{0:N0}}" IsReadOnly="True" Style="{StaticResource FormBox}" Margin="0,3,16,3" Background="#F8F9F9"/>

                        <TextBlock Text="Cân lần 2" Grid.Row="1" Style="{StaticResource FormLabel}" Margin="0,0,8,0"/>
                        <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding DisplayWeight2, Mode=OneWay, StringFormat={}{0:N0}}" IsReadOnly="True" Style="{StaticResource FormBox}" Margin="0,3,16,3" Background="#F8F9F9"/>

                        <TextBlock Text="TL hàng (kg)" Grid.Row="2" Style="{StaticResource FormLabel}" Margin="0,0,8,0"/>
                        <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding DisplayNetWeight, Mode=OneWay, StringFormat={}{0:N0}}" IsReadOnly="True" Style="{StaticResource FormBox}" Margin="0,3,16,3" Background="#F8F9F9"/>
                    </Grid>

                    <Grid Grid.Row="3" Margin="10,0,10,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Button Grid.Column="0" Content="{Binding CaptureWeight1ButtonText}" Command="{Binding TakeCrusherWeight1Command}" Style="{StaticResource WorkflowButtonStyle}" MinHeight="34"/>
                        <Button Grid.Column="2" Command="{Binding TakeCrusherWeight2Command}" Style="{StaticResource PrimaryButtonStyle}" MinHeight="34" Visibility="Collapsed">
                            <TextBlock Text="CÂN LẦN 2" VerticalAlignment="Center"/>
                        </Button>
                        <Button Grid.Column="2" Content="C&#x00C2;N L&#x1EA6;N 2" Command="{Binding TakeCrusherWeight2Command}" Style="{StaticResource PrimaryButtonStyle}" MinHeight="34" Visibility="{Binding ShowCaptureWeight2Button, Converter={StaticResource BoolToVis}}"/>
                        <Button Grid.Column="4" Command="{Binding SaveCrusherWeighingCommand}" Style="{StaticResource PrimaryButtonStyle}" MinHeight="34" Visibility="Collapsed">
                            <TextBlock Text="LƯU" VerticalAlignment="Center"/>
                        </Button>
                        <Button Grid.Column="4" Content="LƯU" Command="{Binding SaveCrusherWeighingCommand}" Style="{StaticResource PrimaryButtonStyle}" MinHeight="34"/>
                        <Button Grid.Column="4" Content="L&#x01AF;U" Command="{Binding SaveCrusherWeighingCommand}" Style="{StaticResource PrimaryButtonStyle}" MinHeight="34"/>
                    </Grid>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="2" Margin="12,0,12,12">
            <DataGrid ItemsSource="{Binding Sessions}"
                      SelectedItem="{Binding SelectedSession, Mode=TwoWay}"
                      Style="{StaticResource SystemDataGridStyle}"
                      ColumnHeaderStyle="{StaticResource SystemDataGridColumnHeaderStyle}"
                      RowStyle="{StaticResource SystemDataGridRowStyle}"
                      CellStyle="{StaticResource SystemDataGridCellStyle}">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Số lượt cân" Binding="{Binding SessionNo}" Width="130" ElementStyle="{StaticResource GridTextCenter}"/>
                    <DataGridTextColumn Header="Số xe" Binding="{Binding VehiclePlate}" Width="120" ElementStyle="{StaticResource GridTextLeft}"/>
                    <DataGridTextColumn Header="Tài xế" Binding="{Binding DriverName}" Width="160" ElementStyle="{StaticResource GridTextLeft}"/>
                    <DataGridTextColumn Header="Chế độ cân" Binding="{Binding WeighingMode, Converter={StaticResource CrusherWeighingModeDisplayConverter}}" Width="180" ElementStyle="{StaticResource GridTextCenter}"/>
                    <DataGridTextColumn Header="Cân lần 1" Binding="{Binding Weight1, StringFormat={}{0:N0}}" Width="120" ElementStyle="{StaticResource GridTextRight}"/>
                    <DataGridTextColumn Header="Giờ cân 1" Binding="{Binding Weight1Time, StringFormat={}{0:dd/MM/yyyy HH:mm:ss}}" Width="170" ElementStyle="{StaticResource GridTextCenter}"/>
                    <DataGridTextColumn Header="Cân lần 2" Binding="{Binding Weight2, StringFormat={}{0:N0}}" Width="120" ElementStyle="{StaticResource GridTextRight}"/>
                    <DataGridTextColumn Header="Giờ cân 2" Binding="{Binding Weight2Time, StringFormat={}{0:dd/MM/yyyy HH:mm:ss}}" Width="170" ElementStyle="{StaticResource GridTextCenter}"/>
                    <DataGridTextColumn Header="TL xe chuẩn" Binding="{Binding StandardTareWeightSnapshot, StringFormat={}{0:N0}}" Width="120" ElementStyle="{StaticResource GridTextRight}"/>
                    <DataGridTextColumn Header="KL hàng" Binding="{Binding NetWeight, StringFormat={}{0:N0}}" Width="120" ElementStyle="{StaticResource GridTextRight}"/>
                    <DataGridTextColumn Header="Trạng thái" Binding="{Binding SessionStatus, Converter={StaticResource SessionStatusDisplay}}" Width="150" ElementStyle="{StaticResource GridTextCenter}"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</UserControl>
