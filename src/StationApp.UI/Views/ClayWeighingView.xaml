<UserControl x:Class="StationApp.UI.Views.ClayWeighingView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:StationApp.UI.Controls"
             Background="{StaticResource MainContentBackground}">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/StationApp.UI;component/Themes/AppTheme.xaml"/>
                <ResourceDictionary Source="/StationApp.UI;component/Styles/ButtonStyles.xaml"/>
                <ResourceDictionary Source="/StationApp.UI;component/Styles/InputStyles.xaml"/>
                <ResourceDictionary Source="/StationApp.UI;component/Styles/BasePageStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <Style x:Key="FormLabel" TargetType="TextBlock" BasedOn="{StaticResource FieldLabelStyle}">
                <Setter Property="HorizontalAlignment" Value="Right"/>
                <Setter Property="VerticalAlignment" Value="Center"/>
                <Setter Property="Margin" Value="0,0,20,0"/>
            </Style>
            <Style x:Key="FormBox" TargetType="TextBox" BasedOn="{StaticResource StandardTextBoxStyle}">
                <Setter Property="Margin" Value="0,2"/>
            </Style>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Style="{StaticResource HeaderBorder}">
            <DockPanel>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Ng&#x00E0;y th&#x1ED1;ng k&#x00EA;" Style="{StaticResource HeaderLabel}" Margin="0,0,8,0"/>
                    <DatePicker SelectedDate="{Binding SelectedDate, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                Width="168"
                                SelectedDateFormat="Short"
                                VerticalAlignment="Center"
                                Style="{StaticResource StandardDatePickerStyle}"/>

                    <TextBlock Text="S&#x1ED1; xe" Style="{StaticResource HeaderLabel}" Margin="20,0,8,0"/>
                    <TextBox x:Name="InternalVehicleSearchBox"
                             Width="180"
                             Style="{StaticResource StandardTextBoxStyle}"
                             Text="{Binding SearchVehicle, UpdateSourceTrigger=PropertyChanged}"
                             KeyDown="SessionSearchBox_KeyDown"/>

                    <Button Command="{Binding RefreshCommand}" Style="{StaticResource HeaderActionButton}" Margin="20,0,0,0">
                        <TextBlock Text="L&#x00C0;M M&#x1EDA;I" VerticalAlignment="Center"/>
                    </Button>
                </StackPanel>
            </DockPanel>
        </Border>

        <Grid Grid.Row="1" Margin="12,10,12,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="320"/>
                <ColumnDefinition Width="360"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">
                <Border BorderBrush="#D0D3D4" BorderThickness="1" CornerRadius="4" Padding="12" Background="White">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="30"/>
                            <RowDefinition Height="30"/>
                            <RowDefinition Height="30"/>
                            <RowDefinition Height="30"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Ch&#x1EBF; &#x0111;&#x1ED9; c&#x00E2;n" Style="{StaticResource FormLabel}"/>
                        <ComboBox Grid.Row="0" Grid.Column="1"
                                  ItemsSource="{Binding WeighingModeOptions}"
                                  SelectedValue="{Binding SelectedWeighingMode, Mode=TwoWay}"
                                  SelectedValuePath="Value"
                                  IsEnabled="{Binding CanEditCrusherInfoForm}"
                                  Style="{StaticResource StandardComboBoxStyle}"
                                  Margin="0,2"/>

                        <TextBlock Grid.Row="0" Grid.Column="2" Text="Số xe" Style="{StaticResource FormLabel}"/>
                        <controls:AutocompleteTextBox Grid.Row="0" Grid.Column="3"
                                                      State="{Binding InternalVehiclePlateInput}"
                                                      IsReadOnly="{Binding IsCrusherInfoFormReadOnly}"
                                                      TextBoxStyle="{StaticResource FormBox}"/>

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="TL bì (kg)" Style="{StaticResource FormLabel}"/>
                        <TextBox Grid.Row="1" Grid.Column="1"
                                 Text="{Binding StandardTareText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 IsReadOnly="True"
                                 Style="{StaticResource FormBox}"/>

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="M&#x00E3; SP" Style="{StaticResource FormLabel}"/>
                        <controls:AutocompleteTextBox Grid.Row="2" Grid.Column="1"
                                                      State="{Binding ProductCodeInput}"
                                                      IsReadOnly="{Binding IsCrusherInfoFormReadOnly}"
                                                      TextBoxStyle="{StaticResource FormBox}"/>

                        <TextBlock Grid.Row="2" Grid.Column="2" Text="S&#x1EA3;n ph&#x1EA9;m" Style="{StaticResource FormLabel}"/>
                        <controls:AutocompleteTextBox Grid.Row="2" Grid.Column="3"
                                                      State="{Binding ProductNameInput}"
                                                      IsReadOnly="{Binding IsCrusherInfoFormReadOnly}"
                                                      TextBoxStyle="{StaticResource FormBox}"/>

                        <TextBlock Grid.Row="3" Grid.Column="0" Text="M&#x00E3; KH" Style="{StaticResource FormLabel}"/>
                        <controls:AutocompleteTextBox Grid.Row="3" Grid.Column="1"
                                                      State="{Binding CustomerCodeInput}"
                                                      IsReadOnly="{Binding IsCrusherInfoFormReadOnly}"
                                                      TextBoxStyle="{StaticResource FormBox}"/>

                        <TextBlock Grid.Row="3" Grid.Column="2" Text="Kh&#x00E1;ch h&#x00E0;ng" Style="{StaticResource FormLabel}"/>
                        <controls:AutocompleteTextBox Grid.Row="3" Grid.Column="3"
                                                      State="{Binding CustomerNameInput}"
                                                      IsReadOnly="{Binding IsCrusherInfoFormReadOnly}"
                                                      TextBoxStyle="{StaticResource FormBox}"/>
                    </Grid>
                </Border>
                <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                    <Button Content="IN PC" Command="{Binding PrintWeighTicketCommand}" Style="{StaticResource UtilityButtonStyle}" Height="34" Width="120" Margin="0,0,8,0"/>
                    <Button Content="ĐỔI SỐ XE" Command="{Binding EditSessionVehicleCommand}" Style="{StaticResource PrimaryButtonStyle}" Height="34" Width="120"/>
                </StackPanel>
            </StackPanel>

            <Border Grid.Column="1" Margin="12,0,0,0" BorderBrush="#D0D3D4" BorderThickness="1" CornerRadius="4" Background="White" Padding="10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <DockPanel Margin="0,0,0,8">
                        <TextBlock Text="Camera" FontSize="13" FontWeight="SemiBold" Foreground="#2C3E50" VerticalAlignment="Center"/>
                        <ComboBox Style="{StaticResource StandardComboBoxStyle}"
                                  SelectedValue="{Binding SelectedPreviewCameraCode, Mode=TwoWay}"
                                  SelectedValuePath="Tag"
                                  Width="200"
                                  Height="28"
                                  HorizontalAlignment="Right"
                                  VerticalAlignment="Center"
                                  DockPanel.Dock="Right">
                            <ComboBoxItem Content="{Binding Camera1PreviewName}" Tag="CAM1" Visibility="{Binding ShowCamera1Selector, Converter={StaticResource BoolToVis}}"/>
                            <ComboBoxItem Content="{Binding Camera2PreviewName}" Tag="CAM2" Visibility="{Binding ShowCamera2Selector, Converter={StaticResource BoolToVis}}"/>
                        </ComboBox>
                    </DockPanel>

                    <Border Grid.Row="1"
                            BorderBrush="#D0D3D4"
                            BorderThickness="1"
                            CornerRadius="4"
                            Background="#F8F9F9"
                            MinHeight="180">
                        <Grid>
                            <Image Source="{Binding CameraPreviewSource}" Margin="8" Stretch="Uniform"/>
                            <TextBlock Text="{Binding CameraPreviewStatusText}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Foreground="#5D6D7E"
                                       FontWeight="SemiBold"
                                       Visibility="{Binding ShowCameraPreviewPlaceholder, Converter={StaticResource BoolToVis}}"/>
                        </Grid>
                    </Border>
                </Grid>
            </Border>

            <Border Grid.Column="2" Margin="12,0,0,0" BorderBrush="#D0D3D4" BorderThickness="1" CornerRadius="4" Background="White" Padding="12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="64"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,8">
                        <RadioButton Content="C&#x00E2;n t&#x1EF1; &#x0111;&#x1ED9;ng"
                                     IsChecked="{Binding CurrentCaptureMode, Converter={StaticResource StringEqToBool}, ConverterParameter='T&#x1EF0; &#x0110;&#x1ED8;NG'}"
                                     Margin="0,0,24,0"
                                     FontWeight="SemiBold"
                                     IsEnabled="True"/>
                        <RadioButton Content="C&#x00E2;n tay"
                                     FontWeight="SemiBold"
                                     IsChecked="{Binding CurrentCaptureMode, Converter={StaticResource StringEqToBool}, ConverterParameter='C&#x00C2;N TAY'}"
                                     IsEnabled="{Binding CanUseManualMode}"
                                     Visibility="{Binding CanUseManualMode, Converter={StaticResource BoolToVis}}"/>
                    </StackPanel>

                    <Border Grid.Row="1" BorderBrush="#F1C40F" BorderThickness="1" Background="#FFF8C4" CornerRadius="4" Margin="0,0,0,8">
                        <Grid>
                            <TextBox Text="{Binding CurrentWeight, StringFormat={}{0:0.###}, UpdateSourceTrigger=LostFocus}"
                                     IsReadOnly="{Binding IsAutoMode}"
                                     FontSize="42"
                                     FontWeight="SemiBold"
                                     FontFamily="Consolas"
                                     Foreground="#000"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     HorizontalContentAlignment="Center"
                                     VerticalContentAlignment="Center"/>
                            <Border Background="{Binding StabilityBrush}"
                                    CornerRadius="10"
                                    Padding="8,2"
                                    Margin="8"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Bottom">
                                <TextBlock Text="{Binding StabilityText}" Foreground="White" FontSize="10" FontWeight="SemiBold"/>
                            </Border>
                        </Grid>
                    </Border>

                    <Grid Margin="10,4,10,6" Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="115"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="32"/>
                            <RowDefinition Height="32"/>
                            <RowDefinition Height="32"/>
                        </Grid.RowDefinitions>

                        <TextBlock Text="C&#x00E2;n l&#x1EA7;n 1" Grid.Row="0" Style="{StaticResource FormLabel}" Margin="0,0,8,0"/>
                        <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding DisplayWeight1, Mode=OneWay, StringFormat={}{0:N0}}" IsReadOnly="True" Style="{StaticResource FormBox}" Margin="0,3,16,3" Background="#F8F9F9"/>

                        <TextBlock Text="C&#x00E2;n l&#x1EA7;n 2" Grid.Row="1" Style="{StaticResource FormLabel}" Margin="0,0,8,0"/>
                        <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding DisplayWeight2, Mode=OneWay, StringFormat={}{0:N0}}" IsReadOnly="True" Style="{StaticResource FormBox}" Margin="0,3,16,3" Background="#F8F9F9"/>

                        <TextBlock Text="TL h&#x00E0;ng (kg)" Grid.Row="2" Style="{StaticResource FormLabel}" Margin="0,0,8,0"/>
                        <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding DisplayNetWeight, Mode=OneWay, StringFormat={}{0:N0}}" IsReadOnly="True" Style="{StaticResource FormBox}" Margin="0,3,16,3" Background="#F8F9F9"/>
                    </Grid>

                    <Grid Grid.Row="3" Margin="10,0,10,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Button Grid.Column="0" Content="{Binding CaptureWeight1ButtonText}" Command="{Binding TakeCrusherWeight1Command}" Style="{StaticResource WorkflowButtonStyle}" MinHeight="34"/>
                        <Button Grid.Column="2" Content="C&#x00C2;N L&#x1EA6;N 2" Command="{Binding TakeCrusherWeight2Command}" Style="{StaticResource PrimaryButtonStyle}" MinHeight="34" Visibility="{Binding ShowCaptureWeight2Button, Converter={StaticResource BoolToVis}}"/>
                        <Button Grid.Column="4" Content="L&#x01AF;U" Command="{Binding SaveCrusherWeighingCommand}" Style="{StaticResource PrimaryButtonStyle}" MinHeight="34"/>
                    </Grid>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="2" Margin="12,0,12,12">
            <DataGrid ItemsSource="{Binding Sessions}"
                      SelectedItem="{Binding SelectedSession, Mode=TwoWay}"
                      Style="{StaticResource SystemDataGridStyle}"
                      ColumnHeaderStyle="{StaticResource SystemDataGridColumnHeaderStyle}"
                      RowStyle="{StaticResource SystemDataGridRowStyle}"
                      CellStyle="{StaticResource SystemDataGridCellStyle}">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="S&#x1ED1; l&#x01B0;&#x1EE3;t c&#x00E2;n" Binding="{Binding SessionNo}" Width="130" ElementStyle="{StaticResource GridTextCenter}"/>
                    <DataGridTextColumn Header="S&#x1ED1; xe" Binding="{Binding VehiclePlate}" Width="120" ElementStyle="{StaticResource GridTextLeft}"/>
                    <DataGridTextColumn Header="Ch&#x1EBF; &#x0111;&#x1ED9; c&#x00E2;n" Binding="{Binding WeighingMode, Converter={StaticResource CrusherWeighingModeDisplayConverter}}" Width="180" ElementStyle="{StaticResource GridTextCenter}"/>
                    <DataGridTextColumn Header="C&#x00E2;n l&#x1EA7;n 1" Binding="{Binding Weight1, StringFormat={}{0:N0}}" Width="120" ElementStyle="{StaticResource GridTextRight}"/>
                    <DataGridTextColumn Header="Gi&#x1EDD; c&#x00E2;n 1" Binding="{Binding Weight1Time, StringFormat={}{0:dd/MM/yyyy HH:mm:ss}}" Width="170" ElementStyle="{StaticResource GridTextCenter}"/>
                    <DataGridTextColumn Header="C&#x00E2;n l&#x1EA7;n 2" Binding="{Binding Weight2, StringFormat={}{0:N0}}" Width="120" ElementStyle="{StaticResource GridTextRight}"/>
                    <DataGridTextColumn Header="Gi&#x1EDD; c&#x00E2;n 2" Binding="{Binding Weight2Time, StringFormat={}{0:dd/MM/yyyy HH:mm:ss}}" Width="170" ElementStyle="{StaticResource GridTextCenter}"/>
                    <DataGridTextColumn Header="TL bì" Binding="{Binding StandardTareWeightSnapshot, StringFormat={}{0:N0}}" Width="120" ElementStyle="{StaticResource GridTextRight}"/>
                    <DataGridTextColumn Header="TL hàng" Binding="{Binding NetWeight, StringFormat={}{0:N0}}" Width="120" ElementStyle="{StaticResource GridTextRight}"/>
                    <DataGridTextColumn Header="S&#x1EA3;n ph&#x1EA9;m" Binding="{Binding ProductName}" Width="150" ElementStyle="{StaticResource GridTextLeft}"/>
                    <DataGridTextColumn Header="Kh&#x00E1;ch h&#x00E0;ng" Binding="{Binding CustomerName}" Width="180" ElementStyle="{StaticResource GridTextLeft}"/>
                    <DataGridTextColumn Header="Tr&#x1EA1;ng th&#x00E1;i" Binding="{Binding SessionStatus, Converter={StaticResource SessionStatusDisplay}}" Width="150" ElementStyle="{StaticResource GridTextCenter}"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</UserControl>


