<UserControl x:Class="StationApp.UI.Views.WeighingView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:StationApp.UI.Controls"
             Background="{StaticResource MainContentBackground}">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/StationApp.UI;component/Themes/AppTheme.xaml"/>
                <ResourceDictionary Source="/StationApp.UI;component/Styles/ButtonStyles.xaml"/>
                <ResourceDictionary Source="/StationApp.UI;component/Styles/InputStyles.xaml"/>
                <ResourceDictionary Source="/StationApp.UI;component/Styles/BasePageStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <Style x:Key="FormLabel" TargetType="TextBlock" BasedOn="{StaticResource FieldLabelStyle}">
                <Setter Property="Margin" Value="0,0,20,0"/>
                <Setter Property="HorizontalAlignment" Value="Right"/>
                <Setter Property="VerticalAlignment" Value="Center"/>
            </Style>
            <Style x:Key="FormBox" TargetType="TextBox" BasedOn="{StaticResource StandardTextBoxStyle}">
                <Setter Property="Margin" Value="0,2"/>
            </Style>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Style="{StaticResource HeaderBorder}">
            <DockPanel>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="{StaticResource Weighing.Search.VehiclePlate}" Style="{StaticResource HeaderLabel}" Margin="20,0,8,0"/>
                    <TextBox Width="160" Style="{StaticResource StandardTextBoxStyle}" Text="{Binding SearchVehiclePlate, UpdateSourceTrigger=PropertyChanged}">
                        <TextBox.InputBindings>
                            <KeyBinding Key="Enter" Command="{Binding LoadSessionsCommand}"/>
                        </TextBox.InputBindings>
                    </TextBox>

                    <TextBlock Text="M&#x00E3; c&#x1EAF;t l&#x1EC7;nh" Style="{StaticResource HeaderLabel}" Margin="20,0,8,0"/>
                    <TextBox Width="160" Style="{StaticResource StandardTextBoxStyle}" Text="{Binding SearchErpCutOrderId, UpdateSourceTrigger=PropertyChanged}">
                        <TextBox.InputBindings>
                            <KeyBinding Key="Enter" Command="{Binding LoadSessionsCommand}"/>
                        </TextBox.InputBindings>
                    </TextBox>

                    <TextBlock Text="{StaticResource Weighing.Search.SessionNo}" Style="{StaticResource HeaderLabel}" Margin="20,0,8,0"/>
                    <TextBox Width="160" Style="{StaticResource StandardTextBoxStyle}" Text="{Binding SearchSessionNo, UpdateSourceTrigger=PropertyChanged}">
                        <TextBox.InputBindings>
                            <KeyBinding Key="Enter" Command="{Binding LoadSessionsCommand}"/>
                        </TextBox.InputBindings>
                    </TextBox>

                    <Button Command="{Binding RefreshCommand}" Style="{StaticResource HeaderActionButton}" Margin="20,0,0,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE72C;" FontFamily="Segoe MDL2 Assets" FontSize="13" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBlock Text="{StaticResource Workflow.RefreshButton}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </DockPanel>
        </Border>

        <Grid Grid.Row="1" Margin="12,10,12,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="320"/>
                <ColumnDefinition Width="420"/>
            </Grid.ColumnDefinitions>

            <Border BorderBrush="#D0D3D4" BorderThickness="1" CornerRadius="4" Padding="12" Background="White">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="30"/>
                        <RowDefinition Height="30"/>
                        <RowDefinition Height="30"/>
                        <RowDefinition Height="30"/>
                        <RowDefinition Height="30"/>
                        <RowDefinition Height="30"/>
                        <RowDefinition Height="30"/>
                        <RowDefinition Height="30"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="{StaticResource Weighing.Label.SessionNo}" Grid.Row="0" Style="{StaticResource FormLabel}"/>
                    <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding SessionNo}" IsReadOnly="True" Style="{StaticResource FormBox}" Background="#F8F9F9"/>

                    <TextBlock Text="{StaticResource Weighing.Label.TransactionType}" Grid.Row="0" Grid.Column="2" Style="{StaticResource FormLabel}"/>
                    <TextBox Grid.Row="0" Grid.Column="3" Text="{Binding TransactionType, Converter={StaticResource TransactionTypeDisplayConverter}}" IsReadOnly="True" Style="{StaticResource FormBox}" Background="#F8F9F9"/>

                    <TextBlock Text="{StaticResource Weighing.Label.VehiclePlate}" Grid.Row="1" Style="{StaticResource FormLabel}"/>
                    <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding VehiclePlate}" IsReadOnly="True" Style="{StaticResource FormBox}" Background="#F8F9F9"/>

                    <TextBlock Text="{StaticResource Workflow.Label.Mooc}" Grid.Row="1" Grid.Column="2" Style="{StaticResource FormLabel}"/>
                    <TextBox Grid.Row="1" Grid.Column="3" Text="{Binding MoocNumber}" IsReadOnly="True" Style="{StaticResource FormBox}" Background="#F8F9F9"/>

                    <TextBlock Text="{StaticResource Weighing.Label.DriverName}" Grid.Row="2" Style="{StaticResource FormLabel}"/>
                    <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding DriverName}" IsReadOnly="True" Style="{StaticResource FormBox}" Background="#F8F9F9"/>

                    <TextBlock Text="{StaticResource Weighing.Label.Status}" Grid.Row="2" Grid.Column="2" Style="{StaticResource FormLabel}"/>
                    <TextBox Grid.Row="2" Grid.Column="3" Text="{Binding SessionStatusText}" IsReadOnly="True" Style="{StaticResource FormBox}" Background="#F8F9F9"/>

                    <TextBlock Text="{StaticResource Weighing.Label.Ttcp10}" Grid.Row="3" Style="{StaticResource FormLabel}"/>
                    <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding Ttcp10WeightSnapshot, StringFormat='{}{0:N0}'}" IsReadOnly="True" Style="{StaticResource FormBox}" Background="#F8F9F9"/>

                    <TextBlock Text="{StaticResource Weighing.Label.Customer}" Grid.Row="4" Style="{StaticResource FormLabel}"/>
                    <TextBox Grid.Row="4" Grid.Column="1" Grid.ColumnSpan="3" Text="{Binding CustomerSummary}" IsReadOnly="True" Style="{StaticResource FormBox}" Background="#F8F9F9"/>

                    <TextBlock Text="{StaticResource Weighing.Label.Product}" Grid.Row="5" Style="{StaticResource FormLabel}"/>
                    <TextBox Grid.Row="5" Grid.Column="1" Grid.ColumnSpan="3" Text="{Binding ProductSummary}" IsReadOnly="True" Style="{StaticResource FormBox}" Background="#F8F9F9"/>

                    <TextBlock Text="Ghi chú" Grid.Row="6" Style="{StaticResource FormLabel}"/>
                    <TextBox Grid.Row="6" Grid.Column="1" Grid.ColumnSpan="3" Text="{Binding NotesSummary}" IsReadOnly="True" Style="{StaticResource FormBox}" Background="#F8F9F9"/>

                    <TextBlock Text="" Grid.Row="7" Style="{StaticResource FormLabel}"/>
                    <CheckBox Grid.Row="7" Grid.Column="1"
                              IsChecked="{Binding UseActualWeightForBaggedCutOrders, Mode=TwoWay}"
                              VerticalAlignment="Center"
                              HorizontalAlignment="Left"
                              Margin="4,0,0,0"
                              Visibility="{Binding ShowBaggedActualWeightOverride, Converter={StaticResource BoolToVis}}"
                              Content="K LẤY ĐÚNG SỐ LƯỢNG"/>
                    <CheckBox Grid.Row="7" Grid.Column="2"
                              Grid.ColumnSpan="2"
                              IsChecked="{Binding IsNoLoadMarked, Mode=TwoWay}"
                              IsEnabled="{Binding CanToggleNoLoad}"
                              VerticalAlignment="Center"
                              HorizontalAlignment="Left"
                              Margin="4,0,0,0"
                              Content="{StaticResource Weighing.Action.NoLoad}"/>
                </Grid>
            </Border>

            <Border Grid.Column="1" Margin="12,0,0,0" BorderBrush="#D0D3D4" BorderThickness="1" CornerRadius="4" Background="White" Padding="10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <DockPanel Margin="0,0,0,8">
                        <TextBlock Text="Camera" FontSize="13" FontWeight="Bold" Foreground="#2C3E50" VerticalAlignment="Center"/>
                        <ComboBox Style="{StaticResource StandardComboBoxStyle}"
                                  SelectedValue="{Binding SelectedPreviewCameraCode, Mode=TwoWay}"
                                  SelectedValuePath="Tag"
                                  Width="200"
                                  Height="28"
                                  HorizontalAlignment="Right"
                                  VerticalAlignment="Center"
                                  DockPanel.Dock="Right">
                            <ComboBoxItem Content="{Binding Camera1PreviewName}" Tag="CAM1" Visibility="{Binding ShowCamera1Selector, Converter={StaticResource BoolToVis}}"/>
                            <ComboBoxItem Content="{Binding Camera2PreviewName}" Tag="CAM2" Visibility="{Binding ShowCamera2Selector, Converter={StaticResource BoolToVis}}"/>
                        </ComboBox>
                    </DockPanel>

                    <Border Grid.Row="1"
                            BorderBrush="#D0D3D4"
                            BorderThickness="1"
                            CornerRadius="4"
                            Background="#F8F9F9"
                            MinHeight="180">
                        <Grid>
                             <Image Source="{Binding CameraPreviewSource}" Margin="8" Stretch="Uniform"/>
                             <TextBlock Text="{Binding CameraPreviewStatusText}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Foreground="#5D6D7E"
                                       FontWeight="SemiBold"
                                       Visibility="{Binding ShowCameraPreviewPlaceholder, Converter={StaticResource BoolToVis}}"/>
                        </Grid>
                    </Border>
                </Grid>
            </Border>

            <Border Grid.Column="2" Margin="12,0,0,0" BorderBrush="#D0D3D4" BorderThickness="1" CornerRadius="4" Background="White" Padding="12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="64"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,8">
                        <RadioButton Content="{StaticResource Weighing.Mode.Auto}"
                                     IsChecked="{Binding CurrentCaptureMode, Converter={StaticResource StringEqToBool}, ConverterParameter='T&#x1EF0; &#x0110;&#x1ED8;NG'}"
                                     Margin="0,0,24,0"
                                     FontWeight="Bold"/>
                        <RadioButton Content="{StaticResource Weighing.Mode.Manual}"
                                     IsChecked="{Binding CurrentCaptureMode, Converter={StaticResource StringEqToBool}, ConverterParameter='C&#x00C2;N TAY'}"
                                     FontWeight="Bold"
                                     IsEnabled="{Binding CanUseManualMode}"
                                     Visibility="{Binding CanUseManualMode, Converter={StaticResource BoolToVis}}"/>
                    </StackPanel>

                    <Border Grid.Row="1" BorderThickness="1" CornerRadius="4" Background="#FDFDCC" BorderBrush="#F1C40F">
                        <Grid>
                            <TextBox Text="{Binding CurrentWeight, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, StringFormat='{}{0:0.###}'}"
                                     IsReadOnly="{Binding IsAutoMode}"
                                     FontSize="42"
                                     FontWeight="Bold"
                                     FontFamily="Consolas"
                                     HorizontalAlignment="Stretch"
                                     VerticalAlignment="Center"
                                     HorizontalContentAlignment="Center"
                                     VerticalContentAlignment="Center"
                                     BorderThickness="0"
                                     Background="Transparent"
                                     Foreground="Black"/>
                            <Border VerticalAlignment="Bottom" HorizontalAlignment="Right" Margin="8" Padding="8,2" CornerRadius="10" Background="{Binding StabilityBrush}">
                                <TextBlock Text="{Binding StabilityText}" Foreground="White" FontSize="10" FontWeight="Bold"/>
                            </Border>
                        </Grid>
                    </Border>

                    <Grid Margin="10,4,10,6" Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="95"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="32"/>
                            <RowDefinition Height="32"/>
                            <RowDefinition Height="32"/>
                        </Grid.RowDefinitions>

                        <TextBlock Text="{StaticResource Weighing.Weight1}" Grid.Row="0" Style="{StaticResource FormLabel}"/>
                        <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding Weight1, StringFormat='{}{0:N0}'}" IsReadOnly="True" Style="{StaticResource FormBox}" Background="#F8F9F9"/>

                        <TextBlock Text="{StaticResource Weighing.Weight2}" Grid.Row="1" Style="{StaticResource FormLabel}"/>
                        <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding Weight2, StringFormat='{}{0:N0}'}" IsReadOnly="True" Style="{StaticResource FormBox}" Background="#F8F9F9"/>

                        <TextBlock Text="{StaticResource Weighing.Label.NetWeight}" Grid.Row="2" Style="{StaticResource FormLabel}"/>
                        <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding NetWeight, StringFormat='{}{0:N0}'}" IsReadOnly="True" Style="{StaticResource FormBox}" Background="#F8F9F9"/>
                    </Grid>

                    <Grid Grid.Row="3" Margin="10,0,10,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Button Grid.Column="0"
                                Content="{StaticResource Weighing.Action.CaptureWeight1}"
                                Command="{Binding CaptureWeight1Command}"
                                Style="{StaticResource WorkflowButtonStyle}"
                                MinHeight="34"/>
                        <Button Grid.Column="2"
                                Content="{StaticResource Weighing.Action.CaptureWeight2}"
                                Command="{Binding CaptureWeight2Command}"
                                Style="{StaticResource PrimaryButtonStyle}"
                                MinHeight="34"/>
                        <Button Grid.Column="4"
                                Content="{StaticResource Weighing.Action.Save}"
                                Command="{Binding SaveCapturedWeightCommand}"
                                Style="{StaticResource PrimaryButtonStyle}"
                                MinHeight="34"/>
                    </Grid>
                </Grid>
            </Border>
        </Grid>

        <ItemsControl Grid.Row="2" HorizontalAlignment="Center" Margin="0,0,0,8">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <WrapPanel HorizontalAlignment="Center"/>
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <Button Content="{StaticResource Weighing.Action.AppendCutOrders}" Command="{Binding OpenAppendCutOrdersCommand}" Style="{StaticResource UtilityButtonStyle}" Margin="0,0,4,4"/>
            <Button Content="{StaticResource Weighing.Action.Allocate}"
                    Command="{Binding OpenAllocationCommand}"
                    Style="{StaticResource UtilityButtonStyle}"
                    Margin="0,0,4,4"
                    Visibility="{Binding ShowAllocationAction, Converter={StaticResource BoolToVis}}"/>
            <Button Content="{StaticResource Weighing.Action.HandleOverweight}" Command="{Binding ShowOverweightHandlingCommand}" Style="{StaticResource DangerButtonStyle}" Margin="0,0,4,4"/>
            <Button Content="IN PC" Command="{Binding PrintWeighTicketCommand}" Style="{StaticResource UtilityButtonStyle}" Margin="0,0,4,4"/>
            <Button Content="IN PGN" Command="{Binding PrintDeliveryTicketCommand}" Style="{StaticResource UtilityButtonStyle}" Margin="0,0,4,4"/>
            <Button Content="{StaticResource Weighing.Action.MoveOut}" Command="{Binding MoveToOutYardCommand}" Style="{StaticResource NeutralButtonStyle}" Margin="0,0,4,4"/>
            <Button Content="{StaticResource Weighing.Action.RelatedTickets}" Command="{Binding ShowRelatedTicketsCommand}" Style="{StaticResource NeutralButtonStyle}" Margin="0,0,4,4"/>
            <Button Content="Xem ảnh lịch sử" Command="{Binding ViewImageHistoryCommand}" Style="{StaticResource NeutralButtonStyle}" Margin="0,0,4,4"/>
        </ItemsControl>

        <Grid Grid.Row="3" Margin="12,0,12,12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/> <!-- Dòng 0: Tiêu đề lưới Mã cắt lệnh -->
                <RowDefinition Height="115"/>  <!-- Dòng 1: Lưới Mã cắt lệnh (Cố định chiều cao hiển thị 2 dòng) -->
                <RowDefinition Height="16"/>   <!-- Dòng 2: Khoảng cách giữa 2 lưới -->
                <RowDefinition Height="Auto"/> <!-- Dòng 3: Tiêu đề lưới Lượt cân -->
                <RowDefinition Height="*"/>    <!-- Dòng 4: Lưới Lượt cân (Chiếm toàn bộ không gian còn lại) -->
            </Grid.RowDefinitions>

            <!-- Tiêu đề và chỉ dẫn luồng cho Lưới Mã cắt lệnh (Detail) -->
            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,6">
                <TextBlock FontSize="12.5" FontWeight="Bold" Foreground="#34495E" VerticalAlignment="Center">
                    <Run Text="CHI TIẾT CẮT LỆNH"/>
                    <Run Text=" (Lượt cân: "/>
                    <Run Text="{Binding SelectedSession.SessionNo, FallbackValue='Chưa chọn', TargetNullValue='Chưa chọn'}" Foreground="#2980B9"/>
                    <Run Text=")"/>
                </TextBlock>
            </StackPanel>

            <!-- Lưới Mã cắt lệnh ở TRÊN (Cố định chiều cao, sử dụng Detail styles xám sáng phụ thuộc nhẹ nhàng, cố định 2 cột đầu) -->
            <Border Grid.Row="1" Background="#F8FAFC" BorderBrush="#CBD5E1" BorderThickness="1" CornerRadius="4" Height="115">
                <DataGrid ItemsSource="{Binding SessionLines}"
                          Style="{StaticResource DetailDataGridStyle}"
                          ColumnHeaderStyle="{StaticResource DetailDataGridColumnHeaderStyle}"
                          RowStyle="{StaticResource DetailDataGridRowStyle}"
                          CellStyle="{StaticResource DetailDataGridCellStyle}"
                          ScrollViewer.HorizontalScrollBarVisibility="Auto"
                          FrozenColumnCount="2">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="{StaticResource Weighing.Column.SequenceNo}" Binding="{Binding SequenceNo}" Width="50" ElementStyle="{StaticResource GridTextCenter}"/>
                        <DataGridTextColumn Header="{StaticResource Weighing.Column.CutOrderId}" Binding="{Binding ErpCutOrderId}" Width="150" ElementStyle="{StaticResource GridTextCenter}"/>
                        <DataGridTextColumn Header="{StaticResource Weighing.Column.Customer}" Binding="{Binding CustomerName}" Width="240" ElementStyle="{StaticResource GridTextLeft}"/>
                        <DataGridTextColumn Header="{StaticResource Weighing.Column.ProductCode}" Binding="{Binding ProductCode}" Width="120" ElementStyle="{StaticResource GridTextCenter}"/>
                        <DataGridTextColumn Header="{StaticResource Weighing.Column.Product}" Binding="{Binding ProductName}" Width="260" ElementStyle="{StaticResource GridTextLeft}"/>
                        <DataGridTextColumn Header="{StaticResource Weighing.Column.PlannedWeight}" Binding="{Binding PlannedWeight, StringFormat='{}{0:N0}'}" Width="110" ElementStyle="{StaticResource GridTextRight}"/>
                        <DataGridTextColumn Header="{StaticResource Weighing.Column.PlannedBags}" Binding="{Binding PlannedBagCount}" Width="90" ElementStyle="{StaticResource GridTextCenter}"/>
                        <DataGridTextColumn Header="{StaticResource Weighing.Column.ActualWeight}" Binding="{Binding ActualAllocatedWeight, StringFormat='{}{0:N0}'}" Width="120" ElementStyle="{StaticResource GridTextRight}"/>
                        <DataGridTextColumn Header="{StaticResource Weighing.Column.ActualBags}" Binding="{Binding ActualAllocatedBagCount}" Width="90" ElementStyle="{StaticResource GridTextCenter}"/>
                        <DataGridCheckBoxColumn Header="{StaticResource Weighing.Column.PrintDelivery}" Binding="{Binding HasPrintedDeliveryTicket, Mode=OneWay}" Width="70" ElementStyle="{StaticResource GridCheckBoxCenter}" Visibility="Collapsed"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>

            <!-- Tiêu đề và chỉ dẫn luồng cho Lưới Lượt cân (Master) -->
            <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,0,0,6">
                <TextBlock Text="DANH SÁCH LƯỢT CÂN HOẠT ĐỘNG" FontSize="12.5" FontWeight="Bold" Foreground="#203B73" VerticalAlignment="Center"/>
                <TextBlock Text="(Chọn một dòng lượt cân để hiển thị danh sách chi tiết mã cắt lệnh tương ứng ở phía trên)" FontSize="12" Foreground="#7F8C8D" FontStyle="Italic" VerticalAlignment="Center" Margin="10,0,0,0"/>
            </StackPanel>

            <!-- Lưới Lượt cân ở DƯỚI (Danh sách nhiều lượt cân xe, chiếm toàn bộ chiều cao còn lại, giữ Navy style chủ đạo, cố định 4 cột đầu) -->
            <Border Grid.Row="4" Background="White" BorderBrush="#ECF0F1" BorderThickness="1" CornerRadius="4">
                <DataGrid ItemsSource="{Binding Sessions}" SelectedItem="{Binding SelectedSession}"
                          Style="{StaticResource SystemDataGridStyle}"
                          ColumnHeaderStyle="{StaticResource SystemDataGridColumnHeaderStyle}"
                          RowStyle="{StaticResource SystemDataGridRowStyle}"
                          CellStyle="{StaticResource SystemDataGridCellStyle}"
                          ScrollViewer.HorizontalScrollBarVisibility="Auto"
                          FrozenColumnCount="4">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="{StaticResource Weighing.Column.SessionNo}" Binding="{Binding SessionNo}" Width="130" ElementStyle="{StaticResource GridTextCenter}"/>
                        <DataGridTextColumn Header="{StaticResource Incoming.Column.TransactionType}" Binding="{Binding TransactionType, Converter={StaticResource TransactionTypeDisplayConverter}}" Width="95" ElementStyle="{StaticResource GridTextCenter}"/>
                        <DataGridTextColumn Header="{StaticResource Weighing.Column.VehiclePlate}" Binding="{Binding VehiclePlate}" Width="100" ElementStyle="{StaticResource GridTextCenter}"/>
                        <DataGridTextColumn Header="{StaticResource Incoming.Column.Mooc}" Binding="{Binding MoocNumber}" Width="95" ElementStyle="{StaticResource GridTextCenter}"/>
                        <DataGridTextColumn Header="{StaticResource Incoming.Column.DriverName}" Binding="{Binding DriverName}" Width="130" ElementStyle="{StaticResource GridTextLeft}"/>
                        <DataGridTextColumn Header="{StaticResource Weighing.Column.Customer}" Binding="{Binding CustomerSummary}" Width="220" ElementStyle="{StaticResource GridTextLeft}"/>
                        <DataGridTextColumn Header="{StaticResource Weighing.Column.Product}" Binding="{Binding ProductSummary}" Width="240" ElementStyle="{StaticResource GridTextLeft}"/>
                        <DataGridTextColumn Header="{StaticResource Weighing.Label.Ttcp10}" Binding="{Binding Ttcp10WeightSnapshot, StringFormat='{}{0:N0}'}" Width="100" ElementStyle="{StaticResource GridTextRight}"/>
                        <DataGridTextColumn Header="{StaticResource Weighing.Weight1}" Binding="{Binding Weight1, StringFormat='{}{0:N0}'}" Width="100" ElementStyle="{StaticResource GridTextRight}"/>
                        <DataGridTextColumn Header="{StaticResource Weighing.Weight2}" Binding="{Binding Weight2, StringFormat='{}{0:N0}'}" Width="100" ElementStyle="{StaticResource GridTextRight}"/>
                        <DataGridTextColumn Header="{StaticResource Weighing.Column.Net}" Binding="{Binding NetWeight, StringFormat='{}{0:N0}'}" Width="100" ElementStyle="{StaticResource GridTextRight}"/>
                        <DataGridTextColumn Header="{StaticResource Weighing.Column.Status}" Binding="{Binding SessionStatus, Converter={StaticResource SessionStatusDisplay}}" Width="135" ElementStyle="{StaticResource GridTextCenter}"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>
        </Grid>

        <Grid Style="{StaticResource ModalOverlayStyle}" Visibility="{Binding IsAppendCutOrdersVisible, Converter={StaticResource BoolToVis}}" Grid.RowSpan="4">
            <Border Style="{StaticResource ModalShellStyle}" MaxWidth="1240" MaxHeight="720" VerticalAlignment="Center" Margin="16">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Style="{StaticResource ModalHeaderStyle}">
                        <TextBlock Text="{StaticResource Weighing.Dialog.AppendCutOrdersTitle}" Style="{StaticResource ModalTitleStyle}"/>
                    </Border>

                    <Border Grid.Row="1" Style="{StaticResource ModalBodyStyle}">
                        <StackPanel>
                            <Border Margin="0,0,0,12"
                                    Padding="12,10"
                                    Background="#FFF7E6"
                                    BorderBrush="#F5C26B"
                                    BorderThickness="1"
                                    CornerRadius="4"
                                    Visibility="{Binding AppendCutOrdersWarningMessage, Converter={StaticResource StringToVis}}">
                                <TextBlock Text="{Binding AppendCutOrdersWarningMessage}"
                                           Foreground="#8A5A00"
                                           FontWeight="SemiBold"
                                           TextWrapping="Wrap"/>
                            </Border>

                            <Border Style="{StaticResource ModalSectionCardStyle}">
                                <DataGrid ItemsSource="{Binding AppendCutOrderCandidates}"
                                          Style="{StaticResource SystemDataGridStyle}"
                                          ColumnHeaderStyle="{StaticResource SystemDataGridColumnHeaderStyle}"
                                          RowStyle="{StaticResource SystemDataGridRowStyle}"
                                          CellStyle="{StaticResource SystemDataGridCellStyle}"
                                          AutoGenerateColumns="False"
                                          IsReadOnly="False"
                                          Background="Transparent"
                                          BorderThickness="0"
                                          ScrollViewer.HorizontalScrollBarVisibility="Auto">
                                    <DataGrid.Columns>
                                        <DataGridCheckBoxColumn Header="{StaticResource Incoming.Column.Select}" Binding="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="60" ElementStyle="{StaticResource GridCheckBoxCenter}" EditingElementStyle="{StaticResource GridCheckBoxCenterEditable}"/>
                                        <DataGridTextColumn Header="{StaticResource Incoming.Column.CutOrderId}" Binding="{Binding ErpCutOrderId}" Width="150" IsReadOnly="True"/>
                                        <DataGridTextColumn Header="{StaticResource Incoming.Column.TransactionType}" Binding="{Binding TransactionType, Converter={StaticResource TransactionTypeDisplayConverter}}" Width="95" IsReadOnly="True"/>
                                        <DataGridTextColumn Header="{StaticResource Incoming.Column.TransportMethod}" Binding="{Binding TransportMethod, Converter={StaticResource TransportMethodDisplayConverter}}" Width="95" IsReadOnly="True"/>
                                        <DataGridTextColumn Header="{StaticResource Incoming.Column.VehiclePlate}" Binding="{Binding VehiclePlate}" Width="110" IsReadOnly="True"/>
                                        <DataGridTextColumn Header="{StaticResource Incoming.Column.Mooc}" Binding="{Binding MoocNumber}" Width="110" IsReadOnly="True"/>
                                        <DataGridTextColumn Header="{StaticResource Incoming.Column.DriverName}" Binding="{Binding ReceiverName}" Width="150" IsReadOnly="True"/>
                                        <DataGridTextColumn Header="{StaticResource Incoming.Column.CustomerName}" Binding="{Binding CustomerName}" Width="240" IsReadOnly="True"/>
                                        <DataGridTextColumn Header="{StaticResource Incoming.Column.ProductCode}" Binding="{Binding ProductCode}" Width="130" IsReadOnly="True"/>
                                        <DataGridTextColumn Header="{StaticResource Incoming.Column.ProductName}" Binding="{Binding ProductName}" Width="250" IsReadOnly="True"/>
                                        <DataGridTextColumn Header="{StaticResource Incoming.Column.PlannedWeight}" Binding="{Binding PlannedWeight, StringFormat='{}{0:N0}'}" Width="115" IsReadOnly="True"/>
                                        <DataGridTextColumn Header="{StaticResource Incoming.Column.BagCount}" Binding="{Binding BagCount}" Width="90" IsReadOnly="True"/>
                                        <DataGridTextColumn Header="{StaticResource Incoming.Column.CreatedAt}" Binding="{Binding CreatedAt, StringFormat='{}{0:dd/MM/yyyy HH:mm}'}" Width="150" IsReadOnly="True"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Border>
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="2" Style="{StaticResource ModalFooterStyle}">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Content="{StaticResource Weighing.Action.Confirm}" Command="{Binding ConfirmAppendCutOrdersCommand}" Style="{StaticResource PrimaryButtonStyle}" Margin="0,0,8,0"/>
                            <Button Content="{StaticResource Workflow.CloseButton}" Command="{Binding CloseAppendCutOrdersCommand}" Style="{StaticResource UtilityButtonStyle}"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <Grid Style="{StaticResource ModalOverlayStyle}" Visibility="{Binding IsAllocationVisible, Converter={StaticResource BoolToVis}}" Grid.RowSpan="4">
            <Border Style="{StaticResource ModalShellStyle}" MaxWidth="1100" VerticalAlignment="Center" Margin="16">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Style="{StaticResource ModalHeaderStyle}">
                        <TextBlock Text="{StaticResource Weighing.Dialog.AllocationTitle}" Style="{StaticResource ModalTitleStyle}"/>
                    </Border>

                    <Border Grid.Row="1" Style="{StaticResource ModalBodyStyle}">
                        <Border Style="{StaticResource ModalSectionCardStyle}">
                            <DataGrid ItemsSource="{Binding AllocationLines}"
                                      Style="{StaticResource SystemDataGridStyle}"
                                      ColumnHeaderStyle="{StaticResource SystemDataGridColumnHeaderStyle}"
                                      RowStyle="{StaticResource SystemDataGridRowStyle}"
                                      CellStyle="{StaticResource SystemDataGridCellStyle}"
                                      AutoGenerateColumns="False"
                                      IsReadOnly="False"
                                      Background="Transparent"
                                      BorderThickness="0"
                                      ScrollViewer.HorizontalScrollBarVisibility="Auto">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="{StaticResource Weighing.Column.SequenceNo}" Binding="{Binding SequenceNo}" Width="50" IsReadOnly="True"/>
                                    <DataGridTextColumn Header="{StaticResource Weighing.Column.CutOrderId}" Binding="{Binding ErpCutOrderId}" Width="150" IsReadOnly="True"/>
                                    <DataGridTextColumn Header="{StaticResource Weighing.Column.Customer}" Binding="{Binding CustomerName}" Width="240" IsReadOnly="True"/>
                                    <DataGridTextColumn Header="{StaticResource Weighing.Column.Product}" Binding="{Binding ProductName}" Width="250" IsReadOnly="True"/>
                                    <DataGridTextColumn Header="{StaticResource Weighing.Column.PlannedWeight}" Binding="{Binding PlannedWeight, StringFormat='{}{0:N0}'}" Width="110" IsReadOnly="True"/>
                                    <DataGridTextColumn Header="{StaticResource Weighing.Column.PlannedBags}" Binding="{Binding PlannedBagCount}" Width="90" IsReadOnly="True"/>
                                    <DataGridCheckBoxColumn Header="{StaticResource Weighing.Column.Priority}" Binding="{Binding IsPriority, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="85" ElementStyle="{StaticResource GridCheckBoxCenter}" EditingElementStyle="{StaticResource GridCheckBoxCenterEditable}"/>
                                    <DataGridTextColumn Header="{StaticResource Weighing.Column.ActualWeight}" Binding="{Binding ActualAllocatedWeight, UpdateSourceTrigger=PropertyChanged, StringFormat='{}{0:N0}'}" Width="120"/>
                                    <DataGridTextColumn Header="{StaticResource Weighing.Column.ActualBags}" Binding="{Binding ActualAllocatedBagCount, UpdateSourceTrigger=PropertyChanged}" Width="90" IsReadOnly="True"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Border>
                    </Border>

                    <Border Grid.Row="2" Style="{StaticResource ModalFooterStyle}">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Content="{StaticResource Weighing.Action.AllocateByPlan}" Command="{Binding AllocateByPlanCommand}" Style="{StaticResource NeutralButtonStyle}" Margin="0,0,8,0"/>
                            <Button Content="{StaticResource Weighing.Action.Confirm}" Command="{Binding ConfirmAllocationCommand}" Style="{StaticResource PrimaryButtonStyle}" Margin="0,0,8,0"/>
                            <Button Content="{StaticResource Workflow.CloseButton}" Command="{Binding CloseAllocationCommand}" Style="{StaticResource UtilityButtonStyle}"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <Grid Style="{StaticResource ModalOverlayStyle}" Visibility="{Binding IsOverweightHandlingVisible, Converter={StaticResource BoolToVis}}" Grid.RowSpan="4">
            <Border Style="{StaticResource ModalShellStyle}" MaxWidth="1180" MaxHeight="700" VerticalAlignment="Center" Margin="16">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Style="{StaticResource ModalHeaderStyle}">
                        <TextBlock Text="{StaticResource Weighing.Dialog.OverweightTitle}" Style="{StaticResource ModalTitleStyle}"/>
                    </Border>

                    <Border Grid.Row="1" Style="{StaticResource ModalBodyStyle}" Padding="16,12,16,10">
                        <StackPanel>
                            <Border Style="{StaticResource ModalSectionCardStyle}">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="18"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Row="0">
                                        <TextBlock Text="{StaticResource Weighing.Dialog.Overweight.Ticket1}" FontWeight="Bold" Margin="0,0,0,6"/>
                                        <TextBox Text="{Binding OverweightSplitTicket1WeightText, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FormBox}"/>
                                    </StackPanel>
                                    <StackPanel Grid.Row="0" Grid.Column="2">
                                        <TextBlock Text="{StaticResource Weighing.Dialog.Overweight.Ticket2}" FontWeight="Bold" Margin="0,0,0,6"/>
                                        <TextBox Text="{Binding OverweightSplitTicket2WeightText, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FormBox}"/>
                                    </StackPanel>

                                    <TextBlock Grid.Row="1" Grid.ColumnSpan="3"
                                               Text="{Binding OverweightSplitValidationMessage}"
                                               Foreground="#C0392B"
                                               FontWeight="SemiBold"
                                               Margin="0,12,0,0"
                                               Visibility="{Binding OverweightSplitValidationMessage, Converter={StaticResource StringToVis}}"/>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="2" Style="{StaticResource ModalBodyStyle}" Padding="16,0,16,14">
                        <Grid>
                            <Border Style="{StaticResource ModalSectionCardStyle}">
                                <DataGrid ItemsSource="{Binding OverweightPreviewLines}" AutoGenerateColumns="False" IsReadOnly="True"
                                          Style="{StaticResource SystemDataGridStyle}"
                                          ColumnHeaderStyle="{StaticResource SystemDataGridColumnHeaderStyle}"
                                          RowStyle="{StaticResource SystemDataGridRowStyle}"
                                          CellStyle="{StaticResource SystemDataGridCellStyle}"
                                          Background="Transparent"
                                          BorderThickness="0"
                                          ScrollViewer.HorizontalScrollBarVisibility="Auto">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="{StaticResource Weighing.Column.Group}" Binding="{Binding SplitSequence}" Width="65"/>
                                        <DataGridTextColumn Header="{StaticResource Weighing.Column.SequenceNo}" Binding="{Binding SequenceNo}" Width="55"/>
                                        <DataGridTextColumn Header="{StaticResource Weighing.Column.CutOrderId}" Binding="{Binding ErpCutOrderId}" Width="150"/>
                                        <DataGridTextColumn Header="{StaticResource Weighing.Column.Customer}" Binding="{Binding CustomerName}" Width="240"/>
                                        <DataGridTextColumn Header="{StaticResource Weighing.Column.Product}" Binding="{Binding ProductName}" Width="250"/>
                                        <DataGridTextColumn Header="{StaticResource Weighing.Column.Weight}" Binding="{Binding AllocatedWeight, StringFormat='{}{0:N0}'}" Width="120"/>
                                        <DataGridTextColumn Header="{StaticResource Weighing.Column.BagCount}" Binding="{Binding AllocatedBagCount}" Width="80"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Border>
                        </Grid>
                    </Border>

                    <Border Grid.Row="3" Style="{StaticResource ModalFooterStyle}">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Content="{StaticResource Weighing.Dialog.Overweight.Split}" Command="{Binding ConfirmOverweightSplitCommand}" Style="{StaticResource DangerButtonStyle}" Margin="0,0,8,0"/>
                            <Button Content="{StaticResource Weighing.Dialog.Overweight.NoSplit}" Command="{Binding ConfirmOverweightNoSplitCommand}" Style="{StaticResource NeutralButtonStyle}" Margin="0,0,8,0"/>
                            <Button Content="{StaticResource Workflow.CloseButton}" Command="{Binding CloseOverweightHandlingCommand}" Style="{StaticResource UtilityButtonStyle}"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <Grid Style="{StaticResource ModalOverlayStyle}" Visibility="{Binding IsRelatedTicketsVisible, Converter={StaticResource BoolToVis}}" Grid.RowSpan="4">
            <Border Style="{StaticResource ModalShellStyle}" MaxWidth="1060" MaxHeight="680" VerticalAlignment="Center" Margin="16">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Style="{StaticResource ModalHeaderStyle}">
                        <TextBlock Text="{StaticResource Weighing.Dialog.RelatedTitle}" Style="{StaticResource ModalTitleStyle}"/>
                    </Border>

                    <Border Grid.Row="1" Style="{StaticResource ModalBodyStyle}">
                        <Border Style="{StaticResource ModalSectionCardStyle}">
                            <DataGrid ItemsSource="{Binding RelatedTickets}" AutoGenerateColumns="False" IsReadOnly="True"
                                      Style="{StaticResource SystemDataGridStyle}"
                                      ColumnHeaderStyle="{StaticResource SystemDataGridColumnHeaderStyle}"
                                      RowStyle="{StaticResource SystemDataGridRowStyle}"
                                      CellStyle="{StaticResource SystemDataGridCellStyle}"
                                      Background="Transparent"
                                      BorderThickness="0">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="{StaticResource Weighing.Column.Type}" Binding="{Binding DocumentType}" Width="180"/>
                                    <DataGridTextColumn Header="{StaticResource Weighing.Column.WeighTicketNo}" Binding="{Binding TicketNo}" Width="140"/>
                                    <DataGridTextColumn Header="{StaticResource Weighing.Column.DeliveryNo}" Binding="{Binding DeliveryNo}" Width="140"/>
                                    <DataGridTextColumn Header="{StaticResource Weighing.Column.Role}" Binding="{Binding RecordRole, Converter={StaticResource RecordRoleDisplay}}" Width="180"/>
                                    <DataGridTextColumn Header="{StaticResource Weighing.Weight1}" Binding="{Binding Weight1, StringFormat='{}{0:N0}'}" Width="110"/>
                                    <DataGridTextColumn Header="{StaticResource Weighing.Weight2}" Binding="{Binding Weight2, StringFormat='{}{0:N0}'}" Width="110"/>
                                    <DataGridTextColumn Header="{StaticResource Weighing.Column.Net}" Binding="{Binding NetWeight, StringFormat='{}{0:N0}'}" Width="110"/>
                                    <DataGridTextColumn Header="{StaticResource Weighing.Column.CreatedAt}" Binding="{Binding CreatedAt, StringFormat='{}{0:dd/MM HH:mm}'}" Width="150"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Border>
                    </Border>

                    <Border Grid.Row="2" Style="{StaticResource ModalFooterStyle}">
                        <Button Content="{StaticResource Workflow.CloseButton}" Command="{Binding CloseRelatedTicketsCommand}" Style="{StaticResource UtilityButtonStyle}" Width="100" HorizontalAlignment="Right"/>
                    </Border>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
