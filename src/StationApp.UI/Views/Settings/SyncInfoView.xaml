<UserControl x:Class="StationApp.UI.Views.Settings.SyncInfoView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="720"
             d:DesignWidth="1200"
             Background="Transparent">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/StationApp.UI;component/Themes/AppTheme.xaml"/>
                <ResourceDictionary Source="/StationApp.UI;component/Styles/ButtonStyles.xaml"/>
                <ResourceDictionary Source="/StationApp.UI;component/Styles/InputStyles.xaml"/>
                <ResourceDictionary Source="/StationApp.UI;component/Styles/BasePageStyles.xaml"/>
                <ResourceDictionary Source="/StationApp.UI;component/Resources/MonitoringTextResources.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <Style x:Key="SyncMetricCardStyle" TargetType="Border" BasedOn="{StaticResource ModalMetricCardStyle}">
                <Setter Property="Margin" Value="0,0,0,0"/>
            </Style>

            <Style x:Key="SyncMetricTimeValueStyle" TargetType="TextBlock" BasedOn="{StaticResource ModalMetricValueStyle}">
                <Setter Property="FontSize" Value="16"/>
                <Setter Property="TextWrapping" Value="Wrap"/>
            </Style>

            <Style x:Key="SyncErrorBodyStyle" TargetType="TextBlock">
                <Setter Property="Foreground" Value="#A61E1E"/>
                <Setter Property="FontSize" Value="13"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="TextWrapping" Value="Wrap"/>
            </Style>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid Background="#FFFFFF" Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0"
                       Text="{StaticResource Sync.Title}"
                       FontSize="18"
                       FontWeight="SemiBold"
                       Foreground="#123B6B"
                       VerticalAlignment="Center"/>

            <StackPanel Grid.Column="1"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right">
                <Button Command="{Binding ShowMetricsCommand}"
                        Style="{StaticResource WorkflowButtonStyle}"
                        Margin="0,0,12,0">
                    <TextBlock Text="CHI TI&#x1EBE;T TH&#x1ED0;NG K&#xCA;" VerticalAlignment="Center"/>
                </Button>

                <Button Command="{Binding RefreshCommand}"
                        Style="{StaticResource UtilityButtonStyle}"
                        Margin="0,0,12,0">
                    <TextBlock Text="{StaticResource Sync.Refresh}" VerticalAlignment="Center"/>
                </Button>

                <Button Command="{Binding ResyncSelectedCommand}"
                        Style="{StaticResource UtilityButtonStyle}"
                        Margin="0,0,12,0">
                    <TextBlock Text="&#x110;&#x1ED2;NG B&#x1ED8; L&#x1EA0;I CH&#x1EE8;NG T&#x1EEA;" VerticalAlignment="Center"/>
                </Button>

                <Button Command="{Binding ForceSyncCommand}"
                        Style="{StaticResource WorkflowButtonStyle}"
                        ToolTip="&#x110;&#x01B0;a t&#x1EA5;t c&#x1EA3; ch&#x1EE9;ng t&#x1EEB; ch&#x01B0;a sync th&#xE0;nh c&#xF4;ng v&#xE0;o h&#xE0;ng &#x111;&#x1EE3;i &#x111;&#x1ED3;ng b&#x1ED9; l&#x1EA1;i, bao g&#x1ED3;m FAILED_FINAL.">
                    <TextBlock Text="{StaticResource Sync.Force}" VerticalAlignment="Center"/>
                </Button>
            </StackPanel>
        </Grid>

        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="220"/>
                    <ColumnDefinition Width="220"/>
                    <ColumnDefinition Width="320"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <ComboBox Grid.Column="0"
                          ItemsSource="{Binding AggregateTypeOptions}"
                          SelectedItem="{Binding SelectedAggregateType, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                          Style="{StaticResource StandardComboBoxStyle}"
                          Margin="0,0,12,0"/>

                <ComboBox Grid.Column="1"
                          ItemsSource="{Binding OutboxStatusOptions}"
                          SelectedItem="{Binding SelectedOutboxStatus, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                          Style="{StaticResource StandardComboBoxStyle}"
                          Margin="0,0,12,0"/>

                <TextBox Grid.Column="2"
                         Text="{Binding SearchKeyword, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource SearchTextBoxStyle}"
                         Margin="0,0,12,0"/>

                <Button Grid.Column="3"
                        Command="{Binding RefreshCommand}"
                        Style="{StaticResource HeaderActionButton}">
                    <TextBlock Text="{StaticResource Sync.Reload}"/>
                </Button>
            </Grid>

            <Grid Grid.Row="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" BorderBrush="#D7E3F0" BorderThickness="1" CornerRadius="6">
                    <DataGrid x:Name="SyncItemsGrid"
                              ItemsSource="{Binding SyncItems}"
                              SelectedItem="{Binding SelectedSyncItem, Mode=TwoWay}"
                              AutoGenerateColumns="False"
                              Style="{StaticResource SystemDataGridStyle}"
                              ColumnHeaderStyle="{StaticResource SystemDataGridColumnHeaderStyle}"
                              CellStyle="{StaticResource SystemDataGridCellStyle}"
                              ScrollViewer.HorizontalScrollBarVisibility="Auto">
                        <DataGrid.RowStyle>
                            <Style TargetType="DataGridRow" BasedOn="{StaticResource SystemDataGridRowStyle}">
                                <Setter Property="Tag"
                                        Value="{Binding DataContext, ElementName=SyncItemsGrid}"/>
                                <Setter Property="ContextMenu">
                                    <Setter.Value>
                                        <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                                            <MenuItem Header="&#x110;&#x1ED2;NG B&#x1ED8; L&#x1EA0;I CH&#x1EE8;NG T&#x1EEA; N&#xC0;Y;"
                                                      Command="{Binding PlacementTarget.Tag.ResyncItemCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                      CommandParameter="{Binding}"/>
                                        </ContextMenu>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </DataGrid.RowStyle>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="{StaticResource Sync.ColAggregate}" Binding="{Binding AggregateType}" Width="120" ElementStyle="{StaticResource GridTextCenter}"/>
                            <DataGridTextColumn Header="{StaticResource Sync.ColBusinessNo}" Binding="{Binding BusinessNo}" Width="145" ElementStyle="{StaticResource GridTextCenter}"/>
                            <DataGridTextColumn Header="{StaticResource Sync.ColSessionNo}" Binding="{Binding SessionNo}" Width="150" ElementStyle="{StaticResource GridTextCenter}"/>
                            <DataGridTextColumn Header="{StaticResource Sync.ColVehiclePlate}" Binding="{Binding VehiclePlate}" Width="110" ElementStyle="{StaticResource GridTextCenter}"/>
                            <DataGridTextColumn Header="Sync entity" Binding="{Binding EntitySyncStatus}" Width="110" ElementStyle="{StaticResource GridTextCenter}"/>
                            <DataGridTextColumn Header="Outbox" Binding="{Binding OutboxStatus}" Width="120" ElementStyle="{StaticResource GridTextCenter}"/>
                            <DataGridTextColumn Header="Retry" Binding="{Binding RetryCount}" Width="70" ElementStyle="{StaticResource GridTextCenter}"/>
                            <DataGridTextColumn Header="{StaticResource Sync.ColCreatedAt}" Binding="{Binding CreatedAt, StringFormat='dd/MM/yyyy HH:mm:ss'}" Width="155" ElementStyle="{StaticResource GridTextCenter}"/>
                            <DataGridTextColumn Header="{StaticResource Sync.ColUpdatedAt}" Binding="{Binding UpdatedAt, StringFormat='dd/MM/yyyy HH:mm:ss'}" Width="155" ElementStyle="{StaticResource GridTextCenter}"/>
                            <DataGridTextColumn Header="{StaticResource Sync.ColNextRetry}" Binding="{Binding NextRetryAt, StringFormat='dd/MM/yyyy HH:mm:ss'}" Width="155" ElementStyle="{StaticResource GridTextCenter}"/>
                            <DataGridTextColumn Header="{StaticResource Sync.ColLastError}" Binding="{Binding LastError}" Width="340" ElementStyle="{StaticResource GridTextLeft}"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Border>

                <Border Grid.Row="1"
                        Background="#F8FBFE"
                        BorderBrush="#D7E3F0"
                        BorderThickness="1,0,1,1"
                        CornerRadius="0,0,6,6"
                        Padding="10,8">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0"
                                   Text="{Binding PageSummary}"
                                   VerticalAlignment="Center"
                                   FontSize="13"
                                   Foreground="#50627A"/>

                        <Button Grid.Column="1"
                                Command="{Binding PreviousPageCommand}"
                                IsEnabled="{Binding CanGoToPreviousPage}"
                                Style="{StaticResource UtilityButtonStyle}"
                                Margin="0,0,8,0"
                                Width="42"
                                Height="30"
                                Padding="0">
                            <TextBlock Text="&lt;" FontSize="16" FontWeight="Bold"/>
                        </Button>

                        <Button Grid.Column="2"
                                Command="{Binding NextPageCommand}"
                                IsEnabled="{Binding CanGoToNextPage}"
                                Style="{StaticResource UtilityButtonStyle}"
                                Width="42"
                                Height="30"
                                Padding="0">
                            <TextBlock Text="&gt;" FontSize="16" FontWeight="Bold"/>
                        </Button>
                    </Grid>
                </Border>
            </Grid>
        </Grid>

        <Grid Grid.RowSpan="2"
              Style="{StaticResource ModalOverlayStyle}"
              Visibility="{Binding IsMetricsVisible, Converter={StaticResource BoolToVis}}">
            <Border Style="{StaticResource ModalShellStyle}"
                    Width="860"
                    MaxWidth="860"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Style="{StaticResource ModalHeaderStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0"
                                       Text="CHI TI&#x1EBE;T TH&#x1ED0;NG K&#xCA; &#x110;&#x1ED2;NG B&#x1ED8;"
                                       Style="{StaticResource ModalTitleStyle}"
                                       VerticalAlignment="Center"/>

                            <Button Grid.Column="1"
                                    Command="{Binding CloseMetricsCommand}"
                                    Width="34"
                                    Height="34"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Foreground="White">
                                <TextBlock Text="&#xE711;" FontFamily="Segoe MDL2 Assets" FontSize="14" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                            </Button>
                        </Grid>
                    </Border>

                    <Border Grid.Row="1" Style="{StaticResource ModalBodyStyle}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Border Grid.Row="0" Grid.Column="0" Style="{StaticResource SyncMetricCardStyle}" Margin="0,0,8,12">
                                <StackPanel>
                                    <TextBlock Text="S&#x1ED0; B&#x1EA2;N GHI SYNC B&#x1ECA; L&#x1ED6;I" Style="{StaticResource ModalMetricLabelStyle}"/>
                                    <TextBlock Text="{Binding FailedSyncCount}" Style="{StaticResource ModalMetricValueStyle}" Foreground="#BD2730"/>
                                </StackPanel>
                            </Border>

                            <Border Grid.Row="0" Grid.Column="1" Style="{StaticResource SyncMetricCardStyle}" Margin="8,0,0,12">
                                <StackPanel>
                                    <TextBlock Text="S&#x1ED0; B&#x1EA2;N GHI SYNC TH&#xC0;NH C&#xD4;NG" Style="{StaticResource ModalMetricLabelStyle}"/>
                                    <TextBlock Text="{Binding SuccessSyncCount}" Style="{StaticResource ModalMetricValueStyle}" Foreground="#0C8A43"/>
                                </StackPanel>
                            </Border>

                            <Border Grid.Row="1" Grid.Column="0" Style="{StaticResource SyncMetricCardStyle}" Margin="0,0,8,12">
                                <StackPanel>
                                    <TextBlock Text="SYNC L&#x1ED6;I G&#x1EA6;N NH&#x1EA4;T" Style="{StaticResource ModalMetricLabelStyle}"/>
                                    <TextBlock Text="{Binding LastSyncFailureAt}" Style="{StaticResource SyncMetricTimeValueStyle}" Foreground="#BD2730"/>
                                </StackPanel>
                            </Border>

                            <Border Grid.Row="1" Grid.Column="1" Style="{StaticResource SyncMetricCardStyle}" Margin="8,0,0,12">
                                <StackPanel>
                                    <TextBlock Text="SYNC TH&#xC0;NH C&#xD4;NG G&#x1EA6;N NH&#x1EA4;T" Style="{StaticResource ModalMetricLabelStyle}"/>
                                    <TextBlock Text="{Binding LastSyncSuccessAt}" Style="{StaticResource SyncMetricTimeValueStyle}" Foreground="#0C8A43"/>
                                </StackPanel>
                            </Border>

                            <Border Grid.Row="2" Grid.ColumnSpan="2" Style="{StaticResource ModalSectionCardStyle}">
                                <StackPanel>
                                    <TextBlock Text="N&#x1ED8;I DUNG L&#x1ED6;I G&#x1EA6;N NH&#x1EA4;T" Style="{StaticResource ModalMetricLabelStyle}"/>
                                    <TextBlock Text="{Binding LastSyncError}" Style="{StaticResource SyncErrorBodyStyle}" Margin="0,8,0,0"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Border>

                    <Border Grid.Row="2" Style="{StaticResource ModalFooterStyle}">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Command="{Binding CloseMetricsCommand}"
                                    Style="{StaticResource UtilityButtonStyle}">
                                <TextBlock Text="&#x110;&#xD3;NG"/>
                            </Button>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
