<UserControl x:Class="StationApp.UI.Views.Settings.SystemSettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="720"
             d:DesignWidth="860"
             Background="Transparent">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/StationApp.UI;component/Themes/AppTheme.xaml"/>
                <ResourceDictionary Source="/StationApp.UI;component/Styles/ButtonStyles.xaml"/>
                <ResourceDictionary Source="/StationApp.UI;component/Styles/InputStyles.xaml"/>
                <ResourceDictionary Source="/StationApp.UI;component/Styles/BasePageStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <Style x:Key="FormLabel" TargetType="TextBlock" BasedOn="{StaticResource FieldLabelStyle}">
                <Setter Property="Foreground" Value="#2C3E50"/>
                <Setter Property="Margin" Value="0,0,16,12"/>
            </Style>

            <Style x:Key="FormBox" TargetType="TextBox" BasedOn="{StaticResource StandardTextBoxStyle}">
                <Setter Property="Height" Value="32"/>
                <Setter Property="Padding" Value="8,4"/>
                <Setter Property="VerticalContentAlignment" Value="Center"/>
                <Setter Property="MinWidth" Value="360"/>
            </Style>

            <Style x:Key="FormPasswordBox" TargetType="PasswordBox" BasedOn="{StaticResource StandardPasswordBoxStyle}">
                <Setter Property="Height" Value="32"/>
                <Setter Property="Padding" Value="8,4"/>
                <Setter Property="MinWidth" Value="360"/>
            </Style>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid Background="#F8FAFC">
        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <Grid Margin="16" MaxWidth="900" HorizontalAlignment="Center">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        Background="#FFFFFF"
                        BorderBrush="#E2E8F0"
                        BorderThickness="1"
                        Padding="24"
                        CornerRadius="8"
                        VerticalAlignment="Top">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
                            <TextBlock Text="&#xE713;"
                                       FontFamily="Segoe MDL2 Assets"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       Foreground="#123B6B"
                                       VerticalAlignment="Center"/>
                            <TextBlock Text="THAM SỐ HỆ THỐNG"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       Foreground="#123B6B"
                                       Margin="8,0,0,0"
                                       VerticalAlignment="Center"/>
                        </StackPanel>

                        <Separator Grid.Row="1" Background="#E2E8F0" Height="1" Margin="0,0,0,20"/>

                        <Grid Grid.Row="2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="280"/>
                                <ColumnDefinition Width="480"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Column="0" Grid.Row="0" Text="Mã trạm (Station Code)" Style="{StaticResource FormLabel}" VerticalAlignment="Center"/>
                            <TextBox Grid.Column="1" Grid.Row="0" Text="{Binding StationCode, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FormBox}" Margin="0,0,0,12"/>

                            <TextBlock Grid.Column="0" Grid.Row="1" Text="Tiền tố phiếu cân" Style="{StaticResource FormLabel}" VerticalAlignment="Center"/>
                            <TextBox Grid.Column="1" Grid.Row="1" Text="{Binding TicketPrefix, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FormBox}" Margin="0,0,0,12"/>

                            <TextBlock Grid.Column="0" Grid.Row="2" Text="Tiền tố phiếu giao nhận" Style="{StaticResource FormLabel}" VerticalAlignment="Center"/>
                            <TextBox Grid.Column="1" Grid.Row="2" Text="{Binding DeliveryPrefix, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FormBox}" Margin="0,0,0,12"/>

                            <TextBlock Grid.Column="0" Grid.Row="3" Text="Dung sai cho 1 bao (kg/bao)" Style="{StaticResource FormLabel}" VerticalAlignment="Center"/>
                            <TextBox Grid.Column="1" Grid.Row="3" Text="{Binding ToleranceKgPerBag, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FormBox}" Margin="0,0,0,12"/>

                            <TextBlock Grid.Column="0" Grid.Row="4" Text="Chu kỳ đồng bộ (giây)" Style="{StaticResource FormLabel}" VerticalAlignment="Center"/>
                            <TextBox Grid.Column="1" Grid.Row="4" Text="{Binding SyncIntervalSeconds, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FormBox}" Margin="0,0,0,12"/>

                            <TextBlock Grid.Column="0" Grid.Row="5" Text="Thời gian thăm dò ERP (giây)" Style="{StaticResource FormLabel}" VerticalAlignment="Center"/>
                            <TextBox Grid.Column="1" Grid.Row="5" Text="{Binding RegistrationInboundPollSeconds, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FormBox}" Margin="0,0,0,12"/>

                            <TextBlock Grid.Column="0" Grid.Row="6" Text="Bước tách quá tải (tỷ lệ)" Style="{StaticResource FormLabel}" VerticalAlignment="Center"/>
                            <TextBox Grid.Column="1" Grid.Row="6" Text="{Binding OverweightSplitStepWeight, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FormBox}" Margin="0,0,0,12"/>

                            <TextBlock Grid.Column="0" Grid.Row="7" Text="Central API URL" Style="{StaticResource FormLabel}" VerticalAlignment="Center"/>
                            <TextBox Grid.Column="1" Grid.Row="7" Text="{Binding CentralApiUrl, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FormBox}" Margin="0,0,0,12"/>

                            <TextBlock Grid.Column="0" Grid.Row="8" Text="Central API Key" Style="{StaticResource FormLabel}" VerticalAlignment="Center"/>
                            <PasswordBox x:Name="CentralApiKeyBox"
                                         Grid.Column="1"
                                         Grid.Row="8"
                                         PasswordChanged="CentralApiKeyBox_OnPasswordChanged"
                                         Style="{StaticResource FormPasswordBox}"
                                         Margin="0,0,0,12"/>

                            <TextBlock Grid.Column="0" Grid.Row="9" Text="Thư mục backup DB local" Style="{StaticResource FormLabel}" VerticalAlignment="Center"/>
                            <TextBox Grid.Column="1"
                                     Grid.Row="9"
                                     Text="{Binding LocalDatabaseBackupDirectory, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource FormBox}"
                                     Margin="0,0,0,12"
                                     ToolTip="Để trống để dùng mặc định: C:\ProgramData\StationApp\SqlBackups"/>

                            <TextBlock Grid.Column="0"
                                       Grid.Row="10"
                                       Text="Trạng thái kết nối"
                                       Style="{StaticResource FormLabel}"
                                       VerticalAlignment="Top"/>
                            <Grid Grid.Column="1" Grid.Row="10">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <Button Grid.Row="0"
                                        Command="{Binding TestCentralApiConnectionCommand}"
                                        Style="{StaticResource UtilityButtonStyle}"
                                        Width="180"
                                        Height="32"
                                        HorizontalAlignment="Right">
                                    <TextBlock Text="KIỂM TRA KẾT NỐI" FontWeight="SemiBold"/>
                                </Button>

                                <Border Grid.Row="1"
                                        Margin="0,10,0,0"
                                        Padding="10,8"
                                        Background="#F8FAFC"
                                        BorderBrush="#D5E3F2"
                                        BorderThickness="1"
                                        CornerRadius="6">
                                    <TextBlock Text="{Binding CentralApiHealthMessage, TargetNullValue=Chưa kiểm tra kết nối Central API.}"
                                               Foreground="#334155"
                                               TextWrapping="Wrap"/>
                                </Border>
                            </Grid>
                        </Grid>
                    </Grid>
                </Border>

                <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,20,0,0" HorizontalAlignment="Right">
                    <Button Command="{Binding LoadCommand}" Style="{StaticResource UtilityButtonStyle}" Margin="0,0,12,0" MinWidth="120" Height="36">
                        <TextBlock Text="LÀM MỚI" VerticalAlignment="Center" FontWeight="SemiBold"/>
                    </Button>
                    <Button Command="{Binding SaveCommand}" Style="{StaticResource PrimaryButtonStyle}" MinWidth="160" Height="36">
                        <TextBlock Text="LƯU THAY ĐỔI" VerticalAlignment="Center" FontWeight="SemiBold"/>
                    </Button>
                </StackPanel>
            </Grid>
        </ScrollViewer>
    </Grid>
</UserControl>
