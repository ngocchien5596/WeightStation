<UserControl x:Class="StationApp.UI.Views.Settings.ProductMasterView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:helpers="clr-namespace:StationApp.UI.Helpers"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="700" d:DesignWidth="1000"
             Background="Transparent">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/StationApp.UI;component/Themes/AppTheme.xaml"/>
                <ResourceDictionary Source="/StationApp.UI;component/Styles/ButtonStyles.xaml"/>
                <ResourceDictionary Source="/StationApp.UI;component/Styles/InputStyles.xaml"/>
                <ResourceDictionary Source="/StationApp.UI;component/Styles/BasePageStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <Style x:Key="FormLabel" TargetType="TextBlock" BasedOn="{StaticResource FieldLabelStyle}">
                <Setter Property="Margin" Value="0,4,0,2"/>
            </Style>
            <Style x:Key="FormBox" TargetType="TextBox" BasedOn="{StaticResource StandardTextBoxStyle}"/>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid Background="#FFFFFF">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#E8EFF7" Margin="12" Padding="16" CornerRadius="4">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" Text="M&#x00E3; s&#x1EA3;n ph&#x1EA9;m" Style="{StaticResource FormLabel}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBox Grid.Column="1"
                             Text="{Binding SearchCode, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource SearchTextBoxStyle}"
                             helpers:EnterKeySearch.Command="{Binding SearchCommand}"
                             Margin="0,0,16,0"/>

                    <TextBlock Grid.Column="2" Text="T&#x00EA;n s&#x1EA3;n ph&#x1EA9;m" Style="{StaticResource FormLabel}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBox Grid.Column="3"
                             Text="{Binding SearchName, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource SearchTextBoxStyle}"
                             helpers:EnterKeySearch.Command="{Binding SearchCommand}"
                             Margin="0,0,16,0"/>

                    <Button Grid.Column="4" Command="{Binding SearchCommand}" Style="{StaticResource UtilityButtonStyle}" Height="32" VerticalAlignment="Center">
                        <TextBlock Text="T&#x00CC;M KI&#x1EBE;M" VerticalAlignment="Center"/>
                    </Button>
                </Grid>

                <Separator Grid.Row="1" Background="#CCCCCC" Margin="0,0,0,16"/>

                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="220"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" Text="M&#x00E3; s&#x1EA3;n ph&#x1EA9;m *" Style="{StaticResource FormLabel}" VerticalAlignment="Center" Margin="0,0,8,8"/>
                    <TextBox Grid.Column="1" Text="{Binding EditCode, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FormBox}" Margin="0,0,16,8"/>

                    <TextBlock Grid.Column="2" Text="T&#x00EA;n s&#x1EA3;n ph&#x1EA9;m *" Style="{StaticResource FormLabel}" VerticalAlignment="Center" Margin="0,0,8,8"/>
                    <TextBox Grid.Column="3" Text="{Binding EditName, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FormBox}" Margin="0,0,16,8"/>

                    <TextBlock Grid.Column="4" Text="Lo&#x1EA1;i s&#x1EA3;n ph&#x1EA9;m *" Style="{StaticResource FormLabel}" VerticalAlignment="Center" Margin="0,0,8,8"/>
                    <ComboBox Grid.Column="5"
                              ItemsSource="{Binding ProductTypeOptions}"
                              SelectedItem="{Binding EditType, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                              Style="{StaticResource StandardComboBoxStyle}"
                              Margin="0,0,0,8"/>
                </Grid>

                <Grid Grid.Row="3" Margin="0,16,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <CheckBox Grid.Column="0"
                              Content="&#x0110;ang ho&#x1EA1;t &#x0111;&#x1ED9;ng"
                              IsChecked="{Binding EditIsActive}"
                              Style="{StaticResource StandardCheckBoxStyle}"
                              VerticalAlignment="Center"/>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Command="{Binding ResetFormCommand}" Style="{StaticResource UtilityButtonStyle}" Margin="0,0,12,0">
                            <TextBlock Text="L&#x00C0;M M&#x1EDA;I" VerticalAlignment="Center"/>
                        </Button>
                        <Button Command="{Binding SaveCommand}" Style="{StaticResource PrimaryButtonStyle}" Margin="0,0,12,0">
                            <TextBlock Text="L&#x01AF;U" VerticalAlignment="Center"/>
                        </Button>
                        <Button Command="{Binding DeactivateCommand}" Style="{StaticResource DangerButtonStyle}">
                            <TextBlock Text="NG&#x1EEA;NG S&#x1EEC; D&#x1EE4;NG" VerticalAlignment="Center"/>
                        </Button>
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>

        <Border Grid.Row="1" Margin="12,0,12,12">
            <DataGrid ItemsSource="{Binding Products}"
                      SelectedItem="{Binding SelectedProduct}"
                      Style="{StaticResource SystemDataGridStyle}"
                      ColumnHeaderStyle="{StaticResource SystemDataGridColumnHeaderStyle}"
                      RowStyle="{StaticResource SystemDataGridRowStyle}"
                      CellStyle="{StaticResource SystemDataGridCellStyle}"
                      ScrollViewer.HorizontalScrollBarVisibility="Auto">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="M&#x00E3; s&#x1EA3;n ph&#x1EA9;m" Binding="{Binding ProductCode}" Width="170" ElementStyle="{StaticResource GridTextCenter}"/>
                    <DataGridTextColumn Header="T&#x00EA;n s&#x1EA3;n ph&#x1EA9;m" Binding="{Binding ProductName}" Width="300" ElementStyle="{StaticResource GridTextLeft}"/>
                    <DataGridTextColumn Header="Lo&#x1EA1;i s&#x1EA3;n ph&#x1EA9;m" Binding="{Binding ProductType}" Width="140" ElementStyle="{StaticResource GridTextCenter}"/>
                    <DataGridCheckBoxColumn Header="Ho&#x1EA1;t &#x0111;&#x1ED9;ng" Binding="{Binding IsActive}" Width="100" ElementStyle="{StaticResource GridCheckBoxCenter}" EditingElementStyle="{StaticResource GridCheckBoxCenterEditable}"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</UserControl>
