<UserControl x:Class="StationApp.UI.Views.Settings.VehicleMasterView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:helpers="clr-namespace:StationApp.UI.Helpers"
             xmlns:enums="clr-namespace:StationApp.Domain.Enums;assembly=StationApp.Domain"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="700" d:DesignWidth="1000"
             Background="Transparent">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/StationApp.UI;component/Themes/AppTheme.xaml"/>
                <ResourceDictionary Source="/StationApp.UI;component/Styles/ButtonStyles.xaml"/>
                <ResourceDictionary Source="/StationApp.UI;component/Styles/InputStyles.xaml"/>
                <ResourceDictionary Source="/StationApp.UI;component/Styles/BasePageStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <BooleanToVisibilityConverter x:Key="BoolToVis"/>

            <Style x:Key="FormLabel" TargetType="TextBlock" BasedOn="{StaticResource FieldLabelStyle}">
                <Setter Property="Margin" Value="0,4,0,2"/>
            </Style>
            <Style x:Key="FormBox" TargetType="TextBox" BasedOn="{StaticResource StandardTextBoxStyle}"/>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid Background="#FFFFFF">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#E8EFF7" Margin="12" Padding="16" CornerRadius="4">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" Text="Bi&#x1EC3;n s&#x1ED1; xe" Style="{StaticResource FormLabel}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBox Grid.Column="1"
                             Text="{Binding SearchVehiclePlate, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource SearchTextBoxStyle}"
                             helpers:EnterKeySearch.Command="{Binding SearchCommand}"
                             Margin="0,0,16,0"/>

                    <TextBlock Grid.Column="2" Text="S&#x1ED1; Mooc" Style="{StaticResource FormLabel}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBox Grid.Column="3"
                             Text="{Binding SearchMoocNumber, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource SearchTextBoxStyle}"
                             helpers:EnterKeySearch.Command="{Binding SearchCommand}"
                             Margin="0,0,16,0"/>

                    <TextBlock Grid.Column="4" Text="T&#x00E0;i x&#x1EBF;" Style="{StaticResource FormLabel}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBox Grid.Column="5"
                             Text="{Binding SearchDriverName, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource SearchTextBoxStyle}"
                             helpers:EnterKeySearch.Command="{Binding SearchCommand}"
                             Margin="0,0,16,0"/>

                    <Button Grid.Column="6" Command="{Binding SearchCommand}" Style="{StaticResource UtilityButtonStyle}" Height="32" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE721;" FontFamily="Segoe MDL2 Assets" FontSize="13" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBlock Text="T&#x00CC;M KI&#x1EBE;M" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </Grid>

                <Separator Grid.Row="1" Background="#CCCCCC" Margin="0,0,0,16"/>

                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Column="0" Grid.Row="0" Text="S&#x1ED1; PTVC *" Style="{StaticResource FormLabel}" VerticalAlignment="Center" Margin="0,0,8,8"/>
                    <TextBox Grid.Column="1" Grid.Row="0" Text="{Binding EditVehiclePlate, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FormBox}" Margin="0,0,16,8"/>

                    <TextBlock Grid.Column="2" Grid.Row="0" Text="S&#x1ED1; Mooc" Style="{StaticResource FormLabel}" VerticalAlignment="Center" Margin="0,0,8,8"/>
                    <TextBox Grid.Column="3" Grid.Row="0" Text="{Binding EditMoocNumber, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FormBox}" Margin="0,0,16,8"/>

                    <TextBlock Grid.Column="4" Grid.Row="0" Text="T&#x00E0;i x&#x1EBF;" Style="{StaticResource FormLabel}" VerticalAlignment="Center" Margin="0,0,8,8"/>
                    <TextBox Grid.Column="5" Grid.Row="0" Text="{Binding EditDriverName, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FormBox}" Margin="0,0,16,8"/>

                    <TextBlock Grid.Column="6" Grid.Row="0" Text="HTVC" Style="{StaticResource FormLabel}" VerticalAlignment="Center" Margin="0,0,8,8"/>
                    <ComboBox Grid.Column="7" Grid.Row="0"
                              SelectedValue="{Binding EditTransportMethod, UpdateSourceTrigger=PropertyChanged}"
                              SelectedValuePath="Tag"
                              Style="{StaticResource StandardComboBoxStyle}"
                              Margin="0,0,0,8">
                        <ComboBoxItem Content="Đường bộ" Tag="{x:Static enums:TransportMethod.ROAD}"/>
                        <ComboBoxItem Content="Đường thủy" Tag="{x:Static enums:TransportMethod.WATERWAY}"/>
                    </ComboBox>

                    <TextBlock Grid.Column="0" Grid.Row="1" Text="TTCP (kg)" Style="{StaticResource FormLabel}" VerticalAlignment="Center" Margin="0,0,8,8"/>
                    <TextBox Grid.Column="1" Grid.Row="1" Text="{Binding EditTtcpWeight, ConverterCulture='vi-VN', StringFormat='{}{0:N0}', UpdateSourceTrigger=LostFocus}" Style="{StaticResource FormBox}" Margin="0,0,16,8"/>

                    <TextBlock Grid.Column="2" Grid.Row="1" Text="S&#x1ED1; &#x0110;K Xe" Style="{StaticResource FormLabel}" VerticalAlignment="Center" Margin="0,0,8,8"/>
                    <TextBox Grid.Column="3" Grid.Row="1" Text="{Binding EditVehicleRegistrationNo, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FormBox}" Margin="0,0,16,8"/>

                    <TextBlock Grid.Column="4" Grid.Row="1" Text="H&#x1EA1;n &#x0110;K Xe" Style="{StaticResource FormLabel}" VerticalAlignment="Center" Margin="0,0,8,8"/>
                    <DatePicker Grid.Column="5" Grid.Row="1" SelectedDate="{Binding EditVehicleRegistrationExpiryDate}" Style="{StaticResource StandardDatePickerStyle}" Margin="0,0,16,8"/>

                    <TextBlock Grid.Column="6" Grid.Row="1" Text="S&#x1ED1; &#x0110;K Mooc" Style="{StaticResource FormLabel}" VerticalAlignment="Center" Margin="0,0,8,8"/>
                    <TextBox Grid.Column="7" Grid.Row="1" Text="{Binding EditMoocRegistrationNo, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FormBox}" Margin="0,0,0,8"/>

                    <TextBlock Grid.Column="0" Grid.Row="2" Text="H&#x1EA1;n &#x0110;K Mooc" Style="{StaticResource FormLabel}" VerticalAlignment="Center" Margin="0,0,8,8"/>
                    <DatePicker Grid.Column="1" Grid.Row="2" SelectedDate="{Binding EditMoocRegistrationExpiryDate}" Style="{StaticResource StandardDatePickerStyle}" Margin="0,0,16,8"/>

                    <CheckBox Grid.Column="2" Grid.Row="2" Grid.ColumnSpan="2" Content="&#x0110;ang ho&#x1EA1;t &#x0111;&#x1ED9;ng" IsChecked="{Binding EditIsActive}" Style="{StaticResource StandardCheckBoxStyle}" Margin="0,0,16,8"/>
                </Grid>

                <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,16,0,0">
                    <Button Command="{Binding ResetFormCommand}" Style="{StaticResource UtilityButtonStyle}" Margin="0,0,12,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE72C;" FontFamily="Segoe MDL2 Assets" FontSize="13" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBlock Text="L&#x00C0;M M&#x1EDA;I" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding SaveCommand}" Style="{StaticResource PrimaryButtonStyle}" Margin="0,0,12,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE74E;" FontFamily="Segoe MDL2 Assets" FontSize="13" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBlock Text="L&#x01AF;U" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding DeactivateCommand}" Style="{StaticResource DangerButtonStyle}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE74D;" FontFamily="Segoe MDL2 Assets" FontSize="13" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBlock Text="NG&#x1EEA;NG S&#x1EEC; D&#x1EE4;NG" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1" Margin="12,0,12,12">
            <DataGrid ItemsSource="{Binding Vehicles}"
                      SelectedItem="{Binding SelectedVehicle}"
                      Style="{StaticResource SystemDataGridStyle}"
                      ColumnHeaderStyle="{StaticResource SystemDataGridColumnHeaderStyle}"
                      RowStyle="{StaticResource SystemDataGridRowStyle}"
                      CellStyle="{StaticResource SystemDataGridCellStyle}"
                      ScrollViewer.HorizontalScrollBarVisibility="Auto">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Bi&#x1EC3;n s&#x1ED1;" Binding="{Binding VehiclePlate}" Width="120" ElementStyle="{StaticResource GridTextCenter}"/>
                    <DataGridTextColumn Header="S&#x1ED1; Mooc" Binding="{Binding MoocNumber}" Width="120" ElementStyle="{StaticResource GridTextCenter}"/>
                    <DataGridTextColumn Header="T&#x00E0;i x&#x1EBF;" Binding="{Binding DriverName}" Width="200" ElementStyle="{StaticResource GridTextLeft}"/>
                    <DataGridTextColumn Header="TTCP (kg)" Binding="{Binding TtcpWeight, ConverterCulture='vi-VN', StringFormat='{}{0:N0}'}" Width="110" ElementStyle="{StaticResource GridTextRight}"/>
                    <DataGridTextColumn Header="TTCP 10% (kg)" Binding="{Binding TtcpWeight, Converter={StaticResource DecimalMultiplierConverter}, ConverterParameter=1.1, ConverterCulture='vi-VN', StringFormat='{}{0:N0}'}" Width="120" ElementStyle="{StaticResource GridTextRight}"/>
                    <DataGridTextColumn Header="S&#x1ED1; &#x0110;K xe" Binding="{Binding VehicleRegistrationNo}" Width="130" ElementStyle="{StaticResource GridTextCenter}"/>
                    <DataGridTextColumn Header="H&#x1EA1;n &#x0110;K Xe" Binding="{Binding VehicleRegistrationExpiryDate, StringFormat='{}{0:dd/MM/yyyy}'}" Width="130" ElementStyle="{StaticResource GridTextCenter}"/>
                    <DataGridTextColumn Header="S&#x1ED1; &#x0110;K mooc" Binding="{Binding MoocRegistrationNo}" Width="130" ElementStyle="{StaticResource GridTextCenter}"/>
                    <DataGridTextColumn Header="H&#x1EA1;n &#x0110;K Mooc" Binding="{Binding MoocRegistrationExpiryDate, StringFormat='{}{0:dd/MM/yyyy}'}" Width="130" ElementStyle="{StaticResource GridTextCenter}"/>
                    <DataGridTextColumn Header="HTVC" Binding="{Binding TransportMethod, Converter={StaticResource TransportMethodDisplayConverter}}" Width="95" ElementStyle="{StaticResource GridTextCenter}"/>
                    <DataGridCheckBoxColumn Header="Ho&#x1EA1;t &#x0111;&#x1ED9;ng" Binding="{Binding IsActive}" Width="100" ElementStyle="{StaticResource GridCheckBoxCenter}" EditingElementStyle="{StaticResource GridCheckBoxCenterEditable}"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</UserControl>
