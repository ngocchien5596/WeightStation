<UserControl x:Class="StationApp.UI.Views.Settings.CameraConfigView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="700" d:DesignWidth="850"
             Background="Transparent">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/StationApp.UI;component/Themes/AppTheme.xaml"/>
                <ResourceDictionary Source="/StationApp.UI;component/Styles/ButtonStyles.xaml"/>
                <ResourceDictionary Source="/StationApp.UI;component/Styles/InputStyles.xaml"/>
                <ResourceDictionary Source="/StationApp.UI;component/Styles/BasePageStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <Style x:Key="FormLabel" TargetType="TextBlock" BasedOn="{StaticResource FieldLabelStyle}">
                <Setter Property="Foreground" Value="#2C3E50"/>
                <Setter Property="Margin" Value="0,0,16,12"/>
            </Style>
            <Style x:Key="FormBox" TargetType="TextBox" BasedOn="{StaticResource StandardTextBoxStyle}">
                <Setter Property="Height" Value="32"/>
                <Setter Property="Padding" Value="8,4"/>
                <Setter Property="VerticalContentAlignment" Value="Center"/>
            </Style>
            <Style x:Key="FormCombo" TargetType="ComboBox" BasedOn="{StaticResource StandardComboBoxStyle}">
                <Setter Property="Height" Value="32"/>
            </Style>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid Background="#F8FAFC">
        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <Grid Margin="16">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1*"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="1*"/>
                </Grid.ColumnDefinitions>

                <!-- Left Column: Cấu hình camera Trạm C2 -->
                <Border Grid.Column="0" Grid.Row="0" Background="#FFFFFF" BorderBrush="#E2E8F0" BorderThickness="1" Padding="24" CornerRadius="8" VerticalAlignment="Top">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Header -->
                        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
                            <TextBlock Text="&#xE722;" FontFamily="Segoe MDL2 Assets" FontSize="16" FontWeight="SemiBold" Foreground="#123B6B" VerticalAlignment="Center"/>
                            <TextBlock Text="CAMERA TRẠM CÂN C2 (CÂN NỘI ĐỊA)" FontSize="14" FontWeight="SemiBold" Foreground="#123B6B" Margin="8,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>

                        <Separator Grid.Row="1" Background="#E2E8F0" Height="1" Margin="0,0,0,16"/>

                        <StackPanel Grid.Row="2">
                            <!-- Camera C2 - 1 Sub-card -->
                            <Border Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="6" Padding="16" Margin="0,0,0,16">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" MinWidth="130"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Camera 1 Enabled -->
                                    <StackPanel Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" Orientation="Horizontal" Margin="0,0,0,12">
                                        <CheckBox IsChecked="{Binding Camera1Enabled}" Style="{StaticResource StandardCheckBoxStyle}" VerticalAlignment="Center"/>
                                        <TextBlock Text="Bật Camera 1" FontSize="13" FontWeight="SemiBold" Foreground="#2C3E50" Margin="8,0,16,0" VerticalAlignment="Center"/>
                                        <CheckBox IsChecked="{Binding IsCamera1DefaultPreview}" Style="{StaticResource StandardCheckBoxStyle}" VerticalAlignment="Center"/>
                                        <TextBlock Text="Mặc định" FontSize="13" FontWeight="SemiBold" Foreground="#2C3E50" Margin="8,0,0,0" VerticalAlignment="Center"/>
                                    </StackPanel>

                                    <!-- Name -->
                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Tên Camera 1" Style="{StaticResource FormLabel}" VerticalAlignment="Center"/>
                                    <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding Camera1Name, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FormBox}" Margin="0,0,0,10"/>

                                    <!-- Main stream -->
                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="RTSP URL (main)" Style="{StaticResource FormLabel}" VerticalAlignment="Center"/>
                                    <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding Camera1RtspUrl, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FormBox}" Margin="0,0,0,10"/>

                                    <!-- Preview stream -->
                                    <TextBlock Grid.Row="3" Grid.Column="0" Text="RTSP URL (preview)" Style="{StaticResource FormLabel}" VerticalAlignment="Center"/>
                                    <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding Camera1PreviewRtspUrl, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FormBox}" Margin="0,0,0,0"/>
                                </Grid>
                            </Border>

                            <!-- Camera C2 - 2 Sub-card -->
                            <Border Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="6" Padding="16">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" MinWidth="130"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Camera 2 Enabled -->
                                    <StackPanel Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" Orientation="Horizontal" Margin="0,0,0,12">
                                        <CheckBox IsChecked="{Binding Camera2Enabled}" Style="{StaticResource StandardCheckBoxStyle}" VerticalAlignment="Center"/>
                                        <TextBlock Text="Bật Camera 2" FontSize="13" FontWeight="SemiBold" Foreground="#2C3E50" Margin="8,0,16,0" VerticalAlignment="Center"/>
                                        <CheckBox IsChecked="{Binding IsCamera2DefaultPreview}" Style="{StaticResource StandardCheckBoxStyle}" VerticalAlignment="Center"/>
                                        <TextBlock Text="Mặc định" FontSize="13" FontWeight="SemiBold" Foreground="#2C3E50" Margin="8,0,0,0" VerticalAlignment="Center"/>
                                    </StackPanel>

                                    <!-- Name -->
                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Tên Camera 2" Style="{StaticResource FormLabel}" VerticalAlignment="Center"/>
                                    <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding Camera2Name, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FormBox}" Margin="0,0,0,10"/>

                                    <!-- Main stream -->
                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="RTSP URL (main)" Style="{StaticResource FormLabel}" VerticalAlignment="Center"/>
                                    <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding Camera2RtspUrl, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FormBox}" Margin="0,0,0,10"/>

                                    <!-- Preview stream -->
                                    <TextBlock Grid.Row="3" Grid.Column="0" Text="RTSP URL (preview)" Style="{StaticResource FormLabel}" VerticalAlignment="Center"/>
                                    <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding Camera2PreviewRtspUrl, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FormBox}" Margin="0,0,0,0"/>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Right Column: Cấu hình camera Trạm C6 -->
                <Border Grid.Column="2" Grid.Row="0" Background="#FFFFFF" BorderBrush="#E2E8F0" BorderThickness="1" Padding="24" CornerRadius="8" VerticalAlignment="Top">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Header -->
                        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
                            <TextBlock Text="&#xE722;" FontFamily="Segoe MDL2 Assets" FontSize="16" FontWeight="SemiBold" Foreground="#123B6B" VerticalAlignment="Center"/>
                            <TextBlock Text="CAMERA TRẠM CÂN C6 (CÂN XUẤT KHẨU)" FontSize="14" FontWeight="SemiBold" Foreground="#123B6B" Margin="8,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>

                        <Separator Grid.Row="1" Background="#E2E8F0" Height="1" Margin="0,0,0,16"/>

                        <StackPanel Grid.Row="2">
                            <!-- Camera C6 - 1 Sub-card -->
                            <Border Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="6" Padding="16" Margin="0,0,0,16">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" MinWidth="130"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Camera 1 Enabled -->
                                    <StackPanel Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" Orientation="Horizontal" Margin="0,0,0,12">
                                        <CheckBox IsChecked="{Binding CameraC6_1Enabled}" Style="{StaticResource StandardCheckBoxStyle}" VerticalAlignment="Center"/>
                                        <TextBlock Text="Bật Camera 1" FontSize="13" FontWeight="SemiBold" Foreground="#2C3E50" Margin="8,0,16,0" VerticalAlignment="Center"/>
                                        <CheckBox IsChecked="{Binding IsCamera1DefaultPreview}" Style="{StaticResource StandardCheckBoxStyle}" VerticalAlignment="Center"/>
                                        <TextBlock Text="Mặc định" FontSize="13" FontWeight="SemiBold" Foreground="#2C3E50" Margin="8,0,0,0" VerticalAlignment="Center"/>
                                    </StackPanel>

                                    <!-- Name -->
                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Tên Camera 1" Style="{StaticResource FormLabel}" VerticalAlignment="Center"/>
                                    <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding CameraC6_1Name, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FormBox}" Margin="0,0,0,10"/>

                                    <!-- Main stream -->
                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="RTSP URL (main)" Style="{StaticResource FormLabel}" VerticalAlignment="Center"/>
                                    <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding CameraC6_1RtspUrl, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FormBox}" Margin="0,0,0,10"/>

                                    <!-- Preview stream -->
                                    <TextBlock Grid.Row="3" Grid.Column="0" Text="RTSP URL (preview)" Style="{StaticResource FormLabel}" VerticalAlignment="Center"/>
                                    <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding CameraC6_1PreviewRtspUrl, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FormBox}" Margin="0,0,0,0"/>
                                </Grid>
                            </Border>

                            <!-- Camera C6 - 2 Sub-card -->
                            <Border Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="6" Padding="16">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" MinWidth="130"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Camera 2 Enabled -->
                                    <StackPanel Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" Orientation="Horizontal" Margin="0,0,0,12">
                                        <CheckBox IsChecked="{Binding CameraC6_2Enabled}" Style="{StaticResource StandardCheckBoxStyle}" VerticalAlignment="Center"/>
                                        <TextBlock Text="Bật Camera 2" FontSize="13" FontWeight="SemiBold" Foreground="#2C3E50" Margin="8,0,16,0" VerticalAlignment="Center"/>
                                        <CheckBox IsChecked="{Binding IsCamera2DefaultPreview}" Style="{StaticResource StandardCheckBoxStyle}" VerticalAlignment="Center"/>
                                        <TextBlock Text="Mặc định" FontSize="13" FontWeight="SemiBold" Foreground="#2C3E50" Margin="8,0,0,0" VerticalAlignment="Center"/>
                                    </StackPanel>

                                    <!-- Name -->
                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Tên Camera 2" Style="{StaticResource FormLabel}" VerticalAlignment="Center"/>
                                    <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding CameraC6_2Name, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FormBox}" Margin="0,0,0,10"/>

                                    <!-- Main stream -->
                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="RTSP URL (main)" Style="{StaticResource FormLabel}" VerticalAlignment="Center"/>
                                    <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding CameraC6_2RtspUrl, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FormBox}" Margin="0,0,0,10"/>

                                    <!-- Preview stream -->
                                    <TextBlock Grid.Row="3" Grid.Column="0" Text="RTSP URL (preview)" Style="{StaticResource FormLabel}" VerticalAlignment="Center"/>
                                    <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding CameraC6_2PreviewRtspUrl, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FormBox}" Margin="0,0,0,0"/>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Crusher cameras -->
                <Border Grid.Column="0" Grid.Row="1" Background="#FFFFFF" BorderBrush="#E2E8F0" BorderThickness="1" Padding="24" CornerRadius="8" VerticalAlignment="Top" Margin="0,20,0,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
                            <TextBlock Text="&#xE722;" FontFamily="Segoe MDL2 Assets" FontSize="16" FontWeight="SemiBold" Foreground="#123B6B" VerticalAlignment="Center"/>
                            <TextBlock Text="CAMERA TRẠM ĐẬP" FontSize="14" FontWeight="SemiBold" Foreground="#123B6B" Margin="8,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>

                        <Separator Grid.Row="1" Background="#E2E8F0" Height="1" Margin="0,0,0,16"/>

                        <StackPanel Grid.Row="2">
                            <Border Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="6" Padding="16" Margin="0,0,0,16">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" MinWidth="130"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" Orientation="Horizontal" Margin="0,0,0,12">
                                        <CheckBox IsChecked="{Binding CameraCrusher_1Enabled}" Style="{StaticResource StandardCheckBoxStyle}" VerticalAlignment="Center"/>
                                        <TextBlock Text="Bật Camera 1" FontSize="13" FontWeight="SemiBold" Foreground="#2C3E50" Margin="8,0,16,0" VerticalAlignment="Center"/>
                                        <CheckBox IsChecked="{Binding IsCamera1DefaultPreview}" Style="{StaticResource StandardCheckBoxStyle}" VerticalAlignment="Center"/>
                                        <TextBlock Text="Mặc định" FontSize="13" FontWeight="SemiBold" Foreground="#2C3E50" Margin="8,0,0,0" VerticalAlignment="Center"/>
                                    </StackPanel>

                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Tên Camera 1" Style="{StaticResource FormLabel}" VerticalAlignment="Center"/>
                                    <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding CameraCrusher_1Name, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FormBox}" Margin="0,0,0,10"/>

                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="RTSP URL (main)" Style="{StaticResource FormLabel}" VerticalAlignment="Center"/>
                                    <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding CameraCrusher_1RtspUrl, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FormBox}" Margin="0,0,0,10"/>

                                    <TextBlock Grid.Row="3" Grid.Column="0" Text="RTSP URL (preview)" Style="{StaticResource FormLabel}" VerticalAlignment="Center"/>
                                    <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding CameraCrusher_1PreviewRtspUrl, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FormBox}"/>
                                </Grid>
                            </Border>

                            <Border Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="6" Padding="16">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" MinWidth="130"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" Orientation="Horizontal" Margin="0,0,0,12">
                                        <CheckBox IsChecked="{Binding CameraCrusher_2Enabled}" Style="{StaticResource StandardCheckBoxStyle}" VerticalAlignment="Center"/>
                                        <TextBlock Text="Bật Camera 2" FontSize="13" FontWeight="SemiBold" Foreground="#2C3E50" Margin="8,0,16,0" VerticalAlignment="Center"/>
                                        <CheckBox IsChecked="{Binding IsCamera2DefaultPreview}" Style="{StaticResource StandardCheckBoxStyle}" VerticalAlignment="Center"/>
                                        <TextBlock Text="Mặc định" FontSize="13" FontWeight="SemiBold" Foreground="#2C3E50" Margin="8,0,0,0" VerticalAlignment="Center"/>
                                    </StackPanel>

                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Tên Camera 2" Style="{StaticResource FormLabel}" VerticalAlignment="Center"/>
                                    <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding CameraCrusher_2Name, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FormBox}" Margin="0,0,0,10"/>

                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="RTSP URL (main)" Style="{StaticResource FormLabel}" VerticalAlignment="Center"/>
                                    <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding CameraCrusher_2RtspUrl, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FormBox}" Margin="0,0,0,10"/>

                                    <TextBlock Grid.Row="3" Grid.Column="0" Text="RTSP URL (preview)" Style="{StaticResource FormLabel}" VerticalAlignment="Center"/>
                                    <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding CameraCrusher_2PreviewRtspUrl, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FormBox}"/>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Clay cameras -->
                <Border Grid.Column="2" Grid.Row="1" Background="#FFFFFF" BorderBrush="#E2E8F0" BorderThickness="1" Padding="24" CornerRadius="8" VerticalAlignment="Top" Margin="0,20,0,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
                            <TextBlock Text="&#xE722;" FontFamily="Segoe MDL2 Assets" FontSize="16" FontWeight="SemiBold" Foreground="#123B6B" VerticalAlignment="Center"/>
                            <TextBlock Text="CAMERA MỎ SÉT" FontSize="14" FontWeight="SemiBold" Foreground="#123B6B" Margin="8,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>

                        <Separator Grid.Row="1" Background="#E2E8F0" Height="1" Margin="0,0,0,16"/>

                        <StackPanel Grid.Row="2">
                            <Border Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="6" Padding="16" Margin="0,0,0,16">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" MinWidth="130"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" Orientation="Horizontal" Margin="0,0,0,12">
                                        <CheckBox IsChecked="{Binding CameraClay_1Enabled}" Style="{StaticResource StandardCheckBoxStyle}" VerticalAlignment="Center"/>
                                        <TextBlock Text="Bật Camera 1" FontSize="13" FontWeight="SemiBold" Foreground="#2C3E50" Margin="8,0,16,0" VerticalAlignment="Center"/>
                                        <CheckBox IsChecked="{Binding IsCamera1DefaultPreview}" Style="{StaticResource StandardCheckBoxStyle}" VerticalAlignment="Center"/>
                                        <TextBlock Text="Mặc định" FontSize="13" FontWeight="SemiBold" Foreground="#2C3E50" Margin="8,0,0,0" VerticalAlignment="Center"/>
                                    </StackPanel>

                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Tên Camera 1" Style="{StaticResource FormLabel}" VerticalAlignment="Center"/>
                                    <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding CameraClay_1Name, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FormBox}" Margin="0,0,0,10"/>

                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="RTSP URL (main)" Style="{StaticResource FormLabel}" VerticalAlignment="Center"/>
                                    <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding CameraClay_1RtspUrl, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FormBox}" Margin="0,0,0,10"/>

                                    <TextBlock Grid.Row="3" Grid.Column="0" Text="RTSP URL (preview)" Style="{StaticResource FormLabel}" VerticalAlignment="Center"/>
                                    <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding CameraClay_1PreviewRtspUrl, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FormBox}"/>
                                </Grid>
                            </Border>

                            <Border Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="6" Padding="16">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" MinWidth="130"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" Orientation="Horizontal" Margin="0,0,0,12">
                                        <CheckBox IsChecked="{Binding CameraClay_2Enabled}" Style="{StaticResource StandardCheckBoxStyle}" VerticalAlignment="Center"/>
                                        <TextBlock Text="Bật Camera 2" FontSize="13" FontWeight="SemiBold" Foreground="#2C3E50" Margin="8,0,16,0" VerticalAlignment="Center"/>
                                        <CheckBox IsChecked="{Binding IsCamera2DefaultPreview}" Style="{StaticResource StandardCheckBoxStyle}" VerticalAlignment="Center"/>
                                        <TextBlock Text="Mặc định" FontSize="13" FontWeight="SemiBold" Foreground="#2C3E50" Margin="8,0,0,0" VerticalAlignment="Center"/>
                                    </StackPanel>

                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Tên Camera 2" Style="{StaticResource FormLabel}" VerticalAlignment="Center"/>
                                    <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding CameraClay_2Name, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FormBox}" Margin="0,0,0,10"/>

                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="RTSP URL (main)" Style="{StaticResource FormLabel}" VerticalAlignment="Center"/>
                                    <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding CameraClay_2RtspUrl, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FormBox}" Margin="0,0,0,10"/>

                                    <TextBlock Grid.Row="3" Grid.Column="0" Text="RTSP URL (preview)" Style="{StaticResource FormLabel}" VerticalAlignment="Center"/>
                                    <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding CameraClay_2PreviewRtspUrl, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FormBox}"/>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Row 2: Common Camera Parameters spanning both columns -->
                <Border Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="3" Background="#FFFFFF" BorderBrush="#E2E8F0" BorderThickness="1" Padding="24" CornerRadius="8" Margin="0,20,0,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Header -->
                        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
                            <TextBlock Text="&#xE713;" FontFamily="Segoe MDL2 Assets" FontSize="16" FontWeight="SemiBold" Foreground="#123B6B" VerticalAlignment="Center"/>
                            <TextBlock Text="THAM SỐ CAMERA CHUNG" FontSize="14" FontWeight="SemiBold" Foreground="#123B6B" Margin="8,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>

                        <Separator Grid.Row="1" Background="#E2E8F0" Height="1" Margin="0,0,0,16"/>

                        <!-- Common Config Fields in a 2-column wrap layout -->
                        <UniformGrid Grid.Row="2" Columns="2">
                            <Grid Margin="0,0,20,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" MinWidth="220"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <!-- Capture Timeout -->
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Timeout chụp ảnh (ms)" Style="{StaticResource FormLabel}" VerticalAlignment="Center"/>
                                <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding CameraCaptureTimeoutMs, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FormBox}" Margin="0,0,0,12"/>
                            </Grid>

                            <Grid Margin="20,0,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" MinWidth="180"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <!-- JPEG Quality -->
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Chất lượng JPEG" Style="{StaticResource FormLabel}" VerticalAlignment="Center"/>
                                <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding CameraCaptureJpegQuality, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FormBox}" Margin="0,0,0,12"/>

                                <!-- Warmup frames -->
                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Số frame warmup" Style="{StaticResource FormLabel}" VerticalAlignment="Center"/>
                                <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding CameraCaptureWarmupFrames, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FormBox}" Margin="0,0,0,0"/>
                            </Grid>
                        </UniformGrid>
                    </Grid>
                </Border>

                <!-- Row 2: Action buttons -->
                <StackPanel Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="3" Orientation="Horizontal" Margin="0,20,0,0" HorizontalAlignment="Right">
                    <Button Command="{Binding LoadCommand}" Style="{StaticResource UtilityButtonStyle}" Margin="0,0,12,0" MinWidth="120" Height="36">
                        <TextBlock Text="LÀM MỚI" VerticalAlignment="Center" FontWeight="SemiBold"/>
                    </Button>
                    <Button Command="{Binding SaveCommand}" Style="{StaticResource PrimaryButtonStyle}" MinWidth="160" Height="36">
                        <TextBlock Text="LƯU THAY ĐỔI" VerticalAlignment="Center" FontWeight="SemiBold"/>
                    </Button>
                </StackPanel>
            </Grid>
        </ScrollViewer>
    </Grid>
</UserControl>
