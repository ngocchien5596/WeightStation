<UserControl x:Class="StationApp.UI.Views.Settings.ScaleDeviceConfigView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="700" d:DesignWidth="1000"
             Background="Transparent">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/StationApp.UI;component/Themes/AppTheme.xaml"/>
                <ResourceDictionary Source="/StationApp.UI;component/Styles/ButtonStyles.xaml"/>
                <ResourceDictionary Source="/StationApp.UI;component/Styles/InputStyles.xaml"/>
                <ResourceDictionary Source="/StationApp.UI;component/Styles/BasePageStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <Style x:Key="FormLabel" TargetType="TextBlock">
                <Setter Property="FontSize" Value="13"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="Foreground" Value="#333333"/>
                <Setter Property="Margin" Value="0,8,0,2"/>
            </Style>
            <Style x:Key="FormBox" TargetType="TextBox" BasedOn="{StaticResource StandardTextBoxStyle}">
                <Setter Property="Height" Value="32"/>
                <Setter Property="Padding" Value="6,4"/>
                <Setter Property="VerticalContentAlignment" Value="Center"/>
            </Style>
            <Style x:Key="FormCombo" TargetType="ComboBox" BasedOn="{StaticResource StandardComboBoxStyle}">
                <Setter Property="Height" Value="32"/>
            </Style>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid Background="#FFFFFF">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="3*"/>
            <ColumnDefinition Width="2*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Margin="12" Background="#E8EFF7" Padding="16" CornerRadius="4" VerticalAlignment="Top">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Column="0" Grid.Row="0" Text="C&#x1ED5;ng COM" Style="{StaticResource FormLabel}" VerticalAlignment="Center" Margin="0,0,8,12"/>
                <Grid Grid.Column="1" Grid.Row="0" Margin="0,0,16,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <ComboBox Grid.Column="0"
                              ItemsSource="{Binding AvailablePorts}"
                              SelectedItem="{Binding ComPort, UpdateSourceTrigger=PropertyChanged}"
                              Style="{StaticResource FormCombo}"/>
                    <Button Grid.Column="1"
                            Command="{Binding RefreshPortsCommand}"
                            Style="{StaticResource UtilityButtonStyle}"
                            Margin="8,0,0,0"
                            MinWidth="44">
                        <TextBlock Text="&#xE72C;" FontFamily="Segoe MDL2 Assets" FontSize="13" VerticalAlignment="Center"/>
                    </Button>
                </Grid>

                <TextBlock Grid.Column="2" Grid.Row="0" Text="Baudrate" Style="{StaticResource FormLabel}" VerticalAlignment="Center" Margin="0,0,8,12"/>
                <ComboBox Grid.Column="3" Grid.Row="0"
                          ItemsSource="{Binding AvailableBaudrates}"
                          SelectedItem="{Binding Baudrate, UpdateSourceTrigger=PropertyChanged}"
                          Style="{StaticResource FormCombo}" Margin="0,0,0,12"/>

                <TextBlock Grid.Column="0" Grid.Row="1" Text="Parity" Style="{StaticResource FormLabel}" VerticalAlignment="Center" Margin="0,0,8,12"/>
                <ComboBox Grid.Column="1" Grid.Row="1"
                          ItemsSource="{Binding AvailableParities}"
                          SelectedItem="{Binding Parity, UpdateSourceTrigger=PropertyChanged}"
                          Style="{StaticResource FormCombo}" Margin="0,0,16,12"/>

                <TextBlock Grid.Column="2" Grid.Row="1" Text="Data Bits" Style="{StaticResource FormLabel}" VerticalAlignment="Center" Margin="0,0,8,12"/>
                <ComboBox Grid.Column="3" Grid.Row="1"
                          ItemsSource="{Binding AvailableDataBits}"
                          SelectedItem="{Binding DataBits, UpdateSourceTrigger=PropertyChanged}"
                          Style="{StaticResource FormCombo}" Margin="0,0,0,12"/>

                <TextBlock Grid.Column="0" Grid.Row="2" Text="Stop Bits" Style="{StaticResource FormLabel}" VerticalAlignment="Center" Margin="0,0,8,12"/>
                <ComboBox Grid.Column="1" Grid.Row="2"
                          ItemsSource="{Binding AvailableStopBits}"
                          SelectedItem="{Binding StopBits, UpdateSourceTrigger=PropertyChanged}"
                          Style="{StaticResource FormCombo}" Margin="0,0,16,12"/>

                <TextBlock Grid.Column="2" Grid.Row="2" Text="Lo&#x1EA1;i parser" Style="{StaticResource FormLabel}" VerticalAlignment="Center" Margin="0,0,8,12"/>
                <ComboBox Grid.Column="3" Grid.Row="2"
                          ItemsSource="{Binding AvailableParserTypes}"
                          SelectedItem="{Binding ParserType, UpdateSourceTrigger=PropertyChanged}"
                          Style="{StaticResource FormCombo}" Margin="0,0,0,12"/>

                <TextBlock Grid.Column="0" Grid.Row="3" Text="K&#xFD; t&#x1EF1; k&#x1EBF;t th&#xFA;c" Style="{StaticResource FormLabel}" VerticalAlignment="Center" Margin="0,0,8,12"/>
                <ComboBox Grid.Column="1" Grid.Row="3"
                          ItemsSource="{Binding AvailableFrameEndChars}"
                          SelectedItem="{Binding FrameEndChar, UpdateSourceTrigger=PropertyChanged}"
                          Style="{StaticResource FormCombo}" Margin="0,0,16,12"/>

                <TextBlock Grid.Column="2" Grid.Row="3" Text="Chu k&#x1EF3; &#x1ED5;n &#x111;&#x1ECB;nh" Style="{StaticResource FormLabel}" VerticalAlignment="Center" Margin="0,0,8,12"/>
                <ComboBox Grid.Column="3" Grid.Row="3"
                          ItemsSource="{Binding AvailableStableCycles}"
                          SelectedItem="{Binding StableCycles, UpdateSourceTrigger=PropertyChanged}"
                          Style="{StaticResource FormCombo}" Margin="0,0,0,12"/>

                <TextBlock Grid.Column="0" Grid.Row="4" Text="V&#x1ECB; tr&#xED; b&#x1EAF;t &#x111;&#x1EA7;u" Style="{StaticResource FormLabel}" VerticalAlignment="Center" Margin="0,0,8,12"/>
                <ComboBox Grid.Column="1" Grid.Row="4"
                          ItemsSource="{Binding AvailableSubstringStarts}"
                          SelectedItem="{Binding WeightSubstringStart, UpdateSourceTrigger=PropertyChanged}"
                          Style="{StaticResource FormCombo}" Margin="0,0,16,12"/>

                <TextBlock Grid.Column="2" Grid.Row="4" Text="&#x110;&#x1ED9; d&#xE0;i chu&#x1ED7;i" Style="{StaticResource FormLabel}" VerticalAlignment="Center" Margin="0,0,8,12"/>
                <ComboBox Grid.Column="3" Grid.Row="4"
                          ItemsSource="{Binding AvailableSubstringLengths}"
                          SelectedItem="{Binding WeightSubstringLength, UpdateSourceTrigger=PropertyChanged}"
                          Style="{StaticResource FormCombo}" Margin="0,0,0,12"/>

                <TextBlock Grid.Column="0" Grid.Row="5" Text="Tr&#x1EA1;ng th&#xE1;i test" Style="{StaticResource FormLabel}" VerticalAlignment="Center" Margin="0,0,8,12"/>
                <TextBox Grid.Column="1" Grid.Row="5" Grid.ColumnSpan="3"
                         Text="{Binding ConnectionTestResult}"
                         Style="{StaticResource FormBox}"
                         IsReadOnly="True"
                         Background="#F1F1F1"
                         Margin="0,0,0,12"/>

                <StackPanel Grid.Column="0" Grid.Row="6" Grid.ColumnSpan="4" Orientation="Horizontal" Margin="0,16,0,0" HorizontalAlignment="Center">
                    <Button Command="{Binding LoadCommand}" Style="{StaticResource UtilityButtonStyle}" Margin="0,0,12,0">
                        <TextBlock Text="L&#x00C0;M M&#x1EDA;I" VerticalAlignment="Center"/>
                    </Button>
                    <Button Command="{Binding TestConnectionCommand}" Style="{StaticResource UtilityButtonStyle}" Margin="0,0,12,0">
                        <TextBlock Text="TEST K&#x1EBE;T N&#x1ED0;I" VerticalAlignment="Center"/>
                    </Button>
                    <Button Command="{Binding SaveCommand}" Style="{StaticResource PrimaryButtonStyle}">
                        <TextBlock Text="L&#x01AF;U C&#x1EA4;U H&#x00CC;NH" VerticalAlignment="Center"/>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Column="1" Margin="12" Background="#FFFFFF" BorderBrush="#E8EFF7" BorderThickness="2" CornerRadius="4" VerticalAlignment="Top" Padding="16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Column="0" Grid.Row="0" Grid.ColumnSpan="2" Text="Ki&#x1EC3;m tra parser / frame d&#x1EEF; li&#x1EC7;u" FontSize="14" FontWeight="SemiBold" Foreground="#123B6B" Margin="0,0,0,16"/>

                <TextBlock Grid.Column="0" Grid.Row="1" Text="D&#x1EEF; li&#x1EC7;u raw" Style="{StaticResource FormLabel}" VerticalAlignment="Center" Margin="0,0,12,12"/>
                <TextBox Grid.Column="1" Grid.Row="1" Text="{Binding SampleRawFrame, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FormBox}" Height="60" TextWrapping="Wrap" AcceptsReturn="True" Margin="0,0,0,12"/>

                <TextBlock Grid.Column="0" Grid.Row="2" Text="Chu&#x1ED7;i xem tr&#x1B0;&#x1EDB;c" Style="{StaticResource FormLabel}" VerticalAlignment="Center" Margin="0,0,12,12"/>
                <TextBox Grid.Column="1" Grid.Row="2" Text="{Binding ParsedStringResult}" IsReadOnly="True" Style="{StaticResource FormBox}" Background="#F1F1F1" Foreground="#007F54" FontWeight="SemiBold" Margin="0,0,0,12"/>

                <TextBlock Grid.Column="0" Grid.Row="3" Text="K&#x1EBF;t qu&#x1EA3; parse" Style="{StaticResource FormLabel}" VerticalAlignment="Center" Margin="0,0,12,12"/>
                <TextBox Grid.Column="1" Grid.Row="3" Text="{Binding ParsedWeightResult}" IsReadOnly="True" Style="{StaticResource FormBox}" Background="#F1F1F1" Foreground="#BD2730" FontWeight="SemiBold" Margin="0,0,0,12"/>

                <Button Grid.Column="1" Grid.Row="4" Command="{Binding TestParseCommand}" Style="{StaticResource UtilityButtonStyle}" Margin="0,4,0,0">
                    <TextBlock Text="KI&#x1EC2;M TRA PARSE" VerticalAlignment="Center"/>
                </Button>
            </Grid>
        </Border>
    </Grid>
</UserControl>
