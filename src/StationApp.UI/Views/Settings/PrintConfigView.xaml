<UserControl x:Class="StationApp.UI.Views.Settings.PrintConfigView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="720"
             d:DesignWidth="1200"
             Background="Transparent">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/StationApp.UI;component/Themes/AppTheme.xaml"/>
                <ResourceDictionary Source="/StationApp.UI;component/Styles/ButtonStyles.xaml"/>
                <ResourceDictionary Source="/StationApp.UI;component/Styles/InputStyles.xaml"/>
                <ResourceDictionary Source="/StationApp.UI;component/Styles/BasePageStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <Style x:Key="FormLabel" TargetType="TextBlock" BasedOn="{StaticResource FieldLabelStyle}">
                <Setter Property="Foreground" Value="#2C3E50"/>
                <Setter Property="Margin" Value="0,0,0,8"/>
            </Style>
            <Style x:Key="FormCombo" TargetType="ComboBox" BasedOn="{StaticResource StandardComboBoxStyle}">
                <Setter Property="Height" Value="34"/>
            </Style>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid Background="#F8FAFC">
        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <Grid Margin="24">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Row 0: DB & Backup Status Card -->
                <Border Grid.Row="0" Background="#FFFFFF" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="8" Padding="20" Margin="0,0,0,20">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Width="44" Height="44" CornerRadius="8" Background="#E8EFF7" Margin="0,0,16,0" VerticalAlignment="Center">
                            <TextBlock Text="&#xE8B7;" FontFamily="Segoe MDL2 Assets" FontSize="20" Foreground="#123B6B" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>

                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="CẤU HÌNH CHÍNH ĐANG LƯU TRONG DB LOCAL DÙNG CHUNG" FontWeight="Bold" Foreground="#123B6B" FontSize="13.5"/>
                            <TextBlock Text="{Binding LastBackupFileDisplay, TargetNullValue=Chưa có file backup}" Margin="0,8,0,0" FontSize="12" Foreground="#64748B" TextWrapping="Wrap" FontWeight="SemiBold"/>
                            
                            <!-- Success Banner -->
                            <Border Background="#ECFDF5" BorderBrush="#A7F3D0" BorderThickness="1" CornerRadius="6" Padding="12,8" Margin="0,10,0,0" Visibility="{Binding PrinterSettingsMessage, Converter={StaticResource StringToVis}}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE930;" FontFamily="Segoe MDL2 Assets" FontSize="14" Foreground="#0F766E" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding PrinterSettingsMessage}" Foreground="#0F766E" FontWeight="SemiBold" TextWrapping="Wrap" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Row 1: Two columns cards -->
                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1*"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="1*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Column 0: Weigh Ticket Card (PC) -->
                    <Border Grid.Column="0" Background="#FFFFFF" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="8" Padding="24" VerticalAlignment="Top">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Text="MẪU IN PHIẾU CÂN (PC)" FontSize="15" FontWeight="Bold" Foreground="#123B6B"/>

                            <Separator Grid.Row="1" Background="#E2E8F0" Height="1" Margin="0,16,0,16"/>

                            <StackPanel Grid.Row="2">
                                <TextBlock Text="Máy in mặc định cho phiếu cân" Style="{StaticResource FormLabel}"/>
                                <ComboBox ItemsSource="{Binding WeighTicketPrinters}"
                                          SelectedItem="{Binding SelectedWeighTicketPrinter, UpdateSourceTrigger=PropertyChanged}"
                                          DisplayMemberPath="Name"
                                          Style="{StaticResource FormCombo}"
                                          Margin="0,0,0,14"/>
                                <Button Command="{Binding ConfigureWeighTicketCommand}"
                                        Style="{StaticResource WorkflowButtonStyle}"
                                        Height="36"
                                        Padding="18,0"
                                        HorizontalAlignment="Left">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE70F;" FontFamily="Segoe MDL2 Assets" FontSize="13" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                        <TextBlock Text="MỞ CẤU HÌNH PHIẾU CÂN" VerticalAlignment="Center" FontWeight="SemiBold"/>
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Column 2: Delivery Ticket Card (PGN) -->
                    <Border Grid.Column="2" Background="#FFFFFF" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="8" Padding="24" VerticalAlignment="Top">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Text="MẪU IN PHIẾU GIAO NHẬN (PGN)" FontSize="15" FontWeight="Bold" Foreground="#123B6B"/>

                            <Separator Grid.Row="1" Background="#E2E8F0" Height="1" Margin="0,16,0,16"/>

                            <StackPanel Grid.Row="2">
                                <TextBlock Text="Máy in mặc định cho phiếu giao nhận" Style="{StaticResource FormLabel}"/>
                                <ComboBox ItemsSource="{Binding DeliveryTicketPrinters}"
                                          SelectedItem="{Binding SelectedDeliveryTicketPrinter, UpdateSourceTrigger=PropertyChanged}"
                                          DisplayMemberPath="Name"
                                          Style="{StaticResource FormCombo}"
                                          Margin="0,0,0,14"/>
                                <Button Command="{Binding ConfigureDeliveryTicketCommand}"
                                        Style="{StaticResource WorkflowButtonStyle}"
                                        Height="36"
                                        Padding="18,0"
                                        HorizontalAlignment="Left">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE70F;" FontFamily="Segoe MDL2 Assets" FontSize="13" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                        <TextBlock Text="MỞ CẤU HÌNH PHIẾU GIAO NHẬN" VerticalAlignment="Center" FontWeight="SemiBold"/>
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>

                <!-- Row 2: Action Buttons Footer -->
                <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,24,0,0" HorizontalAlignment="Right">
                    <Button Command="{Binding SavePrinterDefaultsCommand}" Style="{StaticResource PrimaryButtonStyle}" MinWidth="220" Height="36">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE74E;" FontFamily="Segoe MDL2 Assets" FontSize="13" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBlock Text="LƯU MÁY IN MẶC ĐỊNH" VerticalAlignment="Center" FontWeight="Bold"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </ScrollViewer>
    </Grid>
</UserControl>
