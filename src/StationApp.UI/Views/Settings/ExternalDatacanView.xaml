<UserControl x:Class="StationApp.UI.Views.Settings.ExternalDatacanView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:helpers="clr-namespace:StationApp.UI.Helpers"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="720"
             d:DesignWidth="1200"
             Background="Transparent">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/StationApp.UI;component/Themes/AppTheme.xaml"/>
                <ResourceDictionary Source="/StationApp.UI;component/Styles/ButtonStyles.xaml"/>
                <ResourceDictionary Source="/StationApp.UI;component/Styles/InputStyles.xaml"/>
                <ResourceDictionary Source="/StationApp.UI;component/Styles/BasePageStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <Style x:Key="FormLabel" TargetType="TextBlock" BasedOn="{StaticResource FieldLabelStyle}">
                <Setter Property="Margin" Value="0,4,0,2"/>
            </Style>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid Background="#FFFFFF">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="#E8EFF7"
                BorderBrush="#D7E3F0"
                BorderThickness="1"
                CornerRadius="4"
                Padding="16"
                Margin="12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="150"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="130"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="170"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="170"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="Nguồn"
                           Style="{StaticResource FormLabel}"
                           VerticalAlignment="Center"
                           Margin="0,0,8,0"/>
                <ComboBox Grid.Column="1"
                          ItemsSource="{Binding Sources}"
                          SelectedItem="{Binding SelectedSource}"
                          Style="{StaticResource StandardComboBoxStyle}"
                          Margin="0,0,16,0"/>

                <TextBlock Grid.Column="2"
                           Text="Biển số xe"
                           Style="{StaticResource FormLabel}"
                           VerticalAlignment="Center"
                           Margin="0,0,8,0"/>
                <TextBox Grid.Column="3"
                          Text="{Binding VehiclePlateKeyword, UpdateSourceTrigger=PropertyChanged}"
                          Style="{StaticResource SearchTextBoxStyle}"
                          helpers:EnterKeySearch.Command="{Binding SearchCommand}"
                          Margin="0,0,16,0">
                    <TextBox.InputBindings>
                        <KeyBinding Key="Enter" Command="{Binding SearchCommand}"/>
                    </TextBox.InputBindings>
                </TextBox>

                <TextBlock Grid.Column="4"
                           Text="Sản phẩm"
                           Style="{StaticResource FormLabel}"
                           VerticalAlignment="Center"
                           Margin="0,0,8,0"/>
                <TextBox Grid.Column="5"
                          Text="{Binding ProductKeyword, UpdateSourceTrigger=PropertyChanged}"
                          Style="{StaticResource SearchTextBoxStyle}"
                          helpers:EnterKeySearch.Command="{Binding SearchCommand}"
                          Margin="0,0,16,0">
                    <TextBox.InputBindings>
                        <KeyBinding Key="Enter" Command="{Binding SearchCommand}"/>
                    </TextBox.InputBindings>
                </TextBox>

                <TextBlock Grid.Column="6"
                           Text="Khách hàng"
                           Style="{StaticResource FormLabel}"
                           VerticalAlignment="Center"
                           Margin="0,0,8,0"/>
                <TextBox Grid.Column="7"
                          Text="{Binding CustomerKeyword, UpdateSourceTrigger=PropertyChanged}"
                          Style="{StaticResource SearchTextBoxStyle}"
                          helpers:EnterKeySearch.Command="{Binding SearchCommand}"
                          Margin="0,0,16,0">
                    <TextBox.InputBindings>
                        <KeyBinding Key="Enter" Command="{Binding SearchCommand}"/>
                    </TextBox.InputBindings>
                </TextBox>

                <Button Grid.Column="8"
                        Command="{Binding SearchCommand}"
                        Style="{StaticResource UtilityButtonStyle}"
                        Height="32"
                        VerticalAlignment="Center"
                        Margin="0,0,12,0">
                    <TextBlock Text="TÌM KIẾM" VerticalAlignment="Center"/>
                </Button>

                <Button Grid.Column="9"
                        Command="{Binding RefreshCommand}"
                        Style="{StaticResource UtilityButtonStyle}"
                        Height="32"
                        VerticalAlignment="Center">
                    <TextBlock Text="TẢI LẠI" VerticalAlignment="Center"/>
                </Button>
            </Grid>
        </Border>

        <TextBlock Grid.Row="1"
                   Text="{Binding ErrorMessage}"
                   Foreground="#A61E1E"
                   FontWeight="SemiBold"
                   TextWrapping="Wrap"
                   Margin="12,0,12,8"
                   Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVis}}"/>

        <Border Grid.Row="2"
                BorderBrush="#D7E3F0"
                BorderThickness="1"
                CornerRadius="6"
                Margin="12,0,12,0">
            <DataGrid ItemsSource="{Binding Records}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      SelectionMode="Single"
                      Style="{StaticResource SystemDataGridStyle}"
                      ColumnHeaderStyle="{StaticResource SystemDataGridColumnHeaderStyle}"
                      CellStyle="{StaticResource SystemDataGridCellStyle}"
                      EnableRowVirtualization="True"
                      EnableColumnVirtualization="True"
                      VirtualizingPanel.IsVirtualizing="True"
                      VirtualizingPanel.VirtualizationMode="Recycling"
                      ScrollViewer.HorizontalScrollBarVisibility="Auto"
                      ScrollViewer.VerticalScrollBarVisibility="Auto">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Số phiếu" Binding="{Binding TicketNo}" Width="130" ElementStyle="{StaticResource GridTextCenter}"/>
                    <DataGridTextColumn Header="Biển số xe" Binding="{Binding VehiclePlate}" Width="120" ElementStyle="{StaticResource GridTextLeft}"/>
                    <DataGridTextColumn Header="Loại" Binding="{Binding GroupName}" Width="140" ElementStyle="{StaticResource GridTextLeft}"/>
                    <DataGridTextColumn Header="Khách hàng" Binding="{Binding CustomerName}" Width="240" ElementStyle="{StaticResource GridTextLeft}"/>
                    <DataGridTextColumn Header="Hàng hóa" Binding="{Binding ProductName}" Width="240" ElementStyle="{StaticResource GridTextLeft}"/>
                    <DataGridTextColumn Header="Giờ cân lần 1" Binding="{Binding Weight1Time, StringFormat={}{0:dd/MM/yyyy HH:mm:ss}}" Width="165" ElementStyle="{StaticResource GridTextCenter}"/>
                    <DataGridTextColumn Header="Giờ cân lần 2" Binding="{Binding Weight2Time, StringFormat={}{0:dd/MM/yyyy HH:mm:ss}}" Width="165" ElementStyle="{StaticResource GridTextCenter}"/>
                    <DataGridTextColumn Header="Cân lần 1" Binding="{Binding Weight1, StringFormat={}{0:N0}}" Width="120" ElementStyle="{StaticResource GridTextRight}"/>
                    <DataGridTextColumn Header="Cân lần 2" Binding="{Binding Weight2, StringFormat={}{0:N0}}" Width="120" ElementStyle="{StaticResource GridTextRight}"/>
                    <DataGridTextColumn Header="Trọng lượng hàng" Binding="{Binding NetWeight, StringFormat={}{0:N0}}" Width="145" ElementStyle="{StaticResource GridTextRight}"/>
                    <DataGridTextColumn Header="Người cân" Binding="{Binding OperatorName}" Width="150" ElementStyle="{StaticResource GridTextLeft}"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <Border Grid.Row="3"
                Background="#F8FBFE"
                BorderBrush="#D7E3F0"
                BorderThickness="1,0,1,1"
                CornerRadius="0,0,6,6"
                Padding="10,8"
                Margin="12,0,12,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="{Binding PageSummary}"
                           VerticalAlignment="Center"
                           FontSize="13"
                           Foreground="#50627A"/>

                <Button Grid.Column="1"
                        Command="{Binding PreviousPageCommand}"
                        IsEnabled="{Binding CanGoToPreviousPage}"
                        Style="{StaticResource UtilityButtonStyle}"
                        Margin="0,0,8,0"
                        Width="42"
                        Height="30"
                        Padding="0">
                    <TextBlock Text="&lt;" FontSize="16" FontWeight="Bold"/>
                </Button>

                <Button Grid.Column="2"
                        Command="{Binding NextPageCommand}"
                        IsEnabled="{Binding CanGoToNextPage}"
                        Style="{StaticResource UtilityButtonStyle}"
                        Width="42"
                        Height="30"
                        Padding="0">
                    <TextBlock Text="&gt;" FontSize="16" FontWeight="Bold"/>
                </Button>
            </Grid>
        </Border>
    </Grid>
</UserControl>
