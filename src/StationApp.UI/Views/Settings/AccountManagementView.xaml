<UserControl x:Class="StationApp.UI.Views.Settings.AccountManagementView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:helpers="clr-namespace:StationApp.UI.Helpers"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="700" d:DesignWidth="1000"
             Background="Transparent">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/StationApp.UI;component/Themes/AppTheme.xaml"/>
                <ResourceDictionary Source="/StationApp.UI;component/Styles/ButtonStyles.xaml"/>
                <ResourceDictionary Source="/StationApp.UI;component/Styles/InputStyles.xaml"/>
                <ResourceDictionary Source="/StationApp.UI;component/Styles/BasePageStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <BooleanToVisibilityConverter x:Key="BoolToVis"/>
            <Style x:Key="FormLabel" TargetType="TextBlock" BasedOn="{StaticResource FieldLabelStyle}">
                <Setter Property="Margin" Value="0,4,0,2"/>
            </Style>
            <Style x:Key="FormBox" TargetType="TextBox" BasedOn="{StaticResource StandardTextBoxStyle}"/>
            <Style x:Key="FormCombo" TargetType="ComboBox" BasedOn="{StaticResource StandardComboBoxStyle}"/>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid Background="#FFFFFF">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#E8EFF7" Margin="12" Padding="16" CornerRadius="4">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="180"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" Text="Username" Style="{StaticResource FormLabel}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBox Grid.Column="1"
                             Text="{Binding SearchUsername, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource SearchTextBoxStyle}"
                             helpers:EnterKeySearch.Command="{Binding SearchCommand}"
                             Margin="0,0,16,0"/>

                    <TextBlock Grid.Column="2" Text="Tên hiển thị" Style="{StaticResource FormLabel}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBox Grid.Column="3"
                             Text="{Binding SearchDisplayName, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource SearchTextBoxStyle}"
                             helpers:EnterKeySearch.Command="{Binding SearchCommand}"
                             Margin="0,0,16,0"/>

                    <TextBlock Grid.Column="4" Text="Vai trò" Style="{StaticResource FormLabel}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <ComboBox Grid.Column="5"
                              ItemsSource="{Binding SearchRoleOptions}"
                              SelectedItem="{Binding SelectedSearchRoleOption, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                              Style="{StaticResource FormCombo}"
                              Margin="0,0,16,0"/>

                    <TextBlock Grid.Column="6" Text="Trạng thái" Style="{StaticResource FormLabel}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <ComboBox Grid.Column="7" ItemsSource="{Binding StatusFilterOptions}" SelectedItem="{Binding SelectedStatusFilter}" Style="{StaticResource FormCombo}" Margin="0,0,16,0"/>

                    <Button Grid.Column="8" Command="{Binding SearchCommand}" Style="{StaticResource UtilityButtonStyle}" Margin="0,0,12,0">
                        <TextBlock Text="TÌM KIẾM"/>
                    </Button>
                    <Button Grid.Column="9" Command="{Binding RefreshCommand}" Style="{StaticResource UtilityButtonStyle}">
                        <TextBlock Text="LÀM MỚI"/>
                    </Button>
                </Grid>

                <Separator Grid.Row="1" Background="#CCCCCC" Margin="0,0,0,16"/>

                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Username *" Style="{StaticResource FormLabel}" VerticalAlignment="Center" Margin="0,0,8,8"/>
                    <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding EditUsername, UpdateSourceTrigger=PropertyChanged}" IsReadOnly="{Binding IsUsernameReadOnly}" Style="{StaticResource FormBox}" Margin="0,0,16,8"/>

                    <TextBlock Grid.Row="0" Grid.Column="2" Text="Tên hiển thị *" Style="{StaticResource FormLabel}" VerticalAlignment="Center" Margin="0,0,8,8"/>
                    <TextBox Grid.Row="0" Grid.Column="3" Text="{Binding EditDisplayName, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FormBox}" Margin="0,0,16,8"/>

                    <TextBlock Grid.Row="0" Grid.Column="4" Text="Vai trò *" Style="{StaticResource FormLabel}" VerticalAlignment="Center" Margin="0,0,8,8"/>
                    <ComboBox Grid.Row="0" Grid.Column="5"
                              ItemsSource="{Binding RoleOptions}"
                              SelectedItem="{Binding SelectedRoleOption, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                              Style="{StaticResource FormCombo}"
                              Margin="0,0,16,8"/>

                    <CheckBox Grid.Row="0" Grid.Column="6" Grid.ColumnSpan="2"
                              Content="Đang hoạt động"
                              IsChecked="{Binding EditIsActive}"
                              Style="{StaticResource StandardCheckBoxStyle}"
                              Margin="0,0,0,8"/>

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Mật khẩu *" Style="{StaticResource FormLabel}" VerticalAlignment="Center" Margin="0,0,8,8"
                               Visibility="{Binding IsPasswordSectionVisible, Converter={StaticResource BoolToVis}}"/>
                    <PasswordBox Grid.Row="1" Grid.Column="1"
                                 Margin="0,0,16,8"
                                 Height="28"
                                 Padding="6,2"
                                 Visibility="{Binding IsPasswordSectionVisible, Converter={StaticResource BoolToVis}}"
                                 helpers:PasswordBoxAssistant.BindPassword="True"
                                 helpers:PasswordBoxAssistant.BoundPassword="{Binding CreatePassword, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                    <TextBlock Grid.Row="1" Grid.Column="2" Text="Xác nhận *" Style="{StaticResource FormLabel}" VerticalAlignment="Center" Margin="0,0,8,8"
                               Visibility="{Binding IsPasswordSectionVisible, Converter={StaticResource BoolToVis}}"/>
                    <PasswordBox Grid.Row="1" Grid.Column="3"
                                 Margin="0,0,16,8"
                                 Height="28"
                                 Padding="6,2"
                                 Visibility="{Binding IsPasswordSectionVisible, Converter={StaticResource BoolToVis}}"
                                 helpers:PasswordBoxAssistant.BindPassword="True"
                                 helpers:PasswordBoxAssistant.BoundPassword="{Binding CreateConfirmPassword, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Ngày tạo" Style="{StaticResource FormLabel}" VerticalAlignment="Center" Margin="0,0,8,8"/>
                    <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding CreatedAt, StringFormat={}{0:dd/MM/yyyy HH:mm:ss}}" Style="{StaticResource FormBox}" Margin="0,0,16,8" IsReadOnly="True"/>

                    <TextBlock Grid.Row="2" Grid.Column="2" Text="Người tạo" Style="{StaticResource FormLabel}" VerticalAlignment="Center" Margin="0,0,8,8"/>
                    <TextBox Grid.Row="2" Grid.Column="3" Text="{Binding CreatedBy}" Style="{StaticResource FormBox}" Margin="0,0,16,8" IsReadOnly="True"/>

                    <TextBlock Grid.Row="2" Grid.Column="4" Text="Đăng nhập cuối" Style="{StaticResource FormLabel}" VerticalAlignment="Center" Margin="0,0,8,8"/>
                    <TextBox Grid.Row="2" Grid.Column="5" Text="{Binding LastLoginAt, StringFormat={}{0:dd/MM/yyyy HH:mm:ss}}" Style="{StaticResource FormBox}" Margin="0,0,16,8" IsReadOnly="True"/>

                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Ngày cập nhật" Style="{StaticResource FormLabel}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding UpdatedAt, StringFormat={}{0:dd/MM/yyyy HH:mm:ss}}" Style="{StaticResource FormBox}" Margin="0,0,16,0" IsReadOnly="True"/>

                    <TextBlock Grid.Row="3" Grid.Column="2" Text="Người cập nhật" Style="{StaticResource FormLabel}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBox Grid.Row="3" Grid.Column="3" Text="{Binding UpdatedBy}" Style="{StaticResource FormBox}" Margin="0,0,16,0" IsReadOnly="True"/>
                </Grid>

                <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,16,0,0">
                    <Button Command="{Binding NewCommand}" Style="{StaticResource UtilityButtonStyle}" Margin="0,0,12,0">
                        <TextBlock Text="TẠO MỚI"/>
                    </Button>
                    <Button Command="{Binding SaveCommand}" Style="{StaticResource PrimaryButtonStyle}" Margin="0,0,12,0">
                        <TextBlock Text="LƯU"/>
                    </Button>
                    <Button Command="{Binding ResetPasswordCommand}" Style="{StaticResource WorkflowButtonStyle}" Margin="0,0,12,0">
                        <TextBlock Text="RESET MẬT KHẨU"/>
                    </Button>
                    <Button Command="{Binding DeactivateCommand}" Style="{StaticResource DangerButtonStyle}" Margin="0,0,12,0">
                        <TextBlock Text="NGỪNG HOẠT ĐỘNG"/>
                    </Button>
                    <Button Command="{Binding ReactivateCommand}" Style="{StaticResource NeutralButtonStyle}">
                        <TextBlock Text="KÍCH HOẠT LẠI"/>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1" Margin="12,0,12,12">
            <DataGrid ItemsSource="{Binding Users}"
                      SelectedItem="{Binding SelectedUser}"
                      SelectionMode="Single"
                      SelectionUnit="FullRow"
                      Style="{StaticResource SystemDataGridStyle}"
                      ColumnHeaderStyle="{StaticResource SystemDataGridColumnHeaderStyle}"
                      RowStyle="{StaticResource SystemDataGridRowStyle}"
                      CellStyle="{StaticResource SystemDataGridCellStyle}">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Username" Binding="{Binding Username}" Width="140" ElementStyle="{StaticResource GridTextLeft}"/>
                    <DataGridTextColumn Header="Tên hiển thị" Binding="{Binding DisplayName}" Width="220" ElementStyle="{StaticResource GridTextLeft}"/>
                    <DataGridTextColumn Header="Vai trò" Binding="{Binding RoleCode}" Width="120" ElementStyle="{StaticResource GridTextCenter}"/>
                    <DataGridTextColumn Header="Trạng thái" Binding="{Binding IsActive, Converter={StaticResource BooleanToStatusConverter}}" Width="150" ElementStyle="{StaticResource GridTextCenter}"/>
                    <DataGridTextColumn Header="Đăng nhập cuối" Binding="{Binding LastLoginAt, StringFormat={}{0:dd/MM/yyyy HH:mm:ss}}" Width="160" ElementStyle="{StaticResource GridTextCenter}"/>
                    <DataGridTextColumn Header="Ngày tạo" Binding="{Binding CreatedAt, StringFormat={}{0:dd/MM/yyyy HH:mm:ss}}" Width="160" ElementStyle="{StaticResource GridTextCenter}"/>
                    <DataGridTextColumn Header="Ngày cập nhật" Binding="{Binding UpdatedAt, StringFormat={}{0:dd/MM/yyyy HH:mm:ss}}" Width="160" ElementStyle="{StaticResource GridTextCenter}"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</UserControl>
