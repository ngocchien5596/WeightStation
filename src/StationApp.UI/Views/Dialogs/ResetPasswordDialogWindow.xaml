<Window x:Class="StationApp.UI.Views.Dialogs.ResetPasswordDialogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:helpers="clr-namespace:StationApp.UI.Helpers"
        Title="{Binding Title}"
        Width="460"
        Height="290"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Background="Transparent"
        AllowsTransparency="True"
        WindowStyle="None">
    <Border Background="White" CornerRadius="10" BorderBrush="#1B3263" BorderThickness="1" Margin="10">
        <Grid>
            <Grid.RowDefinitions><RowDefinition Height="44"/><RowDefinition Height="*"/><RowDefinition Height="62"/></Grid.RowDefinitions>
            <Border Grid.Row="0" Background="#1B3263" CornerRadius="9,9,0,0">
                <Grid>
                    <TextBlock Text="{Binding Title}" Foreground="White" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center" Margin="16,0,0,0"/>
                    <Button Content="&#x2715;" Width="36" Height="36" HorizontalAlignment="Right" Margin="0,4,4,4" Background="Transparent" Foreground="White" BorderThickness="0" Command="{Binding CancelCommand}"/>
                </Grid>
            </Border>
            <Grid Grid.Row="1" Margin="20">
                <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                <Grid.ColumnDefinitions><ColumnDefinition Width="120"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                <TextBlock Grid.Row="0" Grid.Column="0" Text="T&#xE0;i kho&#x1EA3;n" Style="{StaticResource FieldLabelStyle}" VerticalAlignment="Center"/>
                <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding Username}" Style="{StaticResource StandardTextBoxStyle}" IsReadOnly="True"/>
                <TextBlock Grid.Row="1" Grid.Column="0" Margin="0,12,0,0" Text="M&#x1EAD;t kh&#x1EA9;u m&#x1EDB;i" Style="{StaticResource FieldLabelStyle}" VerticalAlignment="Center"/>
                <PasswordBox Grid.Row="1" Grid.Column="1" Margin="0,12,0,0" Height="28" Padding="6,2" helpers:PasswordBoxAssistant.BindPassword="True" helpers:PasswordBoxAssistant.BoundPassword="{Binding NewPassword, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                <TextBlock Grid.Row="2" Grid.Column="0" Margin="0,12,0,0" Text="X&#xE1;c nh&#x1EAD;n" Style="{StaticResource FieldLabelStyle}" VerticalAlignment="Center"/>
                <PasswordBox Grid.Row="2" Grid.Column="1" Margin="0,12,0,0" Height="28" Padding="6,2" helpers:PasswordBoxAssistant.BindPassword="True" helpers:PasswordBoxAssistant.BoundPassword="{Binding ConfirmPassword, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                <TextBlock Grid.Row="3" Grid.Column="1" Margin="0,10,0,0" Foreground="#7F8C8D" Text="M&#x1EAD;t kh&#x1EA9;u t&#x1ED1;i thi&#x1EC3;u 8 k&#xFD; t&#x1EF1;." FontSize="12"/>
                <TextBlock Grid.Row="4" Grid.Column="1" Margin="0,8,0,0" Foreground="#C0392B" Text="{Binding ValidationMessage}"/>
            </Grid>
            <Border Grid.Row="2" Background="#F3F6FA" CornerRadius="0,0,9,9" Padding="16,12">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="H&#x1EE7;y" Style="{StaticResource UtilityButtonStyle}" Margin="0,0,10,0" Command="{Binding CancelCommand}"/>
                    <Button Content="X&#xE1;c nh&#x1EAD;n" Style="{StaticResource PrimaryButtonStyle}" Command="{Binding ConfirmCommand}"/>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
