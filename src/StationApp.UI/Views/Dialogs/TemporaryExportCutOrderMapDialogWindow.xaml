<Window x:Class="StationApp.UI.Views.Dialogs.TemporaryExportCutOrderMapDialogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding Title}"
        Width="1060"
        Height="560"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Background="Transparent"
        AllowsTransparency="True"
        WindowStyle="None">
    <Border Background="White" CornerRadius="10" BorderBrush="#1B3263" BorderThickness="1" Margin="10">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="44"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="62"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="#1B3263" CornerRadius="9,9,0,0">
                <Grid>
                    <TextBlock Text="{Binding Title}" Foreground="White" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center" Margin="16,0,0,0"/>
                    <Button Content="X"
                            Width="36"
                            Height="36"
                            HorizontalAlignment="Right"
                            Margin="0,4,4,4"
                            Background="Transparent"
                            Foreground="White"
                            BorderThickness="0"
                            Command="{Binding CancelCommand}"/>
                </Grid>
            </Border>

            <TextBlock Grid.Row="1"
                       Margin="20,18,20,12"
                       Text="{Binding Message}"
                       TextWrapping="Wrap"
                       Foreground="#334155"/>

            <Border Grid.Row="2" Margin="20,0,20,0" BorderBrush="#D6DEE8" BorderThickness="1" CornerRadius="8">
                <DataGrid ItemsSource="{Binding Options}"
                          SelectedItem="{Binding SelectedOption, Mode=TwoWay}"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          IsReadOnly="True"
                          SelectionMode="Single"
                          SelectionUnit="FullRow"
                          Style="{StaticResource SystemDataGridStyle}"
                          ColumnHeaderStyle="{StaticResource SystemDataGridColumnHeaderStyle}"
                          RowStyle="{StaticResource SystemDataGridRowStyle}"
                          CellStyle="{StaticResource SystemDataGridCellStyle}"
                          ScrollViewer.HorizontalScrollBarVisibility="Auto">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="M&#x00C3; T&#x1EA0;M" Binding="{Binding DisplayCode}" Width="150" ElementStyle="{StaticResource GridTextCenter}"/>
                        <DataGridTextColumn Header="M&#x00C3; KH" Binding="{Binding CustomerCode}" Width="110" ElementStyle="{StaticResource GridTextCenter}"/>
                        <DataGridTextColumn Header="KH&#x00C1;CH H&#x00C0;NG" Binding="{Binding CustomerName}" Width="230" ElementStyle="{StaticResource GridTextLeft}"/>
                        <DataGridTextColumn Header="M&#x00C3; SP" Binding="{Binding ProductCode}" Width="120" ElementStyle="{StaticResource GridTextCenter}"/>
                        <DataGridTextColumn Header="S&#x1EA2;N PH&#x1EA8;M" Binding="{Binding ProductName}" Width="240" ElementStyle="{StaticResource GridTextLeft}"/>
                        <DataGridTextColumn Header="SL &#x110;&#x1EB6;T (KG)" Binding="{Binding PlannedWeight, StringFormat='{}{0:N0}'}" Width="120" ElementStyle="{StaticResource GridTextRight}"/>
                        <DataGridTextColumn Header="L&#x0168;Y K&#x1EBE; (KG)" Binding="{Binding AccumulatedWeight, StringFormat='{}{0:N0}'}" Width="120" ElementStyle="{StaticResource GridTextRight}"/>
                        <DataGridTextColumn Header="S&#x1ED0; CHUY&#x1EBE;N" Binding="{Binding TripCount}" Width="100" ElementStyle="{StaticResource GridTextCenter}"/>
                        <DataGridTextColumn Header="CHUY&#x1EBE;N CU&#x1ED0;I" Binding="{Binding LastTripAt, StringFormat='dd/MM/yyyy HH:mm'}" Width="150" ElementStyle="{StaticResource GridTextCenter}"/>
                        <DataGridTextColumn Header="G&#x1EE2;I &#x00DD;" Binding="{Binding MatchScore}" Width="90" ElementStyle="{StaticResource GridTextCenter}"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>

            <Border Grid.Row="3" Background="#F3F6FA" CornerRadius="0,0,9,9" Padding="16,12">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="H&#x1EE7;y" Style="{StaticResource UtilityButtonStyle}" Margin="0,0,10,0" Command="{Binding CancelCommand}"/>
                    <Button Content="Kh&#x00F4;ng map" Style="{StaticResource NeutralButtonStyle}" Margin="0,0,10,0" Command="{Binding SkipMappingCommand}"/>
                    <Button Content="Map c&#x1EAF;t l&#x1EC7;nh" Style="{StaticResource PrimaryButtonStyle}" Command="{Binding ConfirmCommand}"/>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
