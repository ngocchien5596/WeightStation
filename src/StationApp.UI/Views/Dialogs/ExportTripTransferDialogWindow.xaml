<Window x:Class="StationApp.UI.Views.Dialogs.ExportTripTransferDialogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding Title}"
        Width="980"
        Height="560"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Background="Transparent"
        AllowsTransparency="True"
        WindowStyle="None">
    <Border Background="White" CornerRadius="10" BorderBrush="#1B3263" BorderThickness="1" Margin="10">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="44"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="62"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="#1B3263" CornerRadius="9,9,0,0">
                <Grid>
                    <TextBlock Text="{Binding Title}" Foreground="White" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center" Margin="16,0,0,0"/>
                    <Button Content="X"
                            Width="36"
                            Height="36"
                            HorizontalAlignment="Right"
                            Margin="0,4,4,4"
                            Background="Transparent"
                            Foreground="White"
                            BorderThickness="0"
                            Command="{Binding CancelCommand}"/>
                </Grid>
            </Border>

            <TextBlock Grid.Row="1"
                       Margin="20,18,20,12"
                       Text="{Binding Message}"
                       TextWrapping="Wrap"
                       Foreground="#334155"/>

            <Border Grid.Row="2" Margin="20,0,20,0" BorderBrush="#D6DEE8" BorderThickness="1" CornerRadius="8">
                <DataGrid ItemsSource="{Binding Options}"
                          SelectedItem="{Binding SelectedOption, Mode=TwoWay}"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          IsReadOnly="True"
                          SelectionMode="Single"
                          SelectionUnit="FullRow"
                          Style="{StaticResource SystemDataGridStyle}"
                          ColumnHeaderStyle="{StaticResource SystemDataGridColumnHeaderStyle}"
                          RowStyle="{StaticResource SystemDataGridRowStyle}"
                          CellStyle="{StaticResource SystemDataGridCellStyle}"
                          ScrollViewer.HorizontalScrollBarVisibility="Auto">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="MÃ CẮT LỆNH" Binding="{Binding ErpCutOrderId}" Width="160" ElementStyle="{StaticResource GridTextCenter}"/>
                        <DataGridTextColumn Header="SỐ PTVC GỐC" Binding="{Binding VehiclePlate}" Width="130" ElementStyle="{StaticResource GridTextCenter}"/>
                        <DataGridTextColumn Header="KHÁCH HÀNG" Binding="{Binding CustomerName}" Width="220" ElementStyle="{StaticResource GridTextLeft}"/>
                        <DataGridTextColumn Header="SẢN PHẨM" Binding="{Binding ProductName}" Width="220" ElementStyle="{StaticResource GridTextLeft}"/>
                        <DataGridTextColumn Header="SL ĐẶT (KG)" Binding="{Binding PlannedWeight, StringFormat='{}{0:N0}'}" Width="120" ElementStyle="{StaticResource GridTextRight}"/>
                        <DataGridTextColumn Header="CÒN LẠI (KG)" Binding="{Binding RemainingWeight, StringFormat='{}{0:N0}'}" Width="120" ElementStyle="{StaticResource GridTextRight}"/>
                        <DataGridTextColumn Header="SỐ CHUYẾN" Binding="{Binding TripCount}" Width="100" ElementStyle="{StaticResource GridTextCenter}"/>
                        <DataGridTextColumn Header="CHUYẾN CUỐI" Binding="{Binding LastTripAt, StringFormat='dd/MM/yyyy HH:mm'}" Width="150" ElementStyle="{StaticResource GridTextCenter}"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>

            <Border Grid.Row="3" Background="#F3F6FA" CornerRadius="0,0,9,9" Padding="16,12">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Hủy" Style="{StaticResource UtilityButtonStyle}" Margin="0,0,10,0" Command="{Binding CancelCommand}"/>
                    <Button Content="Chuyển chuyến" Style="{StaticResource PrimaryButtonStyle}" Command="{Binding ConfirmCommand}"/>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
