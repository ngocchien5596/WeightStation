<Window x:Class="StationApp.UI.Views.Dialogs.VehicleRepresentativeSelectionDialogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding Title}"
        Width="860"
        Height="520"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Background="Transparent"
        AllowsTransparency="True"
        WindowStyle="None">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/StationApp.UI;component/Resources/MonitoringTextResources.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>
    <Border Background="White" CornerRadius="10" BorderBrush="#1B3263" BorderThickness="1" Margin="10">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="44"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="62"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="#1B3263" CornerRadius="9,9,0,0">
                <Grid>
                    <TextBlock Text="{Binding Title}" Foreground="White" FontSize="14" FontWeight="Bold" VerticalAlignment="Center" Margin="16,0,0,0"/>
                    <Button Content="X"
                            Width="36"
                            Height="36"
                            HorizontalAlignment="Right"
                            Margin="0,4,4,4"
                            Background="Transparent"
                            Foreground="White"
                            BorderThickness="0"
                            Command="{Binding CancelCommand}"/>
                </Grid>
            </Border>

            <TextBlock Grid.Row="1"
                       Margin="20,18,20,12"
                       Text="{Binding Message}"
                       TextWrapping="Wrap"
                       Foreground="#334155"/>

            <Border Grid.Row="2" Margin="20,0,20,0" BorderBrush="#D6DEE8" BorderThickness="1" CornerRadius="8">
                <DataGrid ItemsSource="{Binding Options}"
                          SelectedItem="{Binding SelectedOption, Mode=TwoWay}"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          IsReadOnly="True"
                          SelectionMode="Single"
                          SelectionUnit="FullRow"
                          Style="{StaticResource SystemDataGridStyle}"
                          ColumnHeaderStyle="{StaticResource SystemDataGridColumnHeaderStyle}"
                          RowStyle="{StaticResource SystemDataGridRowStyle}"
                          CellStyle="{StaticResource SystemDataGridCellStyle}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="{StaticResource VehicleRep.ColRegistrationCode}" Binding="{Binding ErpCutOrderId}" Width="140"/>
                        <DataGridTextColumn Header="{StaticResource VehicleRep.ColVehiclePlate}" Binding="{Binding VehiclePlate}" Width="140"/>
                        <DataGridTextColumn Header="MOOC" Binding="{Binding MoocNumber}" Width="130"/>
                        <DataGridTextColumn Header="{StaticResource VehicleRep.ColDriver}" Binding="{Binding DriverName}" Width="180"/>
                        <DataGridTextColumn Header="{StaticResource VehicleRep.ColCreatedAt}" Binding="{Binding CreatedAt, StringFormat='dd/MM/yyyy HH:mm'}" Width="150"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>

            <Border Grid.Row="3" Background="#F3F6FA" CornerRadius="0,0,9,9" Padding="16,12">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="{StaticResource VehicleRep.Cancel}" Style="{StaticResource UtilityButtonStyle}" Margin="0,0,10,0" Command="{Binding CancelCommand}"/>
                    <Button Content="{StaticResource VehicleRep.Confirm}" Style="{StaticResource PrimaryButtonStyle}" Command="{Binding ConfirmCommand}"/>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>

