<Window x:Class="StationApp.UI.Views.Dialogs.ConfirmExportBagCountDialogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding Title}"
        Width="480"
        Height="500"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Background="Transparent"
        AllowsTransparency="True"
        WindowStyle="None">
    <Border Background="White" CornerRadius="10" BorderBrush="#1B3263" BorderThickness="1" Margin="10">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="44"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="62"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="#1B3263" CornerRadius="9,9,0,0">
                <Grid>
                    <TextBlock Text="{Binding Title}" Foreground="White" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center" Margin="16,0,0,0"/>
                    <Button Content="X"
                            Width="36"
                            Height="36"
                            HorizontalAlignment="Right"
                            Margin="0,4,4,4"
                            Background="Transparent"
                            Foreground="White"
                            BorderThickness="0"
                            Command="{Binding CancelCommand}"/>
                </Grid>
            </Border>

            <StackPanel Grid.Row="1" Margin="22,18,22,0">
                <TextBlock Text="{Binding Message}" TextWrapping="Wrap" Foreground="#334155" Margin="0,0,0,14"/>

                <Grid Margin="0,0,0,14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="150"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="28"/>
                        <RowDefinition Height="28"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Biển số xe" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding VehiclePlate}" VerticalAlignment="Center"/>
                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Khối lượng hàng" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding NetWeightText}" VerticalAlignment="Center"/>
                </Grid>

                <CheckBox Content="Hàng hoàn (Rách vỡ)"
                          IsChecked="{Binding IsReturnedBrokenTrip, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                          FontWeight="SemiBold"
                          Foreground="#334155"
                          Margin="0,0,0,14"
                          VerticalAlignment="Center"/>

                <Border Background="#F8FAFC" BorderBrush="#D6DEE8" BorderThickness="1" CornerRadius="8" Padding="14">
                    <StackPanel>
                        <TextBlock Text="Số bao thực tế" FontWeight="SemiBold" Margin="0,0,0,8"/>
                        <StackPanel Orientation="Horizontal">
                            <Button Content="-"
                                    Width="42"
                                    Height="34"
                                    FontSize="18"
                                    FontWeight="Bold"
                                    Style="{StaticResource UtilityButtonStyle}"
                                    Command="{Binding DecreaseCommand}"/>
                            <TextBox Width="130"
                                     Height="34"
                                     Margin="8,0"
                                     HorizontalContentAlignment="Center"
                                     VerticalContentAlignment="Center"
                                     FontSize="15"
                                     FontWeight="SemiBold"
                                     Text="{Binding ConfirmedBagCountText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                            <Button Content="+"
                                    Width="42"
                                    Height="34"
                                    FontSize="18"
                                    FontWeight="Bold"
                                    Style="{StaticResource UtilityButtonStyle}"
                                    Command="{Binding IncreaseCommand}"/>
                        </StackPanel>
                        <TextBlock Text="Số bao thực tế khác số hệ thống tính. Hệ thống sẽ lưu theo số bao bạn xác nhận."
                                   Foreground="#B45309"
                                   TextWrapping="Wrap"
                                   Margin="0,10,0,0">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding HasManualAdjustment}" Value="True">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>
                </Border>

                <Border Background="#F8FAFC" BorderBrush="#D6DEE8" BorderThickness="1" CornerRadius="8" Padding="14" Margin="0,14,0,0">
                    <StackPanel>
                        <TextBlock Text="Ghi chú" FontWeight="SemiBold" Margin="0,0,0,8"/>
                        <TextBox Height="72"
                                 TextWrapping="Wrap"
                                 AcceptsReturn="True"
                                 VerticalScrollBarVisibility="Auto"
                                 Text="{Binding Note, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>
                </Border>
            </StackPanel>

            <Border Grid.Row="2" Background="#F3F6FA" CornerRadius="0,0,9,9" Padding="16,12">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Hủy" Style="{StaticResource UtilityButtonStyle}" Margin="0,0,10,0" Command="{Binding CancelCommand}"/>
                    <Button Content="Đồng ý" Style="{StaticResource PrimaryButtonStyle}" Command="{Binding ConfirmCommand}"/>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
