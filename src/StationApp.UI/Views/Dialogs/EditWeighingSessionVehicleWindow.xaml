<Window x:Class="StationApp.UI.Views.Dialogs.EditWeighingSessionVehicleWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:StationApp.UI.Controls"
        Title="{Binding Title}"
        Width="580"
        MinHeight="530"
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Background="Transparent"
        AllowsTransparency="True"
        WindowStyle="None">
    <Window.Resources>
        <Style x:Key="SectionLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="#475569"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>
        <Style x:Key="ValueText" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
    </Window.Resources>

    <Border Background="White" CornerRadius="10" BorderBrush="#1B3263" BorderThickness="1" Margin="10">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="44"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="62"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0" Background="#1B3263" CornerRadius="9,9,0,0">
                <Grid>
                    <TextBlock Text="{Binding Title}" Foreground="White" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center" Margin="16,0,0,0"/>
                    <Button Content="X"
                            Width="36"
                            Height="36"
                            HorizontalAlignment="Right"
                            Margin="0,4,4,4"
                            Background="Transparent"
                            Foreground="White"
                            BorderThickness="0"
                            Command="{Binding CancelCommand}"/>
                </Grid>
            </Border>

            <!-- Content Area - Two Columns -->
            <Grid Grid.Row="1" Margin="22,18,22,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Left Column: Current Session Info -->
                <Border Grid.Row="0" Grid.Column="0" Background="#F8FAFC" BorderBrush="#D6DEE8" BorderThickness="1" CornerRadius="8" Padding="14">
                    <StackPanel>
                        <TextBlock Text="THÔNG TIN LƯỢT CÂN HIỆN TẠI" Style="{StaticResource SectionLabel}" Foreground="#475569"/>

                        <Grid Margin="0,4,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="24"/>
                                <RowDefinition Height="24"/>
                                <RowDefinition Height="24"/>
                                <RowDefinition Height="24"/>
                                <RowDefinition Height="24"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Số lượt cân:" Style="{StaticResource FieldLabel}" VerticalAlignment="Center"/>
                            <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding SessionNo}" Style="{StaticResource ValueText}" VerticalAlignment="Center"/>

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Biển số xe:" Style="{StaticResource FieldLabel}" VerticalAlignment="Center"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding OldVehiclePlate}" Style="{StaticResource ValueText}" VerticalAlignment="Center" Foreground="#1E3A8A"/>

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Cân L1 / L2 (kg):" Style="{StaticResource FieldLabel}" VerticalAlignment="Center"/>
                            <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="{Binding Weight1, StringFormat={}{0:N0}}" Style="{StaticResource ValueText}"/>
                                <TextBlock Text=" / " Margin="2,0"/>
                                <TextBlock Text="{Binding Weight2, StringFormat={}{0:N0}, TargetNullValue=--}" Style="{StaticResource ValueText}"/>
                            </StackPanel>

                            <TextBlock Grid.Row="3" Grid.Column="0" Text="TL xe chuẩn (kg):" Style="{StaticResource FieldLabel}" VerticalAlignment="Center"/>
                            <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding OldStandardTare, StringFormat={}{0:N0}, TargetNullValue=--}" Style="{StaticResource ValueText}" VerticalAlignment="Center"/>

                            <TextBlock Grid.Row="4" Grid.Column="0" Text="Khối lượng tịnh (kg):" Style="{StaticResource FieldLabel}" VerticalAlignment="Center"/>
                            <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding NetWeight, StringFormat={}{0:N0}, TargetNullValue=--}" Style="{StaticResource ValueText}" Foreground="#B91C1C" FontSize="14" VerticalAlignment="Center"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Right Column: Expected New Info -->
                <Border Grid.Row="0" Grid.Column="2" Background="#EFF6FF" BorderBrush="#BFDBFE" BorderThickness="1" CornerRadius="8" Padding="14">
                    <StackPanel>
                        <TextBlock Text="SỐ LIỆU DỰ KIẾN SAU SỬA" Style="{StaticResource SectionLabel}" Foreground="#1E40AF"/>

                        <Grid Margin="0,4,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="24"/>
                                <RowDefinition Height="24"/>
                                <RowDefinition Height="24"/>
                                <RowDefinition Height="24"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Biển số xe mới:" Style="{StaticResource FieldLabel}" VerticalAlignment="Center"/>
                            <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding SelectedVehicle.VehiclePlate, TargetNullValue=--}" Style="{StaticResource ValueText}" Foreground="#1E40AF" VerticalAlignment="Center"/>

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Tài xế mới:" Style="{StaticResource FieldLabel}" VerticalAlignment="Center"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding SelectedDriverName, TargetNullValue=--}" Style="{StaticResource ValueText}" VerticalAlignment="Center"/>

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="TL xe chuẩn (kg):" Style="{StaticResource FieldLabel}" VerticalAlignment="Center"/>
                            <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding NewStandardTareWeight, StringFormat={}{0:N0}, TargetNullValue=--}" Style="{StaticResource ValueText}" VerticalAlignment="Center"/>

                            <TextBlock Grid.Row="3" Grid.Column="0" Text="Khối lượng tịnh (kg):" Style="{StaticResource FieldLabel}" VerticalAlignment="Center"/>
                            <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding NewNetWeight, StringFormat={}{0:N0}, TargetNullValue=--}" Style="{StaticResource ValueText}" Foreground="#B91C1C" FontSize="14" VerticalAlignment="Center"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- New Vehicle Plate Input -->
                <StackPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3" Margin="0,10,0,0">
                    <TextBlock Text="Nhập biển số xe mới" FontWeight="SemiBold" Margin="0,0,0,6"/>
                    <controls:AutocompleteTextBox State="{Binding VehiclePlateInput}" Height="36" BorderBrush="#CBD5E1" BorderThickness="1"/>
                </StackPanel>

                <!-- Reason Input & Validation -->
                <StackPanel Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="3" Margin="0,12,0,0">
                    <TextBlock Text="Lý do sửa đổi (Bắt buộc)" FontWeight="SemiBold" Margin="0,0,0,6"/>
                    <TextBox Height="70"
                             TextWrapping="Wrap"
                             AcceptsReturn="True"
                             VerticalScrollBarVisibility="Auto"
                             Text="{Binding Reason, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             Padding="6"
                             BorderBrush="#CBD5E1"
                             BorderThickness="1"/>
                    <TextBlock Text="{Binding ValidationMessage}" Foreground="#B91C1C" FontWeight="SemiBold" Margin="0,6,0,0" TextWrapping="Wrap"/>
                </StackPanel>
            </Grid>

            <!-- Buttons -->
            <Border Grid.Row="2" Background="#F3F6FA" CornerRadius="0,0,9,9" Padding="16,12">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Hủy" Style="{StaticResource UtilityButtonStyle}" Margin="0,0,10,0" Command="{Binding CancelCommand}"/>
                    <Button Content="Lưu thay đổi" Style="{StaticResource PrimaryButtonStyle}" Command="{Binding SaveCommand}"/>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
