<UserControl x:Class="StationApp.UI.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:settings="clr-namespace:StationApp.UI.Views.Settings"
             Background="Transparent">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/StationApp.UI;component/Themes/AppTheme.xaml"/>
                <ResourceDictionary Source="/StationApp.UI;component/Styles/ButtonStyles.xaml"/>
                <ResourceDictionary Source="/StationApp.UI;component/Styles/InputStyles.xaml"/>
                <ResourceDictionary Source="/StationApp.UI;component/Styles/BasePageStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <SolidColorBrush x:Key="EnterpriseDarkBlue" Color="#123B6B"/>
            <SolidColorBrush x:Key="EnterprisePanelBg" Color="#E8EFF7"/>
            <SolidColorBrush x:Key="EnterpriseSave" Color="#007F54"/>
            <SolidColorBrush x:Key="EnterpriseDelete" Color="#BD2730"/>
            
            <Style x:Key="SettingLabel" TargetType="TextBlock">
                <Setter Property="FontSize" Value="14"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="Foreground" Value="#333333"/>
                <Setter Property="Margin" Value="0,12,0,4"/>
            </Style>
            <Style x:Key="SettingBox" TargetType="TextBox">
                <Setter Property="Height" Value="36"/>
                <Setter Property="Background" Value="#FFFFFF"/>
                <Setter Property="Foreground" Value="#333333"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="BorderBrush" Value="#CCCCCC"/>
                <Setter Property="Padding" Value="8,6"/>
            </Style>

            <Style TargetType="DataGrid">
                <Setter Property="Background" Value="#FFFFFF"/>
                <Setter Property="BorderBrush" Value="#CCCCCC"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="RowBackground" Value="#FFFFFF"/>
                <Setter Property="AlternatingRowBackground" Value="#F9F9F9"/>
                <Setter Property="GridLinesVisibility" Value="All"/>
                <Setter Property="VerticalGridLinesBrush" Value="#E0E0E0"/>
                <Setter Property="HorizontalGridLinesBrush" Value="#E0E0E0"/>
                <Setter Property="Foreground" Value="#333333"/>
                <Setter Property="FontSize" Value="13"/>
                <Setter Property="RowHeight" Value="32"/>
            </Style>
            <Style TargetType="DataGridColumnHeader">
                <Setter Property="Background" Value="{StaticResource EnterpriseDarkBlue}"/>
                <Setter Property="Foreground" Value="#FFFFFF"/>
                <Setter Property="FontWeight" Value="Bold"/>
                <Setter Property="Padding" Value="12,8"/>
                <Setter Property="BorderThickness" Value="0,0,1,1"/>
                <Setter Property="BorderBrush" Value="#102542"/>
                <Setter Property="Height" Value="40"/>
            </Style>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Top Header Banner -->
        <Border Grid.Row="0" Background="{StaticResource EnterpriseDarkBlue}" CornerRadius="4" Padding="12" Margin="0,0,0,16">
            <TextBlock Text="{Binding ViewTitle}" FontSize="18" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
        </Border>

        <TabControl Grid.Row="1" SelectedIndex="{Binding SelectedTabIndex}" Background="Transparent" BorderThickness="0">
            <TabControl.ItemContainerStyle>
                <Style TargetType="TabItem">
                    <Setter Property="Visibility" Value="Collapsed"/>
                </Style>
            </TabControl.ItemContainerStyle>
            
            <TabItem Header="THAM SỐ HỆ THỐNG">
                <settings:SystemSettingsView DataContext="{Binding SystemSettingsVM}"/>
            </TabItem>

            <TabItem Header="THIẾT BỊ CÂN">
                <settings:ScaleDeviceConfigView DataContext="{Binding ScaleDeviceConfigVM}"/>
            </TabItem>

            <TabItem Header="MASTER XE">
                <settings:VehicleMasterView DataContext="{Binding VehicleMasterVM}"/>
            </TabItem>

            <TabItem Header="KHÁCH HÀNG">
                <settings:CustomerMasterView DataContext="{Binding CustomerMasterVM}"/>
            </TabItem>

            <TabItem Header="SẢN PHẨM">
                <settings:ProductMasterView DataContext="{Binding ProductMasterVM}"/>
            </TabItem>

            <TabItem Header="ĐỒNG BỘ">
                <settings:SyncInfoView DataContext="{Binding SyncInfoVM}"/>
            </TabItem>

            <TabItem Header="QUẢN LÝ TÀI KHOẢN">
                <settings:AccountManagementView DataContext="{Binding AccountManagementVM}"/>
            </TabItem>
        </TabControl>
    </Grid>
</UserControl>
