<UserControl x:Class="StationApp.UI.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:settings="clr-namespace:StationApp.UI.Views.Settings"
             Background="Transparent">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/StationApp.UI;component/Themes/AppTheme.xaml"/>
                <ResourceDictionary Source="/StationApp.UI;component/Styles/ButtonStyles.xaml"/>
                <ResourceDictionary Source="/StationApp.UI;component/Styles/InputStyles.xaml"/>
                <ResourceDictionary Source="/StationApp.UI;component/Styles/BasePageStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <SolidColorBrush x:Key="EnterpriseDarkBlue" Color="#123B6B"/>
            <SolidColorBrush x:Key="EnterprisePanelBg" Color="#E8EFF7"/>
            <SolidColorBrush x:Key="EnterpriseSave" Color="#007F54"/>
            <SolidColorBrush x:Key="EnterpriseDelete" Color="#BD2730"/>

            <Style x:Key="SettingLabel" TargetType="TextBlock">
                <Setter Property="FontSize" Value="14"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="Foreground" Value="#333333"/>
                <Setter Property="Margin" Value="0,12,0,4"/>
            </Style>
            <Style x:Key="SettingBox" TargetType="TextBox">
                <Setter Property="Height" Value="36"/>
                <Setter Property="Background" Value="#FFFFFF"/>
                <Setter Property="Foreground" Value="#333333"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="BorderBrush" Value="#CCCCCC"/>
                <Setter Property="Padding" Value="8,6"/>
            </Style>

            <Style TargetType="DataGrid">
                <Setter Property="Background" Value="#FFFFFF"/>
                <Setter Property="BorderBrush" Value="#CCCCCC"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="RowBackground" Value="#FFFFFF"/>
                <Setter Property="AlternatingRowBackground" Value="#F9F9F9"/>
                <Setter Property="GridLinesVisibility" Value="All"/>
                <Setter Property="VerticalGridLinesBrush" Value="#E0E0E0"/>
                <Setter Property="HorizontalGridLinesBrush" Value="#E0E0E0"/>
                <Setter Property="Foreground" Value="#333333"/>
                <Setter Property="FontSize" Value="13"/>
                <Setter Property="RowHeight" Value="32"/>
            </Style>
            <Style TargetType="DataGridColumnHeader">
                <Setter Property="Background" Value="{StaticResource EnterpriseDarkBlue}"/>
                <Setter Property="Foreground" Value="#FFFFFF"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="Padding" Value="12,8"/>
                <Setter Property="BorderThickness" Value="0,0,1,1"/>
                <Setter Property="BorderBrush" Value="#102542"/>
                <Setter Property="Height" Value="40"/>
            </Style>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{StaticResource EnterpriseDarkBlue}" CornerRadius="4" Padding="12" Margin="0,0,0,16">
            <TextBlock Text="{Binding ViewTitle}" FontSize="18" FontWeight="SemiBold" Foreground="White" HorizontalAlignment="Center"/>
        </Border>

        <TabControl Grid.Row="1" SelectedIndex="{Binding SelectedTabIndex}" Background="Transparent" BorderThickness="0">
            <TabControl.Template>
                <ControlTemplate TargetType="TabControl">
                    <Border Background="Transparent">
                        <ContentPresenter ContentSource="SelectedContent"/>
                    </Border>
                </ControlTemplate>
            </TabControl.Template>

            <TabItem Header="THAM S&#x1ED0; H&#x1EC6; TH&#x1ED0;NG" Visibility="{Binding CanAccessSystemSettings, Converter={StaticResource BoolToVis}}">
                <settings:SystemSettingsView DataContext="{Binding SystemSettingsVM}"/>
            </TabItem>

            <TabItem Header="THI&#x1EBE;T B&#x1ECA; C&#xC2;N" Visibility="{Binding CanAccessScaleDeviceConfig, Converter={StaticResource BoolToVis}}">
                <settings:ScaleDeviceConfigView DataContext="{Binding ScaleDeviceConfigVM}"/>
            </TabItem>

            <TabItem Header="C&#x1EA4;U H&#x00CC;NH IN" Visibility="{Binding CanAccessPrintConfig, Converter={StaticResource BoolToVis}}">
                <settings:PrintConfigView DataContext="{Binding PrintConfigVM}"/>
            </TabItem>

            <TabItem Header="DANH M&#x1EE4;C XE" Visibility="{Binding CanAccessVehicleMaster, Converter={StaticResource BoolToVis}}">
                <settings:VehicleMasterView DataContext="{Binding VehicleMasterVM}"/>
            </TabItem>

            <TabItem Header="KH&#xC1;CH H&#xC0;NG" Visibility="{Binding CanAccessCustomerMaster, Converter={StaticResource BoolToVis}}">
                <settings:CustomerMasterView DataContext="{Binding CustomerMasterVM}"/>
            </TabItem>

            <TabItem Header="S&#x1EA2;N PH&#x1EA8;M" Visibility="{Binding CanAccessProductMaster, Converter={StaticResource BoolToVis}}">
                <settings:ProductMasterView DataContext="{Binding ProductMasterVM}"/>
            </TabItem>

            <TabItem Header="&#x110;&#x1ED2;NG B&#x1ED8;" Visibility="{Binding CanAccessSyncInfo, Converter={StaticResource BoolToVis}}">
                <settings:SyncInfoView DataContext="{Binding SyncInfoVM}"/>
            </TabItem>

            <TabItem Header="L&#x1ECA;CH S&#x1EEC; C&#xC2;N (PM C&#x168;)" Visibility="{Binding CanAccessExternalDatacan, Converter={StaticResource BoolToVis}}">
                <settings:ExternalDatacanView DataContext="{Binding ExternalDatacanVM}"/>
            </TabItem>

            <TabItem Header="QU&#x1EA2;N L&#xDD; T&#xC0;I KHO&#x1EA2;N" Visibility="{Binding CanAccessAccountManagement, Converter={StaticResource BoolToVis}}">
                <settings:AccountManagementView DataContext="{Binding AccountManagementVM}"/>
            </TabItem>

            <TabItem Header="C&#x1EA5;u h&#x00EC;nh camera" Visibility="{Binding CanAccessSystemSettings, Converter={StaticResource BoolToVis}}">
                <settings:CameraConfigView DataContext="{Binding CameraConfigVM}"/>
            </TabItem>
        </TabControl>
    </Grid>
</UserControl>
