<UserControl x:Class="StationApp.UI.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/StationApp.UI;component/Themes/AppTheme.xaml"/>
                <ResourceDictionary Source="/StationApp.UI;component/Styles/ButtonStyles.xaml"/>
                <ResourceDictionary Source="/StationApp.UI;component/Styles/InputStyles.xaml"/>
                <ResourceDictionary Source="/StationApp.UI;component/Styles/BasePageStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <Style x:Key="KpiCardStyle" TargetType="Border">
                <Setter Property="Background" Value="{DynamicResource CardBrush}"/>
                <Setter Property="Margin" Value="8"/>
                <Setter Property="Padding" Value="18"/>
                <Setter Property="CornerRadius" Value="12"/>
                <Setter Property="BorderBrush" Value="#E2E8F0"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="Effect">
                    <Setter.Value>
                        <DropShadowEffect BlurRadius="12" Color="#0C1A30" Opacity="0.06" ShadowDepth="3" Direction="270"/>
                    </Setter.Value>
                </Setter>
            </Style>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid Background="{DynamicResource BackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource HeaderBorder}">
            <DockPanel>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Ngày thống kê" Style="{StaticResource HeaderLabel}" Margin="0,0,8,0"/>
                    <DatePicker SelectedDate="{Binding SelectedDate, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                Width="168"
                                SelectedDateFormat="Short"
                                VerticalAlignment="Center"
                                Style="{StaticResource StandardDatePickerStyle}"/>

                    <TextBlock Text="Mã trạm" Style="{StaticResource HeaderLabel}" Margin="20,0,8,0"/>
                    <Border Width="140"
                            Height="36"
                            BorderBrush="#D5E3F2"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="10,7"
                            Background="#F8FAFC"
                            VerticalAlignment="Center">
                        <TextBlock Text="{Binding StationCode}"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource AccentBrush}"
                                   VerticalAlignment="Center"/>
                    </Border>

                    <Button Command="{Binding RefreshCommand}" Style="{StaticResource HeaderActionButton}" Margin="20,0,0,0">
                        <TextBlock Text="LÀM MỚI" VerticalAlignment="Center"/>
                    </Button>
                </StackPanel>
            </DockPanel>
        </Border>

        <TextBlock Grid.Row="1"
                   Margin="20,12,20,4"
                   Text="KPI theo ngày"
                   FontSize="15"
                   FontWeight="SemiBold"
                   Foreground="{DynamicResource ForegroundBrush}"/>

        <ScrollViewer Grid.Row="2"
                      Margin="12,0,12,12"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <StackPanel>
                <UniformGrid Columns="4">
                    <Border Style="{StaticResource KpiCardStyle}">
                        <StackPanel>
                            <TextBlock Text="Xe nhập chờ cân" Foreground="#64748B" FontSize="12"/>
                            <TextBlock Text="{Binding InboundWaitingCount}" FontSize="42" FontWeight="SemiBold" Foreground="#1D4ED8"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource KpiCardStyle}">
                        <StackPanel>
                            <TextBlock Text="Xe nhập đang xử lý" Foreground="#64748B" FontSize="12"/>
                            <TextBlock Text="{Binding InboundProcessingCount}" FontSize="42" FontWeight="SemiBold" Foreground="#0EA5E9"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource KpiCardStyle}">
                        <StackPanel>
                            <TextBlock Text="Xe nhập đã xong" Foreground="#64748B" FontSize="12"/>
                            <TextBlock Text="{Binding InboundCompletedCount}" FontSize="42" FontWeight="SemiBold" Foreground="#16A34A"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource KpiCardStyle}">
                        <StackPanel>
                            <TextBlock Text="Số tấn nhập hàng" Foreground="#64748B" FontSize="12"/>
                            <TextBlock Text="{Binding InboundCompletedTonnage, StringFormat={}{0:N3}}" FontSize="36" FontWeight="SemiBold" Foreground="#15803D"/>
                        </StackPanel>
                    </Border>
                </UniformGrid>

                <UniformGrid Columns="4" Margin="0,8,0,0">
                    <Border Style="{StaticResource KpiCardStyle}">
                        <StackPanel>
                            <TextBlock Text="Xe xuất chờ cân" Foreground="#64748B" FontSize="12"/>
                            <TextBlock Text="{Binding OutboundWaitingCount}" FontSize="42" FontWeight="SemiBold" Foreground="#1E40AF"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource KpiCardStyle}">
                        <StackPanel>
                            <TextBlock Text="Xe xuất đang lấy hàng" Foreground="#64748B" FontSize="12"/>
                            <TextBlock Text="{Binding OutboundProcessingCount}" FontSize="42" FontWeight="SemiBold" Foreground="#2563EB"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource KpiCardStyle}">
                        <StackPanel>
                            <TextBlock Text="Xe xuất đã xong" Foreground="#64748B" FontSize="12"/>
                            <TextBlock Text="{Binding OutboundCompletedCount}" FontSize="42" FontWeight="SemiBold" Foreground="#22C55E"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource KpiCardStyle}">
                        <StackPanel>
                            <TextBlock Text="Số tấn xuất hàng" Foreground="#64748B" FontSize="12"/>
                            <TextBlock Text="{Binding OutboundCompletedTonnage, StringFormat={}{0:N3}}" FontSize="36" FontWeight="SemiBold" Foreground="#15803D"/>
                        </StackPanel>
                    </Border>
                </UniformGrid>

                <UniformGrid Columns="3" Margin="0,8,0,0">
                    <Border Style="{StaticResource KpiCardStyle}">
                        <StackPanel>
                            <TextBlock Text="Central API" Foreground="#64748B" FontSize="12"/>
                            <TextBlock Text="{Binding NetworkStatus}" FontSize="22" FontWeight="SemiBold" Foreground="{Binding NetworkStatusBrush}" Margin="0,8,0,0"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource KpiCardStyle}">
                        <StackPanel>
                            <TextBlock Text="Thiết bị cân" Foreground="#64748B" FontSize="12"/>
                            <TextBlock Text="{Binding DeviceStatus}" FontSize="22" FontWeight="SemiBold" Foreground="{Binding DeviceStatusBrush}" Margin="0,8,0,0"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource KpiCardStyle}">
                        <StackPanel>
                            <TextBlock Text="Lần sync gần nhất" Foreground="#64748B" FontSize="12"/>
                            <TextBlock Text="{Binding LastSyncTime}" FontSize="22" FontWeight="SemiBold" Foreground="{DynamicResource ForegroundBrush}" Margin="0,8,0,0" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>
                </UniformGrid>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
