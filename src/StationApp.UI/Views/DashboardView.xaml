<UserControl x:Class="StationApp.UI.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/StationApp.UI;component/Themes/AppTheme.xaml"/>
                <ResourceDictionary Source="/StationApp.UI;component/Styles/ButtonStyles.xaml"/>
                <ResourceDictionary Source="/StationApp.UI;component/Styles/InputStyles.xaml"/>
                <ResourceDictionary Source="/StationApp.UI;component/Styles/BasePageStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <Style x:Key="KpiCardStyle" TargetType="Border">
                <Setter Property="Background" Value="{DynamicResource CardBrush}"/>
                <Setter Property="Margin" Value="8"/>
                <Setter Property="Padding" Value="18"/>
                <Setter Property="CornerRadius" Value="12"/>
                <Setter Property="BorderBrush" Value="#E2E8F0"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="Effect">
                    <Setter.Value>
                        <DropShadowEffect BlurRadius="12" Color="#0C1A30" Opacity="0.06" ShadowDepth="3" Direction="270"/>
                    </Setter.Value>
                </Setter>
            </Style>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid Background="{DynamicResource BackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource HeaderBorder}">
            <DockPanel>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Ng&#x00E0;y th&#x1ED1;ng k&#x00EA;" Style="{StaticResource HeaderLabel}" Margin="0,0,8,0"/>
                    <DatePicker SelectedDate="{Binding SelectedDate, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                Width="168"
                                SelectedDateFormat="Short"
                                VerticalAlignment="Center"
                                Style="{StaticResource StandardDatePickerStyle}"/>

                    <Button Command="{Binding RefreshCommand}" Style="{StaticResource HeaderActionButton}" Margin="20,0,0,0">
                        <TextBlock Text="L&#x00C0;M M&#x1EDA;I" VerticalAlignment="Center"/>
                    </Button>
                </StackPanel>
            </DockPanel>
        </Border>

        <TextBlock Grid.Row="1"
                   Margin="20,12,20,4"
                   Text="{Binding DashboardKpiTitle}"
                   FontSize="15"
                   FontWeight="SemiBold"
                   Foreground="{DynamicResource ForegroundBrush}"/>

        <ScrollViewer Grid.Row="2"
                      Margin="12,0,12,12"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <StackPanel>
                <UniformGrid Columns="4" Visibility="{Binding ShowInboundKpi, Converter={StaticResource BoolToVis}}">
                    <Border Style="{StaticResource KpiCardStyle}">
                        <StackPanel>
                            <TextBlock Text="Xe nh&#x1EAD;p ch&#x1EDD; c&#x00E2;n" Foreground="#64748B" FontSize="12"/>
                            <TextBlock Text="{Binding InboundWaitingCount}" FontSize="42" FontWeight="SemiBold" Foreground="#1D4ED8"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource KpiCardStyle}">
                        <StackPanel>
                            <TextBlock Text="Xe nh&#x1EAD;p &#x111;ang x&#x1EED; l&#x00FD;" Foreground="#64748B" FontSize="12"/>
                            <TextBlock Text="{Binding InboundProcessingCount}" FontSize="42" FontWeight="SemiBold" Foreground="#0EA5E9"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource KpiCardStyle}">
                        <StackPanel>
                            <TextBlock Text="Xe nh&#x1EAD;p &#x111;&#x00E3; xong" Foreground="#64748B" FontSize="12"/>
                            <TextBlock Text="{Binding InboundCompletedCount}" FontSize="42" FontWeight="SemiBold" Foreground="#16A34A"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource KpiCardStyle}">
                        <StackPanel>
                            <TextBlock Text="S&#x1ED1; t&#x1EA5;n nh&#x1EAD;p h&#x00E0;ng" Foreground="#64748B" FontSize="12"/>
                            <TextBlock Text="{Binding InboundCompletedTonnage, StringFormat={}{0:N3}}" FontSize="36" FontWeight="SemiBold" Foreground="#15803D"/>
                        </StackPanel>
                    </Border>
                </UniformGrid>

                <UniformGrid Columns="4" Margin="0,8,0,0" Visibility="{Binding ShowOutboundKpi, Converter={StaticResource BoolToVis}}">
                    <Border Style="{StaticResource KpiCardStyle}">
                        <StackPanel>
                            <TextBlock Text="Xe xu&#x1EA5;t ch&#x1EDD; c&#x00E2;n" Foreground="#64748B" FontSize="12"/>
                            <TextBlock Text="{Binding OutboundWaitingCount}" FontSize="42" FontWeight="SemiBold" Foreground="#1E40AF"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource KpiCardStyle}">
                        <StackPanel>
                            <TextBlock Text="Xe xu&#x1EA5;t &#x111;ang l&#x1EA5;y h&#x00E0;ng" Foreground="#64748B" FontSize="12"/>
                            <TextBlock Text="{Binding OutboundProcessingCount}" FontSize="42" FontWeight="SemiBold" Foreground="#2563EB"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource KpiCardStyle}">
                        <StackPanel>
                            <TextBlock Text="Xe xu&#x1EA5;t &#x111;&#x00E3; xong" Foreground="#64748B" FontSize="12"/>
                            <TextBlock Text="{Binding OutboundCompletedCount}" FontSize="42" FontWeight="SemiBold" Foreground="#22C55E"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource KpiCardStyle}">
                        <StackPanel>
                            <TextBlock Text="S&#x1ED1; t&#x1EA5;n xu&#x1EA5;t h&#x00E0;ng" Foreground="#64748B" FontSize="12"/>
                            <TextBlock Text="{Binding OutboundCompletedTonnage, StringFormat={}{0:N3}}" FontSize="36" FontWeight="SemiBold" Foreground="#15803D"/>
                        </StackPanel>
                    </Border>
                </UniformGrid>

                <UniformGrid Columns="3" Margin="0,8,0,0" Visibility="{Binding ShowCrusherKpi, Converter={StaticResource BoolToVis}}">
                    <Border Style="{StaticResource KpiCardStyle}">
                        <StackPanel>
                            <TextBlock Text="Đang cân" Foreground="#64748B" FontSize="12"/>
                            <TextBlock Text="{Binding CrusherActiveCount}" FontSize="42" FontWeight="SemiBold" Foreground="#2563EB"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource KpiCardStyle}">
                        <StackPanel>
                            <TextBlock Text="Đã hoàn thành" Foreground="#64748B" FontSize="12"/>
                            <TextBlock Text="{Binding CrusherCompletedCount}" FontSize="42" FontWeight="SemiBold" Foreground="#16A34A"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource KpiCardStyle}">
                        <StackPanel>
                            <TextBlock Text="{Binding SpecialStationCompletedTonnageLabel}" Foreground="#64748B" FontSize="12"/>
                            <TextBlock Text="{Binding CrusherCompletedTonnage, StringFormat={}{0:N3}}" FontSize="36" FontWeight="SemiBold" Foreground="#15803D"/>
                        </StackPanel>
                    </Border>
                </UniformGrid>

                <UniformGrid Columns="3" Margin="0,8,0,0">
                    <Border Style="{StaticResource KpiCardStyle}">
                        <StackPanel>
                            <TextBlock Text="Central API" Foreground="#64748B" FontSize="12"/>
                            <TextBlock Text="{Binding NetworkStatus}" FontSize="22" FontWeight="SemiBold" Foreground="{Binding NetworkStatusBrush}" Margin="0,8,0,0"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource KpiCardStyle}">
                        <StackPanel>
                            <TextBlock Text="Thi&#x1EBF;t b&#x1ECB; c&#x00E2;n" Foreground="#64748B" FontSize="12"/>
                            <TextBlock Text="{Binding DeviceStatus}" FontSize="22" FontWeight="SemiBold" Foreground="{Binding DeviceStatusBrush}" Margin="0,8,0,0"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource KpiCardStyle}">
                        <StackPanel>
                            <TextBlock Text="L&#x1EA7;n sync g&#x1EA7;n nh&#x1EA5;t" Foreground="#64748B" FontSize="12"/>
                            <TextBlock Text="{Binding LastSyncTime}" FontSize="22" FontWeight="SemiBold" Foreground="{DynamicResource ForegroundBrush}" Margin="0,8,0,0" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>
                </UniformGrid>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>

