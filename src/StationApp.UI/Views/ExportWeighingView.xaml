<UserControl x:Class="StationApp.UI.Views.ExportWeighingView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:StationApp.UI.Controls"
             xmlns:converters="clr-namespace:StationApp.UI.Converters"
             Background="{StaticResource MainContentBackground}">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/StationApp.UI;component/Themes/AppTheme.xaml"/>
                <ResourceDictionary Source="/StationApp.UI;component/Styles/ButtonStyles.xaml"/>
                <ResourceDictionary Source="/StationApp.UI;component/Styles/InputStyles.xaml"/>
                <ResourceDictionary Source="/StationApp.UI;component/Styles/BasePageStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <converters:SessionStatusDisplayConverter x:Key="SessionStatusDisplayConverter"/>
            <converters:WeightToTonConverter x:Key="WeightToTonConverter"/>
            <Style x:Key="FormLabel" TargetType="TextBlock" BasedOn="{StaticResource FieldLabelStyle}">
                <Setter Property="Margin" Value="0,0,8,0"/>
                <Setter Property="HorizontalAlignment" Value="Right"/>
                <Setter Property="VerticalAlignment" Value="Center"/>
            </Style>
            <Style x:Key="FormBox" TargetType="TextBox" BasedOn="{StaticResource StandardTextBoxStyle}">
                <Setter Property="Margin" Value="0,2"/>
            </Style>
            <Style x:Key="FormDatePicker" TargetType="DatePicker" BasedOn="{StaticResource StandardDatePickerStyle}">
                <Setter Property="Margin" Value="0,2"/>
            </Style>
            <Style x:Key="VehicleExpiryLabelStyle" TargetType="TextBlock" BasedOn="{StaticResource FormLabel}">
                <Style.Triggers>
                    <DataTrigger Binding="{Binding IsVehicleRegistrationExpired}" Value="True">
                        <Setter Property="Foreground" Value="#C0392B"/>
                        <Setter Property="FontWeight" Value="SemiBold"/>
                    </DataTrigger>
                </Style.Triggers>
            </Style>
            <Style x:Key="MoocExpiryLabelStyle" TargetType="TextBlock" BasedOn="{StaticResource FormLabel}">
                <Style.Triggers>
                    <DataTrigger Binding="{Binding IsMoocRegistrationExpired}" Value="True">
                        <Setter Property="Foreground" Value="#C0392B"/>
                        <Setter Property="FontWeight" Value="SemiBold"/>
                    </DataTrigger>
                </Style.Triggers>
            </Style>
            <Style x:Key="VehicleExpiryDatePickerStyle" TargetType="DatePicker" BasedOn="{StaticResource FormDatePicker}">
                <Style.Triggers>
                    <DataTrigger Binding="{Binding IsVehicleRegistrationExpired}" Value="True">
                        <Setter Property="Foreground" Value="#C0392B"/>
                        <Setter Property="FontWeight" Value="SemiBold"/>
                    </DataTrigger>
                </Style.Triggers>
            </Style>
            <Style x:Key="MoocExpiryDatePickerStyle" TargetType="DatePicker" BasedOn="{StaticResource FormDatePicker}">
                <Style.Triggers>
                    <DataTrigger Binding="{Binding IsMoocRegistrationExpired}" Value="True">
                        <Setter Property="Foreground" Value="#C0392B"/>
                        <Setter Property="FontWeight" Value="SemiBold"/>
                    </DataTrigger>
                </Style.Triggers>
            </Style>
            <Style x:Key="MetricLabel" TargetType="TextBlock" BasedOn="{StaticResource FieldLabelStyle}">
                <Setter Property="Foreground" Value="#5D6D7E"/>
                <Setter Property="HorizontalAlignment" Value="Center"/>
                <Setter Property="Margin" Value="0,0,0,4"/>
            </Style>
            <Style x:Key="MetricValue" TargetType="TextBlock">
                <Setter Property="FontFamily" Value="{StaticResource AppFontFamily}"/>
                <Setter Property="FontSize" Value="24"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="Foreground" Value="#203B73"/>
                <Setter Property="HorizontalAlignment" Value="Center"/>
                <Setter Property="VerticalAlignment" Value="Center"/>
            </Style>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource HeaderBorder}">
            <DockPanel>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="M&#xE3; c&#x1EAF;t l&#x1EC7;nh" Style="{StaticResource HeaderLabel}" Margin="20,0,8,0"/>
                    <TextBox Width="180"
                             Style="{StaticResource StandardTextBoxStyle}"
                             Text="{Binding SearchErpCutOrderId, UpdateSourceTrigger=PropertyChanged}">
                        <TextBox.InputBindings>
                            <KeyBinding Key="Enter" Command="{Binding RefreshCommand}"/>
                        </TextBox.InputBindings>
                    </TextBox>

                    <TextBlock Text="S&#x1ED1; PTVC" Style="{StaticResource HeaderLabel}" Margin="20,0,8,0"/>
                    <TextBox Width="160"
                             Style="{StaticResource StandardTextBoxStyle}"
                             Text="{Binding SearchVehiclePlate, UpdateSourceTrigger=PropertyChanged}">
                        <TextBox.InputBindings>
                            <KeyBinding Key="Enter" Command="{Binding RefreshCommand}"/>
                        </TextBox.InputBindings>
                    </TextBox>

                    <Button Command="{Binding RefreshCommand}" Style="{StaticResource HeaderActionButton}" Margin="20,0,0,0">
                        <TextBlock Text="{StaticResource Workflow.RefreshButton}" VerticalAlignment="Center"/>
                    </Button>
                </StackPanel>
            </DockPanel>
        </Border>

        <Grid Grid.Row="1" Margin="12,10,12,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="320"/>
                <ColumnDefinition Width="360"/>
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="8"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

            <Border Grid.Row="0" BorderBrush="#D0D3D4" BorderThickness="1" CornerRadius="4" Padding="12" Background="White">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*" MinWidth="85"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*" MinWidth="85"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*" MinWidth="85"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*" MinWidth="85"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="30"/>
                        <RowDefinition Height="30"/>
                        <RowDefinition Height="30"/>
                        <RowDefinition Height="30"/>
                        <RowDefinition Height="30"/>
                    </Grid.RowDefinitions>

                    <!-- Row 0: Mã cắt lệnh & Khách hàng -->
                    <TextBlock Text="M&#xE3; c&#x1EAF;t l&#x1EC7;nh" Grid.Row="0" Grid.Column="0" Style="{StaticResource FormLabel}"/>
                    <TextBox Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="3" HorizontalAlignment="Left" Width="180" Text="{Binding SelectedCutOrder.DisplayCutOrderCode, Mode=OneWay}" IsReadOnly="True" Style="{StaticResource FormBox}" Background="#F8F9F9"/>

                    <TextBlock Text="Kh&#xE1;ch h&#xE0;ng" Grid.Row="0" Grid.Column="4" Style="{StaticResource FormLabel}"/>
                    <TextBox Grid.Row="0" Grid.Column="5" Grid.ColumnSpan="3" HorizontalAlignment="Stretch" Text="{Binding SelectedCutOrder.CustomerName, Mode=OneWay}" IsReadOnly="True" Style="{StaticResource FormBox}" Background="#F8F9F9"/>

                    <!-- Row 1: Chuyến cuối & Sản phẩm -->
                    <TextBlock Text="Chuy&#x1EBF;n cu&#x1ED1;i" Grid.Row="1" Grid.Column="0" Style="{StaticResource FormLabel}"/>
                    <TextBox Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="3" HorizontalAlignment="Left" Width="180" Text="{Binding SelectedCutOrder.LastTripAt, Mode=OneWay, StringFormat='{}{0:dd/MM/yyyy HH:mm}'}" IsReadOnly="True" Style="{StaticResource FormBox}" Background="#F8F9F9"/>

                    <TextBlock Text="S&#x1EA3;n ph&#x1EA9;m" Grid.Row="1" Grid.Column="4" Style="{StaticResource FormLabel}"/>
                    <TextBox Grid.Row="1" Grid.Column="5" Grid.ColumnSpan="3" HorizontalAlignment="Stretch" Text="{Binding SelectedCutOrder.ProductName, Mode=OneWay}" IsReadOnly="True" Style="{StaticResource FormBox}" Background="#F8F9F9"/>

                    <!-- Row 2: SL đặt (tấn), SL đặt (bao), TL vỏ (kg), TL bao (kg) -->
                    <TextBlock Text="SL &#x111;&#x1EB7;t (t&#x1EA5;n)" Grid.Row="2" Grid.Column="0" Style="{StaticResource FormLabel}"/>
                    <TextBox Grid.Row="2" Grid.Column="1" HorizontalAlignment="Left" Width="80" Text="{Binding SelectedCutOrder.PlannedWeight, Mode=OneWay, Converter={StaticResource WeightToTonConverter}, StringFormat='{}{0:#,##0.###}'}" IsReadOnly="True" Style="{StaticResource FormBox}" Background="#F8F9F9"/>

                    <TextBlock Text="SL &#x111;&#x1EB7;t (bao)" Grid.Row="2" Grid.Column="2" Style="{StaticResource FormLabel}"/>
                    <TextBox Grid.Row="2" Grid.Column="3" HorizontalAlignment="Left" Width="80" Text="{Binding SelectedCutOrder.PlannedBagCountDisplay, Mode=OneWay, StringFormat='{}{0:N0}'}" IsReadOnly="True" Style="{StaticResource FormBox}" Background="#F8F9F9"/>

                    <TextBlock Text="TL v&#x1ECF; (kg)" Grid.Row="2" Grid.Column="4" Style="{StaticResource FormLabel}"/>
                    <TextBox Grid.Row="2" Grid.Column="5" HorizontalAlignment="Left" Width="80" Text="{Binding SelectedCutOrder.TareWeightKg, Mode=OneWay, StringFormat='{}{0:#,##0.###}'}" IsReadOnly="True" Style="{StaticResource FormBox}" Background="#F8F9F9"/>

                    <TextBlock Text="TL bao (kg)" Grid.Row="2" Grid.Column="6" Style="{StaticResource FormLabel}"/>
                    <TextBox Grid.Row="2" Grid.Column="7" HorizontalAlignment="Right" Width="80" Text="{Binding SelectedCutOrder.BagWeightKg, Mode=OneWay, StringFormat='{}{0:#,##0.###}'}" IsReadOnly="True" Style="{StaticResource FormBox}" Background="#F8F9F9"/>

                    <!-- Row 3: Lũy kế (tấn), Lũy kế (bao), Còn lại (tấn), Còn lại (bao) -->
                    <TextBlock Text="L&#x0169;y k&#x1EBF; (t&#x1EA5;n)" Grid.Row="3" Grid.Column="0" Style="{StaticResource FormLabel}"/>
                    <TextBox Grid.Row="3" Grid.Column="1" HorizontalAlignment="Left" Width="80" Text="{Binding SelectedCutOrder.AccumulatedWeight, Mode=OneWay, Converter={StaticResource WeightToTonConverter}, StringFormat='{}{0:#,##0.###}'}" IsReadOnly="True" Style="{StaticResource FormBox}" Background="#F8F9F9"/>

                    <TextBlock Text="L&#x0169;y k&#x1EBF; (bao)" Grid.Row="3" Grid.Column="2" Style="{StaticResource FormLabel}"/>
                    <TextBox Grid.Row="3" Grid.Column="3" HorizontalAlignment="Left" Width="80" Text="{Binding SelectedCutOrder.AccumulatedBagCountDisplay, Mode=OneWay, StringFormat='{}{0:N0}'}" IsReadOnly="True" Style="{StaticResource FormBox}" Background="#F8F9F9"/>

                    <TextBlock Text="C&#xF2;n l&#x1EA1;i (t&#x1EA5;n)" Grid.Row="3" Grid.Column="4" Style="{StaticResource FormLabel}"/>
                    <TextBox Grid.Row="3" Grid.Column="5" HorizontalAlignment="Left" Width="80" Text="{Binding SelectedCutOrder.RemainingWeight, Mode=OneWay, Converter={StaticResource WeightToTonConverter}, StringFormat='{}{0:#,##0.###}'}" IsReadOnly="True" Style="{StaticResource FormBox}" Background="#F8F9F9"/>

                    <TextBlock Text="C&#xF2;n l&#x1EA1;i (bao)" Grid.Row="3" Grid.Column="6" Style="{StaticResource FormLabel}"/>
                    <TextBox Grid.Row="3" Grid.Column="7" HorizontalAlignment="Right" Width="80" Text="{Binding SelectedCutOrder.RemainingBagCountDisplay, Mode=OneWay, StringFormat='{}{0:N0}'}" IsReadOnly="True" Style="{StaticResource FormBox}" Background="#F8F9F9"/>

                    <!-- Row 4: Ghi chú -->
                    <TextBlock Text="Ghi ch&#xFA;" Grid.Row="4" Grid.Column="0" Style="{StaticResource FormLabel}"/>
                    <TextBox Grid.Row="4" Grid.Column="1" Grid.ColumnSpan="7" HorizontalAlignment="Stretch" Text="{Binding SelectedCutOrder.Notes, Mode=OneWay}" IsReadOnly="True" Style="{StaticResource FormBox}" Background="#F8F9F9"/>

                </Grid>
            </Border>

            <Border Grid.Row="2" BorderBrush="#D0D3D4" BorderThickness="1" CornerRadius="4" Background="White" Padding="10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="90"/>
                        <ColumnDefinition Width="1*"/>
                        <ColumnDefinition Width="95"/>
                        <ColumnDefinition Width="1.2*"/>
                        <ColumnDefinition Width="80"/>
                        <ColumnDefinition Width="1*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="30"/>
                        <RowDefinition Height="30"/>
                        <RowDefinition Height="30"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="S&#x1ED1; PTVC" Grid.Row="0" Grid.Column="0" Style="{StaticResource FormLabel}"/>
                    <controls:AutocompleteTextBox Grid.Row="0" Grid.Column="1"
                                                   State="{Binding TripVehiclePlateInput}"
                                                   TextBoxStyle="{StaticResource FormBox}"
                                                   IsReadOnly="{Binding IsTripFormReadOnly}"/>

                    <TextBlock Text="Mooc" Grid.Row="0" Grid.Column="2" Style="{StaticResource FormLabel}"/>
                    <controls:AutocompleteTextBox Grid.Row="0" Grid.Column="3"
                                                   State="{Binding TripMoocInput}"
                                                   TextBoxStyle="{StaticResource FormBox}"
                                                   IsReadOnly="{Binding IsTripFormReadOnly}"/>

                    <TextBlock Text="T&#xE0;i x&#x1EBF;" Grid.Row="0" Grid.Column="4" Style="{StaticResource FormLabel}"/>
                    <controls:AutocompleteTextBox Grid.Row="0" Grid.Column="5"
                                                   State="{Binding TripDriverInput}"
                                                   TextBoxStyle="{StaticResource FormBox}"
                                                   IsReadOnly="{Binding IsTripFormReadOnly}"/>

                    <TextBlock Text="S&#x1ED1; &#x0110;K Xe" Grid.Row="1" Grid.Column="0" Style="{StaticResource FormLabel}"/>
                    <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding VehicleRegistrationNo, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" IsReadOnly="{Binding IsTripFormReadOnly}" Style="{StaticResource FormBox}"/>

                    <TextBlock Text="H&#x1EA1;n &#x0110;K Xe" Grid.Row="1" Grid.Column="2" Style="{StaticResource VehicleExpiryLabelStyle}"/>
                    <DatePicker Grid.Row="1" Grid.Column="3"
                                SelectedDate="{Binding VehicleRegistrationExpiryDate, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                IsEnabled="{Binding IsTripFormEditable}"
                                Style="{StaticResource VehicleExpiryDatePickerStyle}"/>

                    <TextBlock Text="TTCP (kg)" Grid.Row="1" Grid.Column="4" Style="{StaticResource FormLabel}"/>
                    <TextBox Grid.Row="1" Grid.Column="5" Text="{Binding VehicleTtcpWeight, Mode=TwoWay, StringFormat='{}{0:N0}', UpdateSourceTrigger=LostFocus}" IsReadOnly="{Binding IsTripFormReadOnly}" Style="{StaticResource FormBox}"/>

                    <TextBlock Text="S&#x1ED1; &#x0110;K Mooc" Grid.Row="2" Grid.Column="0" Style="{StaticResource FormLabel}"/>
                    <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding MoocRegistrationNo, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" IsReadOnly="{Binding IsTripFormReadOnly}" Style="{StaticResource FormBox}"/>

                    <TextBlock Text="H&#x1EA1;n &#x0110;K Mooc" Grid.Row="2" Grid.Column="2" Style="{StaticResource MoocExpiryLabelStyle}"/>
                    <DatePicker Grid.Row="2" Grid.Column="3"
                                SelectedDate="{Binding MoocRegistrationExpiryDate, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                IsEnabled="{Binding IsTripFormEditable}"
                                Style="{StaticResource MoocExpiryDatePickerStyle}"/>

                    <TextBlock Text="TTCP 10%" Grid.Row="2" Grid.Column="4" Style="{StaticResource FormLabel}"/>
                    <TextBox Grid.Row="2" Grid.Column="5" Text="{Binding VehicleTtcp10Weight, Mode=OneWay, StringFormat='{}{0:N0}'}" IsReadOnly="True" Style="{StaticResource FormBox}" Background="#F8F9F9"/>
                </Grid>
            </Border>
            </Grid>

            <Border Grid.Column="1" Margin="12,0,0,0" BorderBrush="#D0D3D4" BorderThickness="1" CornerRadius="4" Background="White" Padding="12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <DockPanel Margin="0,0,0,8">
                        <TextBlock Text="Camera" FontSize="13" FontWeight="SemiBold" Foreground="#2C3E50" VerticalAlignment="Center"/>
                        <ComboBox Style="{StaticResource StandardComboBoxStyle}"
                                  SelectedValue="{Binding SelectedPreviewCameraCode, Mode=TwoWay}"
                                  SelectedValuePath="Tag"
                                  Width="200"
                                  Height="28"
                                  HorizontalAlignment="Right"
                                  VerticalAlignment="Center"
                                  DockPanel.Dock="Right">
                            <ComboBoxItem Content="{Binding Camera1PreviewName}" Tag="CAM1" Visibility="{Binding ShowCamera1Selector, Converter={StaticResource BoolToVis}}"/>
                            <ComboBoxItem Content="{Binding Camera2PreviewName}" Tag="CAM2" Visibility="{Binding ShowCamera2Selector, Converter={StaticResource BoolToVis}}"/>
                        </ComboBox>
                    </DockPanel>

                    <Border Grid.Row="1"
                            BorderBrush="#D0D3D4"
                            BorderThickness="1"
                            CornerRadius="4"
                            Background="#F8F9F9">
                        <Grid>
                            <Image Source="{Binding CameraPreviewSource}" Margin="8" Stretch="Uniform"/>
                            <TextBlock Text="{Binding CameraPreviewStatusText}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Foreground="#5D6D7E"
                                       FontWeight="SemiBold"
                                       TextWrapping="Wrap"
                                       TextAlignment="Center"
                                       Visibility="{Binding ShowCameraPreviewPlaceholder, Converter={StaticResource BoolToVis}}"/>
                        </Grid>
                    </Border>
                </Grid>
            </Border>

            <Border Grid.Column="2" Margin="12,0,0,0" BorderBrush="#D0D3D4" BorderThickness="1" CornerRadius="4" Background="White" Padding="12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="64"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,8">
                        <RadioButton Content="{StaticResource Weighing.Mode.Auto}"
                                     IsChecked="{Binding CurrentCaptureMode, Converter={StaticResource StringEqToBool}, ConverterParameter='T&#x1EF0; &#x0110;&#x1ED8;NG'}"
                                     Margin="0,0,24,0"
                                     FontWeight="SemiBold"/>
                        <RadioButton Content="{StaticResource Weighing.Mode.Manual}"
                                     IsChecked="{Binding CurrentCaptureMode, Converter={StaticResource StringEqToBool}, ConverterParameter='C&#x00C2;N TAY'}"
                                     FontWeight="SemiBold"
                                     IsEnabled="{Binding CanUseManualMode}"
                                     Visibility="{Binding CanUseManualMode, Converter={StaticResource BoolToVis}}"/>
                    </StackPanel>

                    <Border Grid.Row="1" BorderThickness="1" CornerRadius="4" Background="#FDFDCC" BorderBrush="#F1C40F">
                        <Grid>
                            <TextBox Text="{Binding CurrentWeight, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, StringFormat='{}{0:0.###}'}"
                                     IsReadOnly="{Binding IsAutoMode}"
                                     FontSize="42"
                                     FontWeight="SemiBold"
                                     FontFamily="Consolas"
                                     HorizontalAlignment="Stretch"
                                     VerticalAlignment="Center"
                                     HorizontalContentAlignment="Center"
                                     VerticalContentAlignment="Center"
                                     BorderThickness="0"
                                     Background="Transparent"
                                     Foreground="Black"/>
                            <Border VerticalAlignment="Bottom" HorizontalAlignment="Right" Margin="8" Padding="8,2" CornerRadius="10" Background="{Binding StabilityBrush}">
                                <TextBlock Text="{Binding StabilityText}" Foreground="White" FontSize="10" FontWeight="SemiBold"/>
                            </Border>
                        </Grid>
                    </Border>

                    <Grid Margin="10,4,10,6" Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="115"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="32"/>
                            <RowDefinition Height="32"/>
                            <RowDefinition Height="32"/>
                        </Grid.RowDefinitions>

                        <TextBlock Text="{StaticResource Weighing.Weight1}" Grid.Row="0" Style="{StaticResource FormLabel}"/>
                        <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding Weight1, StringFormat='{}{0:N0}'}" IsReadOnly="True" Style="{StaticResource FormBox}" Background="#F8F9F9"/>

                        <TextBlock Text="{StaticResource Weighing.Weight2}" Grid.Row="1" Style="{StaticResource FormLabel}"/>
                        <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding Weight2, StringFormat='{}{0:N0}'}" IsReadOnly="True" Style="{StaticResource FormBox}" Background="#F8F9F9"/>

                        <TextBlock Text="{StaticResource Weighing.Label.NetWeight}" Grid.Row="2" Style="{StaticResource FormLabel}"/>
                        <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding NetWeight, StringFormat='{}{0:N0}'}" IsReadOnly="True" Style="{StaticResource FormBox}" Background="#F8F9F9"/>
                    </Grid>

                    <Grid Grid.Row="3" Margin="10,0,10,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Button Grid.Column="0"
                                Content="{StaticResource Weighing.Action.CaptureWeight1}"
                                Command="{Binding CaptureWeight1Command}"
                                Style="{StaticResource WorkflowButtonStyle}"
                                MinHeight="34"/>
                        <Button Grid.Column="2"
                                Content="{StaticResource Weighing.Action.CaptureWeight2}"
                                Command="{Binding CaptureWeight2Command}"
                                Style="{StaticResource PrimaryButtonStyle}"
                                MinHeight="34"/>
                        <Button Grid.Column="4"
                                Content="{StaticResource Weighing.Action.Save}"
                                Command="{Binding SaveCapturedWeightCommand}"
                                Style="{StaticResource PrimaryButtonStyle}"
                                MinHeight="34"/>
                    </Grid>
                </Grid>
            </Border>
        </Grid>

        <ItemsControl Grid.Row="2" HorizontalAlignment="Center" Margin="0,0,0,8">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <WrapPanel HorizontalAlignment="Center"/>
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <Button Content="T&#x1EA0;O C&#x1EAE;T L&#x1EC6;NH T&#x1EA0;M" Command="{Binding CreateTemporaryCutOrderCommand}" Style="{StaticResource PrimaryButtonStyle}" Margin="0,0,4,4"/>
            <Button Content="TẠO CHUYẾN XE" Command="{Binding CreateTripCommand}" Style="{StaticResource UtilityButtonStyle}" Margin="0,0,4,4"/>
            <Button Content="CHUYỂN CHUYẾN" Command="{Binding TransferTripCommand}" Style="{StaticResource UtilityButtonStyle}" Margin="0,0,4,4"/>
            <Button Content="X&#xD3;A CHUY&#x1EBE;N XE" Command="{Binding DeleteTripCommand}" Style="{StaticResource DangerButtonStyle}" Margin="0,0,4,4"/>
            <Button Content="IN PC" Command="{Binding PrintWeighTicketCommand}" Style="{StaticResource UtilityButtonStyle}" Margin="0,0,4,4"/>
            <Button Content="IN PGN" Command="{Binding PrintDeliveryTicketCommand}" Style="{StaticResource UtilityButtonStyle}" Margin="0,0,4,4"/>
            <Button Content="XEM &#x1EA2;NH" Command="{Binding ViewImageHistoryCommand}" Style="{StaticResource NeutralButtonStyle}" Margin="0,0,4,4"/>
            <Button Command="{Binding FinalizeCommand}" Style="{StaticResource NeutralButtonStyle}" Margin="0,0,4,4" Content="CHỐT TỔNG"/>
        </ItemsControl>

        <Grid Grid.Row="3" Margin="12,0,12,12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="16"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <DockPanel Grid.Row="0" Margin="0,0,0,6">
                <CheckBox Content="&#x110;&#x00E3; ho&#x00E0;n th&#x00E0;nh"
                          IsChecked="{Binding ShowCompletedCutOrders, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                          Style="{StaticResource StandardCheckBoxStyle}"
                          VerticalAlignment="Center"
                          DockPanel.Dock="Right"/>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="DANH S&#x00C1;CH C&#x1EAE;T L&#x1EC6;NH XU&#x1EA4;T KH&#x1EA8;U" FontSize="12.5" FontWeight="SemiBold" Foreground="#203B73" VerticalAlignment="Center"/>
                    <TextBlock Text="(Ch&#x1ECD;n m&#x1ED9;t d&#x00F2;ng c&#x1EAF;t l&#x1EC7;nh &#x111;&#x1EC3; hi&#x1EC3;n th&#x1ECB; danh s&#x00E1;ch chuy&#x1EBF;n xe t&#x01B0;&#x01A1;ng &#x1EE9;ng &#x1EDF; ph&#x00ED;a d&#x01B0;&#x1EDB;i)" FontSize="12" Foreground="#7F8C8D" FontStyle="Italic" VerticalAlignment="Center" Margin="10,0,0,0"/>
                </StackPanel>
            </DockPanel>

            <Border Grid.Row="1" Background="White" BorderBrush="#ECF0F1" BorderThickness="1" CornerRadius="4">
                <DataGrid ItemsSource="{Binding CutOrders}" SelectedItem="{Binding SelectedCutOrder}"
                          IsSynchronizedWithCurrentItem="False"
                          MaxHeight="185"
                          Style="{StaticResource SystemDataGridStyle}"
                          ColumnHeaderStyle="{StaticResource SystemDataGridColumnHeaderStyle}"
                          RowStyle="{StaticResource SystemDataGridRowStyle}"
                          CellStyle="{StaticResource SystemDataGridCellStyle}"
                          ScrollViewer.HorizontalScrollBarVisibility="Auto"
                          FrozenColumnCount="3">
                    <DataGrid.Columns>
                        <DataGridCheckBoxColumn Header="ERP" Binding="{Binding ErpExportCompleted, Mode=OneWay}" Width="70" ElementStyle="{StaticResource GridCheckBoxCenter}"/>
                        <DataGridTextColumn Header="M&#xC3; C&#x1EAE;T L&#x1EC6;NH" Binding="{Binding DisplayCutOrderCode, Mode=OneWay}" Width="150" ElementStyle="{StaticResource GridTextCenter}"/>
                        <DataGridTextColumn Header="S&#x1ED0; PTVC G&#x1ED0;C" Binding="{Binding VehiclePlate}" Width="130" ElementStyle="{StaticResource GridTextCenter}"/>
                        <DataGridTextColumn Header="MOOC" Binding="{Binding MoocNumber}" Width="120" ElementStyle="{StaticResource GridTextCenter}"/>
                        <DataGridTextColumn Header="KH&#xC1;CH H&#xC0;NG" Binding="{Binding CustomerName}" Width="240" ElementStyle="{StaticResource GridTextLeft}"/>
                        <DataGridTextColumn Header="M&#xC3; SP" Binding="{Binding ProductCode}" Width="120" ElementStyle="{StaticResource GridTextCenter}"/>
                        <DataGridTextColumn Header="S&#x1EA2;N PH&#x1EA8;M" Binding="{Binding ProductName}" Width="260" ElementStyle="{StaticResource GridTextLeft}"/>
                        <DataGridTextColumn Header="SL &#x111;&#x1EB7;t (KG)" Binding="{Binding PlannedWeight, StringFormat='{}{0:N0}'}" Width="120" ElementStyle="{StaticResource GridTextRight}"/>
                        <DataGridTextColumn Header="SL &#x111;&#x1EB7;t (BAO)" Binding="{Binding PlannedBagCountDisplay, StringFormat='{}{0:N0}'}" Width="120" ElementStyle="{StaticResource GridTextRight}"/>
                        <DataGridTextColumn Header="L&#x0168;Y K&#x1EBE; (KG)" Binding="{Binding AccumulatedWeight, StringFormat='{}{0:N0}'}" Width="120" ElementStyle="{StaticResource GridTextRight}"/>
                        <DataGridTextColumn Header="L&#x0168;Y K&#x1EBE; (BAO)" Binding="{Binding AccumulatedBagCountDisplay, StringFormat='{}{0:N0}'}" Width="120" ElementStyle="{StaticResource GridTextRight}"/>
                        <DataGridTextColumn Header="C&#xD2;N L&#x1EA0;I (KG)" Binding="{Binding RemainingWeight, StringFormat='{}{0:N0}'}" Width="120" ElementStyle="{StaticResource GridTextRight}"/>
                        <DataGridTextColumn Header="C&#xD2;N L&#x1EA0;I (BAO)" Binding="{Binding RemainingBagCountDisplay, StringFormat='{}{0:N0}'}" Width="120" ElementStyle="{StaticResource GridTextRight}"/>
                        <DataGridTextColumn Header="TL V&#x1ECE; (KG)" Binding="{Binding TareWeightKg, StringFormat='{}{0:#,##0.###}'}" Width="110" ElementStyle="{StaticResource GridTextRight}"/>
                        <DataGridTextColumn Header="TL BAO (KG)" Binding="{Binding BagWeightKg, StringFormat='{}{0:#,##0.###}'}" Width="110" ElementStyle="{StaticResource GridTextRight}"/>
                        <DataGridTextColumn Header="S&#x1ED0; CHUY&#x1EBE;N" Binding="{Binding TripCount}" Width="100" ElementStyle="{StaticResource GridTextCenter}"/>
                        <DataGridTextColumn Header="CHUY&#x1EBE;N CU&#x1ED0;I" Binding="{Binding LastTripAt, StringFormat='dd/MM/yyyy HH:mm'}" Width="150" ElementStyle="{StaticResource GridTextCenter}"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>

            <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,0,0,6">
                <TextBlock FontSize="12.5" FontWeight="SemiBold" Foreground="#34495E" VerticalAlignment="Center">
                    <Run Text="DANH S&#x00C1;CH CHUY&#x1EBE;N XE"/>
                    <Run Text=" - T&#x1ED5;ng chuy&#x1EBF;n &#x111;&#xE3; l&#x1EA5;y: "/>
                    <Run Text="{Binding SelectedCutOrder.TripCount, FallbackValue='0', TargetNullValue='0'}" Foreground="#2980B9"/>
                    <Run Text=" - T&#x1ED5;ng chuy&#x1EBF;n &#x111;&#xE3; ho&#xE0;n: "/>
                    <Run Text="{Binding CompletedTripCount, Mode=OneWay, FallbackValue='0', TargetNullValue='0'}" Foreground="#16A085"/>
                    <Run Text=" (C&#x1EAF;t l&#x1EC7;nh: "/>
                    <Run Text="{Binding SelectedCutOrder.DisplayCutOrderCode, Mode=OneWay, FallbackValue='Ch&#x1B0;a ch&#x1ECD;n', TargetNullValue='Ch&#x1B0;a ch&#x1ECD;n'}" Foreground="#2980B9"/>
                    <Run Text=")"/>
                </TextBlock>
            </StackPanel>

            <Border Grid.Row="4" Background="#F8FAFC" BorderBrush="#CBD5E1" BorderThickness="1" CornerRadius="4">
                <DataGrid x:Name="TripsDataGrid"
                          ItemsSource="{Binding Trips}"
                          PreviewMouseLeftButtonDown="OnTripsGridPreviewMouseLeftButtonDown"
                          SelectionChanged="OnTripsGridSelectionChanged"
                          SelectionMode="Single"
                          SelectionUnit="FullRow"
                          IsEnabled="{Binding IsTripsGridEnabled}"
                          IsSynchronizedWithCurrentItem="False"
                          Style="{StaticResource DetailDataGridStyle}"
                          ColumnHeaderStyle="{StaticResource DetailDataGridColumnHeaderStyle}"
                          CellStyle="{StaticResource DetailDataGridCellStyle}"
                          ScrollViewer.HorizontalScrollBarVisibility="Auto"
                          FrozenColumnCount="3">
                    <DataGrid.RowStyle>
                        <Style TargetType="DataGridRow" BasedOn="{StaticResource DetailDataGridRowStyle}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsReturnedBrokenTrip}" Value="True">
                                    <Setter Property="Foreground" Value="#C0392B"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.RowStyle>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="S&#x1ED1; L&#x1AF;&#x1EE2;T C&#xC2;N" Binding="{Binding SessionNo}" Width="110" ElementStyle="{StaticResource GridTextCenter}"/>
                        <DataGridTextColumn Header="S&#x1ED1; PTVC" Binding="{Binding VehiclePlate}" Width="100" ElementStyle="{StaticResource GridTextCenter}"/>
                        <DataGridTextColumn Header="MOOC" Binding="{Binding MoocNumber}" Width="100" ElementStyle="{StaticResource GridTextCenter}"/>
                        <DataGridTextColumn Header="T&#xC0;I X&#x1EBE;" Binding="{Binding DriverName}" Width="140" ElementStyle="{StaticResource GridTextLeft}"/>
                        <DataGridTextColumn Header="C&#xC2;N L&#x1EA6;N 1" Binding="{Binding Weight1, StringFormat='{}{0:N0}'}" Width="90" ElementStyle="{StaticResource GridTextRight}"/>
                        <DataGridTextColumn Header="C&#xC2;N L&#x1EA6;N 2" Binding="{Binding Weight2, StringFormat='{}{0:N0}'}" Width="90" ElementStyle="{StaticResource GridTextRight}"/>
                        <DataGridTextColumn Header="NET" Binding="{Binding NetWeight, StringFormat='{}{0:N0}'}" Width="90" ElementStyle="{StaticResource GridTextRight}"/>
                        <DataGridTextColumn Header="BAO" Binding="{Binding BagCountDisplay, StringFormat='{}{0:N0}'}" Width="70" ElementStyle="{StaticResource GridTextCenter}"/>
                        <DataGridTextColumn Header="TR&#x1EA0;NG TH&#xC1;I" Binding="{Binding SessionStatus, Converter={StaticResource SessionStatusDisplayConverter}}" Width="130" ElementStyle="{StaticResource GridTextCenter}"/>
                        <DataGridTextColumn Header="PC" Binding="{Binding WeighTicketNo}" Width="100" ElementStyle="{StaticResource GridTextCenter}"/>
                        <DataGridTextColumn Header="PGN" Binding="{Binding DeliveryNo}" Width="105" ElementStyle="{StaticResource GridTextCenter}"/>
                        <DataGridTemplateColumn Header="HOÀN" Width="75">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <CheckBox HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Focusable="False"
                                              IsEnabled="{Binding CanToggleReturnedBrokenTrip}"
                                              IsChecked="{Binding IsReturnedBrokenTrip, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                              Command="{Binding DataContext.ToggleReturnedBrokenTripCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                              CommandParameter="{Binding}"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
