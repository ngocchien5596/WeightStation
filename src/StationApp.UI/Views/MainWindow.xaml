<Window x:Class="StationApp.UI.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{StaticResource MainWindow.Title}"
        Icon="/Assets/logo.jpg"
        Height="768"
        Width="1366"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource BackgroundBrush}">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="{Binding SidebarWidth}"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Style="{StaticResource SidebarContainerStyle}" CornerRadius="0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="64"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="{StaticResource SidebarTopBackground}" Padding="12,0">
                    <Grid>
                        <TextBlock Text="{Binding AppVersionText}"
                                   HorizontalAlignment="Left"
                                   VerticalAlignment="Center"
                                   Foreground="#D7E0F0"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   Margin="12,0,0,0"/>
                        <Button Command="{Binding ToggleSidebarCommand}"
                                Width="28"
                                Height="28"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center"
                                Background="Transparent"
                                BorderThickness="0"
                                Cursor="Hand"
                                ToolTip="Thu gọn / Mở rộng menu">
                            <TextBlock Text="&#xE700;"
                                       FontFamily="Segoe MDL2 Assets"
                                       FontSize="18"
                                       Foreground="#D7E0F0"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Button>
                    </Grid>
                </Border>

                <Border Grid.Row="1"
                        Background="{StaticResource SidebarBackground}"
                        Visibility="{Binding IsSidebarCollapsed, Converter={StaticResource InverseBoolToVis}}">
                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled"
                                  PanningMode="VerticalOnly"
                                  Background="Transparent"
                                  BorderThickness="0">
                        <StackPanel Background="{StaticResource SidebarItemBackground}">
                            <Button Style="{StaticResource SidebarMenuItemStyle}"
                                    Visibility="{Binding CanViewDashboard, Converter={StaticResource BoolToVis}}"
                                    Command="{Binding NavigateCommand}"
                                    CommandParameter="Dashboard">
                                <TextBlock Text="{StaticResource MainWindow.Nav.Dashboard}" VerticalAlignment="Center"/>
                            </Button>
                            <Button Style="{StaticResource SidebarMenuItemStyle}"
                                    Visibility="{Binding CanViewIncomingVehicles, Converter={StaticResource BoolToVis}}"
                                    Command="{Binding NavigateCommand}"
                                    CommandParameter="IncomingVehicles">
                                <TextBlock Text="{StaticResource MainWindow.Nav.Incoming}" VerticalAlignment="Center"/>
                            </Button>
                            <Button Style="{StaticResource SidebarMenuItemStyle}"
                                    Visibility="{Binding CanViewWeighing, Converter={StaticResource BoolToVis}}"
                                    Command="{Binding NavigateCommand}"
                                    CommandParameter="Weighing">
                                <TextBlock Text="{StaticResource MainWindow.Nav.Weighing}" VerticalAlignment="Center"/>
                            </Button>
                            <Button Style="{StaticResource SidebarMenuItemStyle}"
                                    Visibility="{Binding CanViewCrusherWeighing, Converter={StaticResource BoolToVis}}"
                                    Command="{Binding NavigateCommand}"
                                    CommandParameter="CrusherWeighing">
                                <TextBlock Text="C&#xE2;n tr&#x1EA1;m &#x111;&#x1EAD;p" VerticalAlignment="Center"/>
                            </Button>
                            <Button Style="{StaticResource SidebarMenuItemStyle}"
                                    Visibility="{Binding CanViewExportWeighing, Converter={StaticResource BoolToVis}}"
                                    Command="{Binding NavigateCommand}"
                                    CommandParameter="ExportWeighing">
                                <TextBlock Text="C&#xE2;n xu&#x1EA5;t kh&#x1EA9;u" VerticalAlignment="Center"/>
                            </Button>
                            <Button Style="{StaticResource SidebarMenuItemStyle}"
                                    Visibility="{Binding CanViewOutgoingVehicles, Converter={StaticResource BoolToVis}}"
                                    Command="{Binding NavigateCommand}"
                                    CommandParameter="OutgoingVehicles">
                                <TextBlock Text="{StaticResource MainWindow.Nav.Outgoing}" VerticalAlignment="Center"/>
                            </Button>
                            <Button Style="{StaticResource SidebarExpandableItemStyle}"
                                    Visibility="{Binding CanViewReportsMenu, Converter={StaticResource BoolToVis}}"
                                    Command="{Binding ToggleReportsSubmenuCommand}">
                                <DockPanel LastChildFill="False">
                                    <TextBlock Text="Báo cáo" VerticalAlignment="Center"/>
                                    <TextBlock DockPanel.Dock="Right"
                                               Margin="10,0,0,0"
                                               Text="&#xE70D;"
                                               FontFamily="Segoe MDL2 Assets"
                                               FontSize="11"
                                               Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                               VerticalAlignment="Center"/>
                                </DockPanel>
                            </Button>

                            <StackPanel Visibility="{Binding IsReportsSubmenuVisible, Converter={StaticResource BoolToVis}}">
                                <Button Style="{StaticResource SidebarMenuItemStyle}" Padding="30,0,12,0"
                                        Visibility="{Binding CanViewExportSummaryReport, Converter={StaticResource BoolToVis}}"
                                        Command="{Binding NavigateCommand}" CommandParameter="Reports_ExportSummary">
                                    <TextBlock Text="Báo cáo xuất" VerticalAlignment="Center"/>
                                </Button>
                                <Button Style="{StaticResource SidebarMenuItemStyle}" Padding="30,0,12,0"
                                        Visibility="{Binding CanViewInboundSummaryReport, Converter={StaticResource BoolToVis}}"
                                        Command="{Binding NavigateCommand}" CommandParameter="Reports_InboundSummary">
                                    <TextBlock Text="Báo cáo nhập" VerticalAlignment="Center"/>
                                </Button>
                            </StackPanel>
                            <Button Style="{StaticResource SidebarMenuItemStyle}"
                                    Visibility="{Binding CanViewTicketList, Converter={StaticResource BoolToVis}}"
                                    Command="{Binding NavigateCommand}"
                                    CommandParameter="TicketList">
                                <TextBlock Text="{StaticResource MainWindow.Nav.Tickets}" VerticalAlignment="Center"/>
                            </Button>
                            <Button Style="{StaticResource SidebarMenuItemStyle}"
                                    Visibility="{Binding CanViewDiagnostics, Converter={StaticResource BoolToVis}}"
                                    Command="{Binding NavigateCommand}"
                                    CommandParameter="Diagnostics">
                                <TextBlock Text="{StaticResource MainWindow.Nav.Diagnostics}" VerticalAlignment="Center"/>
                            </Button>

                            <Button Style="{StaticResource SidebarExpandableItemStyle}"
                                    Visibility="{Binding CanViewSettingsMenu, Converter={StaticResource BoolToVis}}"
                                    Command="{Binding ToggleSettingsSubmenuCommand}">
                                <DockPanel LastChildFill="False">
                                    <TextBlock Text="{StaticResource MainWindow.Nav.Settings}" VerticalAlignment="Center"/>
                                    <TextBlock DockPanel.Dock="Right"
                                               Margin="10,0,0,0"
                                               Text="&#xE70D;"
                                               FontFamily="Segoe MDL2 Assets"
                                               FontSize="11"
                                               Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                               VerticalAlignment="Center"/>
                                </DockPanel>
                            </Button>

                            <StackPanel Visibility="{Binding IsSettingsSubmenuVisible, Converter={StaticResource BoolToVis}}">
                                <Button Style="{StaticResource SidebarMenuItemStyle}" Padding="30,0,12,0"
                                        Visibility="{Binding CanViewAppUpdate, Converter={StaticResource BoolToVis}}"
                                        Command="{Binding NavigateCommand}" CommandParameter="AppUpdate">
                                    <TextBlock Text="C&#x1EAD;p nh&#x1EAD;t &#x1EE9;ng d&#x1EE5;ng" VerticalAlignment="Center"/>
                                </Button>
                                <Button Style="{StaticResource SidebarMenuItemStyle}" Padding="30,0,12,0"
                                        Visibility="{Binding CanViewSettingsParams, Converter={StaticResource BoolToVis}}"
                                        Command="{Binding NavigateCommand}" CommandParameter="Settings_Params">
                                    <TextBlock Text="{StaticResource MainWindow.Nav.SettingsParams}" VerticalAlignment="Center"/>
                                </Button>
                                <Button Style="{StaticResource SidebarMenuItemStyle}" Padding="30,0,12,0"
                                        Visibility="{Binding CanViewSettingsParams, Converter={StaticResource BoolToVis}}"
                                        Command="{Binding NavigateCommand}" CommandParameter="Settings_Camera">
                                    <TextBlock Text="{StaticResource MainWindow.Nav.SettingsCamera}" VerticalAlignment="Center"/>
                                </Button>
                                <Button Style="{StaticResource SidebarMenuItemStyle}" Padding="30,0,12,0"
                                        Visibility="{Binding CanViewSettingsDevice, Converter={StaticResource BoolToVis}}"
                                        Command="{Binding NavigateCommand}" CommandParameter="Settings_Device">
                                    <TextBlock Text="{StaticResource MainWindow.Nav.SettingsDevice}" VerticalAlignment="Center"/>
                                </Button>
                                <Button Style="{StaticResource SidebarMenuItemStyle}" Padding="30,0,12,0"
                                        Visibility="{Binding CanViewSettingsPrint, Converter={StaticResource BoolToVis}}"
                                        Command="{Binding NavigateCommand}" CommandParameter="Settings_Print">
                                    <TextBlock Text="{StaticResource MainWindow.Nav.SettingsPrint}" VerticalAlignment="Center"/>
                                </Button>
                                <Button Style="{StaticResource SidebarMenuItemStyle}" Padding="30,0,12,0"
                                        Visibility="{Binding CanViewSettingsVehicles, Converter={StaticResource BoolToVis}}"
                                        Command="{Binding NavigateCommand}" CommandParameter="Settings_Vehicles">
                                    <TextBlock Text="{StaticResource MainWindow.Nav.SettingsVehicles}" VerticalAlignment="Center"/>
                                </Button>
                                <Button Style="{StaticResource SidebarMenuItemStyle}" Padding="30,0,12,0"
                                        Visibility="{Binding CanViewSettingsCustomers, Converter={StaticResource BoolToVis}}"
                                        Command="{Binding NavigateCommand}" CommandParameter="Settings_Customers">
                                    <TextBlock Text="{StaticResource MainWindow.Nav.SettingsCustomers}" VerticalAlignment="Center"/>
                                </Button>
                                <Button Style="{StaticResource SidebarMenuItemStyle}" Padding="30,0,12,0"
                                        Visibility="{Binding CanViewSettingsProducts, Converter={StaticResource BoolToVis}}"
                                        Command="{Binding NavigateCommand}" CommandParameter="Settings_Products">
                                    <TextBlock Text="{StaticResource MainWindow.Nav.SettingsProducts}" VerticalAlignment="Center"/>
                                </Button>
                                <Button Style="{StaticResource SidebarMenuItemStyle}" Padding="30,0,12,0"
                                        Visibility="{Binding CanViewSettingsSync, Converter={StaticResource BoolToVis}}"
                                        Command="{Binding NavigateCommand}" CommandParameter="Settings_Sync">
                                    <TextBlock Text="{StaticResource MainWindow.Nav.SettingsSync}" VerticalAlignment="Center"/>
                                </Button>
                                <Button Style="{StaticResource SidebarMenuItemStyle}" Padding="30,0,12,0"
                                        Visibility="{Binding CanViewSettingsExternalDatacan, Converter={StaticResource BoolToVis}}"
                                        Command="{Binding NavigateCommand}" CommandParameter="Settings_ExternalDatacan">
                                    <TextBlock Text="{StaticResource MainWindow.Nav.SettingsExternalDatacan}" VerticalAlignment="Center"/>
                                </Button>
                                <Button Style="{StaticResource SidebarMenuItemStyle}" Padding="30,0,12,0"
                                        Visibility="{Binding CanViewSettingsStations, Converter={StaticResource BoolToVis}}"
                                        Command="{Binding NavigateCommand}" CommandParameter="Settings_Stations">
                                    <TextBlock Text="{StaticResource MainWindow.Nav.SettingsStations}" VerticalAlignment="Center"/>
                                </Button>
                                <Button Style="{StaticResource SidebarMenuItemStyle}" Padding="30,0,12,0"
                                        Visibility="{Binding CanViewSettingsAccounts, Converter={StaticResource BoolToVis}}"
                                        Command="{Binding NavigateCommand}" CommandParameter="Settings_Accounts">
                                    <TextBlock Text="{StaticResource MainWindow.Nav.SettingsAccounts}" VerticalAlignment="Center"/>
                                </Button>
                            </StackPanel>
                        </StackPanel>
                    </ScrollViewer>
                </Border>

                <Border Grid.Row="2"
                        Background="{StaticResource SidebarBackground}"
                        Visibility="{Binding IsSidebarCollapsed, Converter={StaticResource InverseBoolToVis}}">
                    <StackPanel Background="{StaticResource SidebarFooterBackground}">
                        <Border Background="{StaticResource SidebarItemBackground}" Padding="20,12,12,12">
                            <StackPanel>
                                <TextBlock Text="{Binding CurrentUserDisplayName}" FontWeight="SemiBold" Foreground="{StaticResource SidebarItemForeground}"/>
                                <TextBlock Text="{Binding CurrentUserRoleCode}" FontSize="11" Foreground="#9FB0C3" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Border>
                        <Button Style="{StaticResource SidebarMenuItemStyle}" Command="{Binding LogoutCommand}">
                            <TextBlock Text="{StaticResource MainWindow.Nav.Logout}" VerticalAlignment="Center"/>
                        </Button>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <Grid Grid.Column="1" Background="{StaticResource MainContentBackground}">
            <ContentControl Content="{Binding CurrentView}" Margin="0"/>

            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        Margin="0,13,260,0"
                        Panel.ZIndex="99">
                <TextBlock Text="Tr&#x1EA1;m:"
                           Style="{StaticResource HeaderLabel}"
                           VerticalAlignment="Center"
                           Margin="0,0,8,0"/>
                <ComboBox Width="150"
                          Height="38"
                          Style="{StaticResource HeaderComboBoxStyle}"
                          FontSize="13.5"
                          FontWeight="Normal"
                          ItemsSource="{Binding AllowedStations}"
                          SelectedItem="{Binding SelectedStation, Mode=TwoWay}"
                          ToolTip="{Binding CurrentStationDisplay}">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding StationName}"
                                       FontSize="13.5"
                                       FontWeight="Normal"
                                       TextTrimming="CharacterEllipsis"/>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
            </StackPanel>
            
            <!-- Global Clock Capsule Badge -->
            <Border Style="{StaticResource ClockBadgeStyle}" 
                    HorizontalAlignment="Right" 
                    VerticalAlignment="Top" 
                    Margin="0,13,20,0"
                    Panel.ZIndex="99">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock Text="&#xE916;" 
                               FontFamily="Segoe MDL2 Assets" 
                               Foreground="{StaticResource ClockIconForeground}" 
                               FontSize="19" 
                               VerticalAlignment="Center" 
                               Margin="0,0,8,0"/>
                    <TextBlock Text="{Binding CurrentTimeDisplay}" 
                               Style="{StaticResource ClockTextStyle}" 
                               VerticalAlignment="Center"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
