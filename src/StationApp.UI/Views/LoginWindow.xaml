<Window x:Class="StationApp.UI.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:helpers="clr-namespace:StationApp.UI.Helpers"
        Title="Đăng nhập - Hệ thống quản lý trạm cân"
        Width="960"
        Height="580"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        WindowStyle="None"
        Background="Transparent"
        AllowsTransparency="True"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">

    <Window.Resources>
        <!-- Login TextBox Style with icon placeholder -->
        <Style x:Key="LoginTextBoxStyle" TargetType="TextBox">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#0F172A"/>
            <Setter Property="Background" Value="#F8FAFC"/>
            <Setter Property="BorderBrush" Value="#CBD5E1"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Height" Value="44"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8"
                                SnapsToDevicePixels="True">
                            <ScrollViewer x:Name="PART_ContentHost" Focusable="False"
                                          Margin="{TemplateBinding Padding}"
                                          HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Hidden"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="#94A3B8"/>
                            </Trigger>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="#2E86C1"/>
                                <Setter TargetName="border" Property="BorderThickness" Value="1.5"/>
                                <Setter TargetName="border" Property="Background" Value="#FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Background" Value="#E2E8F0"/>
                                <Setter Property="Foreground" Value="#94A3B8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Login PasswordBox Style -->
        <Style x:Key="LoginPasswordBoxStyle" TargetType="PasswordBox">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#0F172A"/>
            <Setter Property="Background" Value="#F8FAFC"/>
            <Setter Property="BorderBrush" Value="#CBD5E1"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Height" Value="44"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="PasswordBox">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8"
                                SnapsToDevicePixels="True">
                            <ScrollViewer x:Name="PART_ContentHost" Focusable="False"
                                          Margin="{TemplateBinding Padding}"
                                          HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Hidden"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="#94A3B8"/>
                            </Trigger>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="#2E86C1"/>
                                <Setter TargetName="border" Property="BorderThickness" Value="1.5"/>
                                <Setter TargetName="border" Property="Background" Value="#FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Background" Value="#E2E8F0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Login Button Style -->
        <Style x:Key="LoginButtonStyle" TargetType="Button">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#1B2631"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Height" Value="46"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                    <Condition Property="IsEnabled" Value="True"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="border" Property="Background" Value="#263545"/>
                            </MultiTrigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsPressed" Value="True"/>
                                    <Condition Property="IsEnabled" Value="True"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="border" Property="Background" Value="#0F1A24"/>
                            </MultiTrigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Background" Value="#94A3B8"/>
                                <Setter Property="Foreground" Value="#CBD5E1"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Close Button Style -->
        <Style x:Key="LoginCloseButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="32"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="#64748B"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#F1F5F9"/>
                                <Setter Property="Foreground" Value="#1E293B"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <!-- Show Password Toggle Button Style -->
        <Style x:Key="ShowPasswordToggleStyle" TargetType="ToggleButton">
            <Setter Property="Width" Value="32"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="#94A3B8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border Background="{TemplateBinding Background}">
                            <TextBlock x:Name="icon" 
                                       Text="&#xE7B3;" 
                                       FontFamily="Segoe MDL2 Assets" 
                                       FontSize="16"
                                       HorizontalAlignment="Center" 
                                       VerticalAlignment="Center"
                                       Foreground="{TemplateBinding Foreground}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="icon" Property="Text" Value="&#xE052;"/>
                                <Setter Property="Foreground" Value="#2E86C1"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="#64748B"/>
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                    <Condition Property="IsChecked" Value="True"/>
                                </MultiTrigger.Conditions>
                                <Setter Property="Foreground" Value="#21618C"/>
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>


    <!-- Outer shadow container -->
    <Border Margin="16">
        <Border.Effect>
            <DropShadowEffect BlurRadius="32" ShadowDepth="4" Direction="270" Opacity="0.18" Color="#1B2631"/>
        </Border.Effect>

        <!-- Main card with clipped corners -->
        <Border CornerRadius="12" ClipToBounds="True">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="380"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- LEFT PANEL: Dark navy branding -->
                <Border Grid.Column="0">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="0.3,1">
                            <GradientStop Color="#1B2631" Offset="0"/>
                            <GradientStop Color="#1E3044" Offset="0.5"/>
                            <GradientStop Color="#203B52" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>

                    <Grid Margin="40,36,40,40">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Logo + Company Name (inline) -->
                        <Grid Grid.Row="0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0" Width="64" Height="64" CornerRadius="14" Background="#FFFFFF" 
                                    HorizontalAlignment="Left" Padding="5" VerticalAlignment="Center">
                                <Image Source="/Assets/logo.jpg" Stretch="Uniform" RenderOptions.BitmapScalingMode="HighQuality"/>
                            </Border>

                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="14,0,0,0">
                                <TextBlock Text="CÔNG TY CỔ PHẦN" FontSize="11" FontWeight="Medium" Foreground="#7B95AD" 
                                           FontFamily="Segoe UI"/>
                                <TextBlock Text="XI MĂNG CẨM PHẢ" FontSize="18" FontWeight="Bold" Foreground="#FFFFFF" 
                                           Margin="0,2,0,0" FontFamily="Segoe UI"/>
                            </StackPanel>
                        </Grid>

                        <!-- Decorative line -->
                        <Border Grid.Row="1" Height="2" Background="#C5A059" HorizontalAlignment="Left" 
                                Width="48" Margin="0,24,0,0" CornerRadius="1"/>

                        <!-- System title - prominent -->
                        <StackPanel Grid.Row="2" VerticalAlignment="Top" Margin="0,24,0,0">
                            <TextBlock FontSize="28" FontWeight="Bold" Foreground="#FFFFFF" 
                                       FontFamily="Segoe UI" TextWrapping="Wrap" LineHeight="36">
                                <Run Text="Hệ thống"/>
                                <LineBreak/>
                                <Run Text="quản lý trạm cân"/>
                            </TextBlock>
                        </StackPanel>

                        <!-- Footer on left panel -->
                        <StackPanel Grid.Row="3">
                            <TextBlock Text="Copyright © 2026 by CNTT" FontSize="12" Foreground="#94B3CF"
                                       FontFamily="Segoe UI"/>
                            <TextBlock Text="{Binding VersionText}" FontSize="12" Foreground="#94B3CF" 
                                       Margin="0,4,0,0" FontFamily="Segoe UI"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- RIGHT PANEL: Login form -->
                <Border Grid.Column="1" Background="#FFFFFF">
                    <Grid>
                        <!-- Close button -->
                        <Button Style="{StaticResource LoginCloseButtonStyle}"
                                HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,16,16,0"
                                Click="CloseButton_Click" Content="✕"/>

                        <!-- Form content -->
                        <StackPanel VerticalAlignment="Center" Margin="52,0">
                            
                            <!-- Heading -->
                            <TextBlock Text="Đăng nhập" FontSize="24" FontWeight="Bold" Foreground="#1E293B"
                                       FontFamily="Segoe UI"/>
                            <!-- Error Message -->
                            <Border Margin="0,24,0,0" Padding="14,12" CornerRadius="8" 
                                    Background="#FEF2F2" BorderBrush="#FECACA" BorderThickness="1"
                                    Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVis}}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xEA39;" FontFamily="Segoe MDL2 Assets" FontSize="14" 
                                               Foreground="#DC2626" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                    <TextBlock Text="{Binding ErrorMessage}" Foreground="#DC2626" FontSize="13" 
                                               TextWrapping="Wrap" VerticalAlignment="Center" FontFamily="Segoe UI"/>
                                </StackPanel>
                            </Border>

                            <!-- Username field -->
                            <StackPanel Margin="0,28,0,0">
                                <TextBlock Text="Tên đăng nhập" FontSize="13" FontWeight="SemiBold" 
                                           Foreground="#334155" FontFamily="Segoe UI" Margin="0,0,0,8"/>
                                <Grid>
                                    <TextBox x:Name="UsernameTextBox"
                                             Style="{StaticResource LoginTextBoxStyle}"
                                             Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                                             IsEnabled="{Binding IsInputEnabled}"/>
                                    <TextBlock Text="&#xE77B;" FontFamily="Segoe MDL2 Assets" FontSize="16"
                                               Foreground="#94A3B8" VerticalAlignment="Center" 
                                               HorizontalAlignment="Right" Margin="0,0,14,0"
                                               IsHitTestVisible="False"/>
                                </Grid>
                            </StackPanel>

                            <!-- Password field -->
                            <StackPanel Margin="0,20,0,0">
                                <TextBlock Text="Mật khẩu" FontSize="13" FontWeight="SemiBold" 
                                           Foreground="#334155" FontFamily="Segoe UI" Margin="0,0,0,8"/>
                                <Grid>
                                    <!-- Visible Password -->
                                    <TextBox Style="{StaticResource LoginTextBoxStyle}"
                                             Text="{Binding Password, UpdateSourceTrigger=PropertyChanged}"
                                             IsEnabled="{Binding IsInputEnabled}"
                                             Visibility="{Binding IsPasswordVisible, Converter={StaticResource BoolToVis}}"/>
                                    
                                    <!-- Hidden Password -->
                                    <PasswordBox x:Name="PasswordBoxInput"
                                                 Style="{StaticResource LoginPasswordBoxStyle}"
                                                 IsEnabled="{Binding IsInputEnabled}"
                                                 helpers:PasswordBoxAssistant.BindPassword="True"
                                                 helpers:PasswordBoxAssistant.BoundPassword="{Binding Password, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                 Visibility="{Binding IsPasswordVisible, Converter={StaticResource InverseBoolToVis}}"/>

                                    <!-- Toggle Button -->
                                    <ToggleButton Style="{StaticResource ShowPasswordToggleStyle}"
                                                  IsChecked="{Binding IsPasswordVisible}"
                                                  HorizontalAlignment="Right" 
                                                  Margin="0,0,6,0"
                                                  VerticalAlignment="Center"/>
                                </Grid>
                            </StackPanel>

                            <!-- Login button -->
                            <Button Margin="0,32,0,0"
                                    Style="{StaticResource LoginButtonStyle}"
                                    Command="{Binding LoginCommand}"
                                    IsDefault="True">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding LoginButtonText}" VerticalAlignment="Center" FontFamily="Segoe UI"/>
                                    <TextBlock Text="&#xE72A;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                                               VerticalAlignment="Center" Margin="10,0,0,0"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </Border>
    </Border>
</Window>
