<UserControl x:Class="StationApp.UI.Views.IncomingVehicleListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:StationApp.UI.Controls"
             xmlns:enums="clr-namespace:StationApp.Domain.Enums;assembly=StationApp.Domain"
             Background="Transparent">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/StationApp.UI;component/Themes/AppTheme.xaml"/>
                <ResourceDictionary Source="/StationApp.UI;component/Styles/ButtonStyles.xaml"/>
                <ResourceDictionary Source="/StationApp.UI;component/Styles/InputStyles.xaml"/>
                <ResourceDictionary Source="/StationApp.UI;component/Styles/BasePageStyles.xaml"/>
                <ResourceDictionary Source="/StationApp.UI;component/Resources/MonitoringTextResources.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <Style x:Key="FormLabel" TargetType="TextBlock" BasedOn="{StaticResource FieldLabelStyle}">
                <Setter Property="Margin" Value="0,0,20,0"/>
                <Setter Property="HorizontalAlignment" Value="Right"/>
                <Setter Property="VerticalAlignment" Value="Center"/>
            </Style>
            <Style x:Key="FormBox" TargetType="TextBox" BasedOn="{StaticResource StandardTextBoxStyle}"/>
            <Style x:Key="FormDatePicker" TargetType="DatePicker" BasedOn="{StaticResource StandardDatePickerStyle}"/>
            <Style x:Key="VehicleExpiryLabelStyle" TargetType="TextBlock" BasedOn="{StaticResource FormLabel}">
                <Style.Triggers>
                    <DataTrigger Binding="{Binding IsVehicleRegistrationExpired}" Value="True">
                        <Setter Property="Foreground" Value="#C0392B"/>
                        <Setter Property="FontWeight" Value="SemiBold"/>
                    </DataTrigger>
                </Style.Triggers>
            </Style>
            <Style x:Key="MoocExpiryLabelStyle" TargetType="TextBlock" BasedOn="{StaticResource FormLabel}">
                <Style.Triggers>
                    <DataTrigger Binding="{Binding IsMoocRegistrationExpired}" Value="True">
                        <Setter Property="Foreground" Value="#C0392B"/>
                        <Setter Property="FontWeight" Value="SemiBold"/>
                    </DataTrigger>
                </Style.Triggers>
            </Style>
            <Style x:Key="VehicleExpiryDatePickerStyle" TargetType="DatePicker" BasedOn="{StaticResource FormDatePicker}">
                <Style.Triggers>
                    <DataTrigger Binding="{Binding IsVehicleRegistrationExpired}" Value="True">
                        <Setter Property="Foreground" Value="#C0392B"/>
                        <Setter Property="FontWeight" Value="SemiBold"/>
                    </DataTrigger>
                </Style.Triggers>
            </Style>
            <Style x:Key="MoocExpiryDatePickerStyle" TargetType="DatePicker" BasedOn="{StaticResource FormDatePicker}">
                <Style.Triggers>
                    <DataTrigger Binding="{Binding IsMoocRegistrationExpired}" Value="True">
                        <Setter Property="Foreground" Value="#C0392B"/>
                        <Setter Property="FontWeight" Value="SemiBold"/>
                    </DataTrigger>
                </Style.Triggers>
            </Style>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid Background="#FFFFFF">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource HeaderBorder}">
            <DockPanel>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="{StaticResource Incoming.SearchRegistrationCodeLabel}" Style="{StaticResource HeaderLabel}" Margin="0,0,8,0"/>
                    <TextBox Width="168" Style="{StaticResource StandardTextBoxStyle}"
                             Text="{Binding SearchErpCutOrderId, UpdateSourceTrigger=PropertyChanged}">
                        <TextBox.InputBindings>
                            <KeyBinding Key="Enter" Command="{Binding RefreshCommand}"/>
                        </TextBox.InputBindings>
                    </TextBox>

                    <TextBlock Text="{StaticResource Incoming.SearchVehiclePlateLabel}" Style="{StaticResource HeaderLabel}" Margin="20,0,8,0"/>
                    <controls:AutocompleteTextBox Width="168"
                                                  State="{Binding SearchVehiclePlateInput}"
                                                  TextBoxStyle="{StaticResource StandardTextBoxStyle}">
                        <controls:AutocompleteTextBox.InputBindings>
                            <KeyBinding Key="Enter" Command="{Binding RefreshCommand}"/>
                        </controls:AutocompleteTextBox.InputBindings>
                    </controls:AutocompleteTextBox>

                    <Button Command="{Binding RefreshCommand}" Style="{StaticResource HeaderActionButton}" Margin="20,0,0,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE72C;" FontFamily="Segoe MDL2 Assets" FontSize="13" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBlock Text="{StaticResource Workflow.RefreshButton}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </DockPanel>
        </Border>

        <Border Grid.Row="1" Margin="12" BorderBrush="#D0D3D4" BorderThickness="1" CornerRadius="4" Padding="16" Background="White">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="32"/>
                        <RowDefinition Height="32"/>
                        <RowDefinition Height="32"/>
                        <RowDefinition Height="32"/>
                        <RowDefinition Height="32"/>
                        <RowDefinition Height="32"/>
                        <RowDefinition Height="32"/>
                        <RowDefinition Height="32"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="M&#xE3; c&#x1EAF;t l&#x1EC7;nh" Grid.Row="0" Grid.Column="0" Style="{StaticResource FormLabel}"/>
                    <TextBox Grid.Row="0" Grid.Column="1"
                             Text="{Binding FormErpCutOrderId, Mode=OneWay}"
                             IsReadOnly="True"
                             Style="{StaticResource FormBox}"
                             Background="#F8F9F9"/>

                    <TextBlock Text="{StaticResource Incoming.VehiclePlateLabel}" Grid.Row="1" Grid.Column="0" Style="{StaticResource FormLabel}"/>
                    <controls:AutocompleteTextBox Grid.Row="1" Grid.Column="1"
                                                   State="{Binding FormVehiclePlateInput}"
                                                   TextBoxStyle="{StaticResource FormBox}"
                                                   IsReadOnly="{Binding IsOutboundDetailLockMode}"/>

                    <TextBlock Text="Mooc" Grid.Row="1" Grid.Column="2" Style="{StaticResource FormLabel}"/>
                    <controls:AutocompleteTextBox Grid.Row="1" Grid.Column="3"
                                                   State="{Binding FormMoocInput}"
                                                   TextBoxStyle="{StaticResource FormBox}"
                                                   IsReadOnly="{Binding IsOutboundDetailLockMode}"/>

                    <TextBlock Text="HTVC" Grid.Row="0" Grid.Column="4" Style="{StaticResource FormLabel}"/>
                    <ComboBox Grid.Row="0" Grid.Column="5"
                               SelectedValue="{Binding FormTransportMethod, UpdateSourceTrigger=PropertyChanged}"
                               SelectedValuePath="Tag"
                               Style="{StaticResource StandardComboBoxStyle}"
                               IsEnabled="{Binding CanEditNonRegistrationFields}">
                        <ComboBoxItem Content="&#x110;&#x1B0;&#x1EDD;ng b&#x1ED9;" Tag="{x:Static enums:TransportMethod.ROAD}"/>
                        <ComboBoxItem Content="&#x110;&#x1B0;&#x1EDD;ng th&#x1EE7;y" Tag="{x:Static enums:TransportMethod.WATERWAY}"/>
                    </ComboBox>

                    <TextBlock Text="Th&#x1ECB; tr&#x1B0;&#x1EDD;ng" Grid.Row="2" Grid.Column="0" Style="{StaticResource FormLabel}"/>
                    <TextBox Grid.Row="2" Grid.Column="1"
                             Text="{Binding FormMarket, Mode=OneWay}"
                             IsReadOnly="True"
                             Style="{StaticResource FormBox}"
                             Background="#F8F9F9"/>

                    <TextBlock Text="TT ti&#xEA;u th&#x1EE5;" Grid.Row="2" Grid.Column="2" Style="{StaticResource FormLabel}"/>
                    <TextBox Grid.Row="2" Grid.Column="3"
                             Text="{Binding FormConsumptionPlace, Mode=OneWay}"
                             IsReadOnly="True"
                             Style="{StaticResource FormBox}"
                             Background="#F8F9F9"/>

                    <TextBlock Text="L&#x1B0;&#x1EE3;t c&#xE2;n" Grid.Row="2" Grid.Column="4" Style="{StaticResource FormLabel}"/>
                    <TextBox Grid.Row="2" Grid.Column="5"
                             Text="{Binding FormAttachSessionNo, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource FormBox}"/>

                    <TextBlock Text="M&#xE3; KH" Grid.Row="3" Grid.Column="0" Style="{StaticResource FormLabel}"/>
                    <TextBox Grid.Row="3" Grid.Column="1"
                              Text="{Binding FormCustomerCode, UpdateSourceTrigger=PropertyChanged}"
                              Style="{StaticResource FormBox}"
                              IsReadOnly="{Binding IsOutboundDetailLockMode}"/>

                    <TextBlock Text="{StaticResource Incoming.CustomerLabel}" Grid.Row="3" Grid.Column="2" Style="{StaticResource FormLabel}"/>
                    <controls:AutocompleteTextBox Grid.Row="3" Grid.Column="3"
                                                   State="{Binding FormCustomerInput}"
                                                   TextBoxStyle="{StaticResource FormBox}"
                                                   IsReadOnly="{Binding IsOutboundDetailLockMode}"/>

                    <TextBlock Text="M&#xE3; SP" Grid.Row="3" Grid.Column="4" Style="{StaticResource FormLabel}"/>
                    <controls:AutocompleteTextBox Grid.Row="3" Grid.Column="5"
                                                   State="{Binding FormProductCodeInput}"
                                                   TextBoxStyle="{StaticResource FormBox}"
                                                   IsReadOnly="{Binding IsOutboundDetailLockMode}"/>

                    <TextBlock Text="S&#x1ED1; &#x110;K Xe" Grid.Row="5" Grid.Column="0" Style="{StaticResource FormLabel}"/>
                    <TextBox Grid.Row="5" Grid.Column="1"
                              Text="{Binding VehicleRegistrationNo, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                              Style="{StaticResource FormBox}"/>

                    <TextBlock Text="S&#x1ED1; &#x110;K Mooc" Grid.Row="5" Grid.Column="2" Style="{StaticResource FormLabel}"/>
                    <TextBox Grid.Row="5" Grid.Column="3"
                              Text="{Binding MoocRegistrationNo, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                              Style="{StaticResource FormBox}"/>

                    <TextBlock Text="TTCP (kg)" Grid.Row="5" Grid.Column="4" Style="{StaticResource FormLabel}"/>
                    <TextBox Grid.Row="5" Grid.Column="5"
                              Text="{Binding TtcpWeight, Mode=TwoWay, StringFormat='{}{0:N0}', UpdateSourceTrigger=LostFocus, ConverterCulture='vi-VN'}"
                              Style="{StaticResource FormBox}"/>

                    <TextBlock Text="H&#x1EA1;n &#x110;K Xe" Grid.Row="6" Grid.Column="0" Style="{StaticResource VehicleExpiryLabelStyle}"/>
                    <DatePicker Grid.Row="6" Grid.Column="1"
                                 SelectedDate="{Binding VehicleRegistrationExpiry, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource VehicleExpiryDatePickerStyle}"/>

                    <TextBlock Text="H&#x1EA1;n &#x110;K Mooc" Grid.Row="6" Grid.Column="2" Style="{StaticResource MoocExpiryLabelStyle}"/>
                    <DatePicker Grid.Row="6" Grid.Column="3"
                                 SelectedDate="{Binding MoocRegistrationExpiry, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource MoocExpiryDatePickerStyle}"/>

                    <TextBlock Text="TTCP 10% (kg)" Grid.Row="6" Grid.Column="4" Style="{StaticResource FormLabel}"/>
                    <TextBox Grid.Row="6" Grid.Column="5"
                              Text="{Binding DisplayTtcp10PercentKg, Mode=OneWay, StringFormat='{}{0:N0}', ConverterCulture='vi-VN'}"
                              IsReadOnly="True"
                              Style="{StaticResource FormBox}"
                              Background="#F8F9F9"/>

                    <TextBlock Text="{StaticResource Incoming.DriverLabel}" Grid.Row="1" Grid.Column="4" Style="{StaticResource FormLabel}"/>
                    <controls:AutocompleteTextBox Grid.Row="1" Grid.Column="5"
                                                   State="{Binding FormDriverInput}"
                                                   TextBoxStyle="{StaticResource FormBox}"
                                                   IsReadOnly="{Binding IsOutboundDetailLockMode}"/>

                    <TextBlock Text="Lo&#x1EA1;i" Grid.Row="0" Grid.Column="2" Style="{StaticResource FormLabel}"/>
                    <ComboBox Grid.Row="0" Grid.Column="3"
                               SelectedValue="{Binding FormTransactionType, UpdateSourceTrigger=PropertyChanged}"
                               SelectedValuePath="Tag"
                               Style="{StaticResource StandardComboBoxStyle}"
                               IsEnabled="{Binding CanEditNonRegistrationFields}">
                        <ComboBoxItem Content="Nh&#x1EAD;p h&#xE0;ng" Tag="{x:Static enums:TransactionType.INBOUND}"/>
                        <ComboBoxItem Content="Xu&#x1EA5;t h&#xE0;ng" Tag="{x:Static enums:TransactionType.OUTBOUND}"/>
                    </ComboBox>

                    <TextBlock Text="SL &#x111;&#x1EB7;t" Grid.Row="4" Grid.Column="0" Style="{StaticResource FormLabel}"/>
                    <TextBox Grid.Row="4" Grid.Column="1" Text="{Binding FormPlannedWeight, ConverterCulture='vi-VN', StringFormat='{}{0:N0}', UpdateSourceTrigger=LostFocus}" Style="{StaticResource FormBox}" IsReadOnly="{Binding IsOutboundDetailLockMode}"/>

                    <TextBlock Text="S&#x1ED1; bao" Grid.Row="4" Grid.Column="2" Style="{StaticResource FormLabel}" Visibility="{Binding IsFormProductBagged, Converter={StaticResource BoolToVis}}"/>
                    <TextBox Grid.Row="4" Grid.Column="3" Text="{Binding FormBagCount, ConverterCulture='vi-VN', StringFormat='{}{0:N0}', UpdateSourceTrigger=LostFocus}" Style="{StaticResource FormBox}" Visibility="{Binding IsFormProductBagged, Converter={StaticResource BoolToVis}}" IsReadOnly="{Binding IsOutboundDetailLockMode}"/>

                    <TextBlock Text="{StaticResource Incoming.ProductLabel}" Grid.Row="4" Grid.Column="4" Style="{StaticResource FormLabel}"/>
                    <controls:AutocompleteTextBox Grid.Row="4" Grid.Column="5"
                                                   State="{Binding FormProductNameInput}"
                                                   TextBoxStyle="{StaticResource FormBox}"
                                                   IsReadOnly="{Binding IsOutboundDetailLockMode}"/>

                    <TextBlock Text="Ghi ch&#xFA;" Grid.Row="7" Grid.Column="0" Style="{StaticResource FormLabel}"/>
                    <TextBox Grid.Row="7" Grid.Column="1" Grid.ColumnSpan="5"
                             Text="{Binding FormNotes, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             MaxLength="500"
                             Style="{StaticResource FormBox}"/>

                    <StackPanel Grid.Row="8" Grid.Column="0" Grid.ColumnSpan="6" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
                        <Button Command="{Binding SaveDetailCommand}" Margin="0,0,12,0">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
                                    <Setter Property="Visibility" Value="Visible"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsCreateMode}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE74E;" FontFamily="Segoe MDL2 Assets" FontSize="13" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <TextBlock Text="{Binding SaveButtonText}" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button Command="{Binding ConfirmEnterWeighingCommand}" Style="{StaticResource WorkflowButtonStyle}" IsEnabled="{Binding CanConfirmEnterWeighing}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE8C8;" FontFamily="Segoe MDL2 Assets" FontSize="13" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <TextBlock Text="{StaticResource Incoming.CreateSession}" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button Command="{Binding MarkNoLoadCommand}" Style="{StaticResource NeutralButtonStyle}" Margin="12,0,0,0" IsEnabled="{Binding CanMarkNoLoad}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE8AB;" FontFamily="Segoe MDL2 Assets" FontSize="13" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <TextBlock Text="{StaticResource Incoming.NoLoad}" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>

        <Border Grid.Row="2" Margin="12,0,12,12">
            <DataGrid ItemsSource="{Binding Vehicles}" SelectedItem="{Binding SelectedVehicle}"
                      Style="{StaticResource SystemDataGridStyle}"
                      ColumnHeaderStyle="{StaticResource SystemDataGridColumnHeaderStyle}"
                      RowStyle="{StaticResource SystemDataGridRowStyle}"
                      CellStyle="{StaticResource SystemDataGridCellStyle}"
                      FrozenColumnCount="4"
                      ScrollViewer.HorizontalScrollBarVisibility="Auto">
                <DataGrid.Columns>
                    <DataGridTemplateColumn Header="CH&#x1ECC;N" Width="60">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <CheckBox HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          IsChecked="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Header="{StaticResource Incoming.ColRegistrationCode}" Binding="{Binding ErpCutOrderId}" Width="150" ElementStyle="{StaticResource GridTextCenter}"/>
                    <DataGridTextColumn Header="{StaticResource Incoming.VehiclePlateLabel}" Binding="{Binding VehiclePlate}" Width="115" ElementStyle="{StaticResource GridTextCenter}"/>
                    <DataGridTextColumn Header="MOOC" Binding="{Binding MoocNumber}" Width="115" ElementStyle="{StaticResource GridTextCenter}"/>
                    <DataGridTextColumn Header="LO&#x1EA0;I" Binding="{Binding TransactionType, Converter={StaticResource TransactionTypeDisplayConverter}}" Width="95" ElementStyle="{StaticResource GridTextCenter}"/>
                    <DataGridTextColumn Header="HTVC" Binding="{Binding TransportMethod, Converter={StaticResource TransportMethodDisplayConverter}}" Width="95" ElementStyle="{StaticResource GridTextCenter}"/>
                    <DataGridTextColumn Header="{StaticResource Incoming.DriverLabel}" Binding="{Binding ReceiverName}" Width="150" ElementStyle="{StaticResource GridTextLeft}"/>
                    <DataGridTextColumn Header="KH&#xC1;CH H&#xC0;NG" Binding="{Binding CustomerName}" Width="260" ElementStyle="{StaticResource GridTextLeft}"/>
                    <DataGridTextColumn Header="TT TI&#xEA;U TH&#x1EE4;" Binding="{Binding ConsumptionPlace}" Width="150" ElementStyle="{StaticResource GridTextLeft}"/>
                    <DataGridTextColumn Header="TH&#x1ECA; TR&#x1AF;&#x1EDC;NG" Binding="{Binding Market}" Width="150" ElementStyle="{StaticResource GridTextLeft}"/>
                    <DataGridTextColumn Header="{StaticResource Incoming.ColProductCode}" Binding="{Binding ProductCode}" Width="130" ElementStyle="{StaticResource GridTextCenter}"/>
                    <DataGridTextColumn Header="{StaticResource Incoming.ProductLabel}" Binding="{Binding ProductName}" Width="260" ElementStyle="{StaticResource GridTextLeft}"/>
                    <DataGridTextColumn Header="SL &#x110;&#x1EB6;T (KG)" Binding="{Binding PlannedWeight, StringFormat=N0}" Width="115" ElementStyle="{StaticResource GridTextRight}"/>
                    <DataGridTextColumn Header="S&#x1ED0; BAO" Binding="{Binding BagCount}" Width="90" ElementStyle="{StaticResource GridTextCenter}"/>
                    <DataGridTextColumn Header="TH&#x1EDC;I GIAN T&#x1EA0;O" Binding="{Binding CreatedAt, StringFormat='dd/MM/yyyy HH:mm'}" Width="150" ElementStyle="{StaticResource GridTextCenter}"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</UserControl>


