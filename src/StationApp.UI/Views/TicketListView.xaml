<UserControl x:Class="StationApp.UI.Views.TicketListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:helpers="clr-namespace:StationApp.UI.Helpers"
             Background="Transparent">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/StationApp.UI;component/Themes/AppTheme.xaml"/>
                <ResourceDictionary Source="/StationApp.UI;component/Styles/ButtonStyles.xaml"/>
                <ResourceDictionary Source="/StationApp.UI;component/Styles/InputStyles.xaml"/>
                <ResourceDictionary Source="/StationApp.UI;component/Styles/BasePageStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>
    <Grid Background="#FFFFFF">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Margin="12" Background="#E8EFF7" Padding="16" CornerRadius="4">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,16">
                    <TextBlock Text="&#xE8A4;" FontFamily="Segoe MDL2 Assets" FontSize="22" VerticalAlignment="Center" Margin="0,0,10,0" Foreground="#123B6B"/>
                    <TextBlock Text="DANH S&#xC1;CH PHI&#x1EBE;U" FontSize="20" FontWeight="SemiBold" Foreground="#123B6B" VerticalAlignment="Center"/>
                </StackPanel>

                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" Text="T&#x1EEB; kh&#xF3;a t&#xEC;m ki&#x1EBF;m" Style="{StaticResource FieldLabelStyle}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBox Grid.Column="1"
                             Text="{Binding SearchKeyword, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource SearchTextBoxStyle}"
                             helpers:EnterKeySearch.Command="{Binding SearchCommand}"
                             Margin="0,0,16,0"
                             MaxWidth="400"
                             HorizontalAlignment="Left"
                             Width="400"/>
                    
                    <Button Grid.Column="2" Command="{Binding SearchCommand}" Style="{StaticResource UtilityButtonStyle}" Margin="0,0,12,0" Height="32">
                        <TextBlock Text="T&#xCC;M KI&#x1EBE;M" VerticalAlignment="Center"/>
                    </Button>

                    <Button Grid.Column="3" Command="{Binding CreateTicketCommand}" Style="{StaticResource PrimaryButtonStyle}" Height="32">
                        <TextBlock Text="T&#x1EA0;O PHI&#x1EBE;U" VerticalAlignment="Center"/>
                    </Button>
                </Grid>
            </Grid>
        </Border>

        <Border Grid.Row="1" Margin="12,0,12,12">
            <DataGrid ItemsSource="{Binding Tickets}" SelectedItem="{Binding SelectedTicket}"
                      Style="{StaticResource SystemDataGridStyle}"
                      ColumnHeaderStyle="{StaticResource SystemDataGridColumnHeaderStyle}"
                      RowStyle="{StaticResource SystemDataGridRowStyle}"
                      CellStyle="{StaticResource SystemDataGridCellStyle}"
                      ScrollViewer.HorizontalScrollBarVisibility="Auto">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="S&#x1ED1; phi&#x1EBF;u" Binding="{Binding TicketNo}" Width="150" ElementStyle="{StaticResource GridTextCenter}"/>
                    <DataGridTextColumn Header="S&#x1ED1; xe" Binding="{Binding VehiclePlate}" Width="110" ElementStyle="{StaticResource GridTextCenter}"/>
                    <DataGridTextColumn Header="Lo&#x1EA1;i phi&#x1EBF;u" Binding="{Binding TransactionType}" Width="120" ElementStyle="{StaticResource GridTextCenter}"/>
                    <DataGridTextColumn Header="Tr&#x1EA1;ng th&#xE1;i" Binding="{Binding Status}" Width="140" ElementStyle="{StaticResource GridTextCenter}"/>
                    <DataGridTextColumn Header="C&#xE2;n 1 (kg)" Binding="{Binding Weight1, StringFormat=N0}" Width="105" ElementStyle="{StaticResource GridTextRight}"/>
                    <DataGridTextColumn Header="C&#xE2;n 2 (kg)" Binding="{Binding Weight2, StringFormat=N0}" Width="105" ElementStyle="{StaticResource GridTextRight}"/>
                    <DataGridTextColumn Header="TL H&#xE0;ng (kg)" Binding="{Binding NetWeight, StringFormat=N0}" Width="110" ElementStyle="{StaticResource GridTextRight}"/>
                    <DataGridTextColumn Header="&#x110;&#x1ED3;ng b&#x1ED9;" Binding="{Binding SyncStatus}" Width="110" ElementStyle="{StaticResource GridTextCenter}"/>
                    <DataGridTextColumn Header="Ng&#xE0;y t&#x1EA1;o" Binding="{Binding CreatedAt, StringFormat='dd/MM/yyyy HH:mm'}" Width="150" ElementStyle="{StaticResource GridTextCenter}"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</UserControl>
