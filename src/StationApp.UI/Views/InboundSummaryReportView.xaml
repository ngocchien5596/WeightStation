<UserControl x:Class="StationApp.UI.Views.InboundSummaryReportView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/StationApp.UI;component/Themes/AppTheme.xaml"/>
                <ResourceDictionary Source="/StationApp.UI;component/Styles/ButtonStyles.xaml"/>
                <ResourceDictionary Source="/StationApp.UI;component/Styles/InputStyles.xaml"/>
                <ResourceDictionary Source="/StationApp.UI;component/Styles/BasePageStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <Style x:Key="ReportDatePickerStyle" TargetType="DatePicker" BasedOn="{StaticResource StandardDatePickerStyle}">
                <Setter Property="Width" Value="150"/>
                <Setter Property="Height" Value="36"/>
            </Style>

            <Style x:Key="ReportTimeComboStyle" TargetType="ComboBox" BasedOn="{StaticResource StandardComboBoxStyle}">
                <Setter Property="Width" Value="62"/>
                <Setter Property="Height" Value="36"/>
            </Style>

            <Style x:Key="ReportLookupComboStyle" TargetType="ComboBox">
                <Setter Property="FontFamily" Value="{StaticResource AppFontFamily}"/>
                <Setter Property="FontSize" Value="13"/>
                <Setter Property="Foreground" Value="#111827"/>
                <Setter Property="Background" Value="#FFFFFF"/>
                <Setter Property="BorderBrush" Value="#9AA4AA"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="Padding" Value="6,2"/>
                <Setter Property="VerticalContentAlignment" Value="Center"/>
                <Setter Property="HorizontalContentAlignment" Value="Left"/>
                <Setter Property="MaxDropDownHeight" Value="260"/>
            </Style>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid Background="{DynamicResource BackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource HeaderBorder}">
            <DockPanel>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Báo cáo nhập hàng" Style="{StaticResource HeaderLabel}" Margin="0,0,16,0"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <Border Grid.Row="1"
                Margin="12,24,12,12"
                Padding="24"
                Background="{DynamicResource CardBrush}"
                BorderBrush="#E2E8F0"
                BorderThickness="1"
                CornerRadius="12"
                HorizontalAlignment="Center"
                VerticalAlignment="Top">
            <Border.Effect>
                <DropShadowEffect BlurRadius="12" Color="#0C1A30" Opacity="0.06" ShadowDepth="3" Direction="270"/>
            </Border.Effect>
            <Grid Width="620">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="140"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0"
                           Text="Từ giờ"
                           VerticalAlignment="Center"
                           Margin="0,0,12,16"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource ForegroundBrush}"/>
                <StackPanel Grid.Row="0" Grid.Column="1"
                            Orientation="Horizontal"
                            Margin="0,0,0,16">
                    <ComboBox ItemsSource="{Binding HourOptions}"
                              SelectedItem="{Binding FromHour, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                              Style="{StaticResource ReportTimeComboStyle}"/>
                    <TextBlock Text=":" VerticalAlignment="Center" FontSize="16" FontWeight="Bold" Margin="0,0,8,0"/>
                    <ComboBox ItemsSource="{Binding MinuteOptions}"
                              SelectedItem="{Binding FromMinute, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                              Style="{StaticResource ReportTimeComboStyle}"/>
                    <TextBlock Text=":" VerticalAlignment="Center" FontSize="16" FontWeight="Bold" Margin="0,0,8,0"/>
                    <ComboBox ItemsSource="{Binding SecondOptions}"
                              SelectedItem="{Binding FromSecond, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                              Style="{StaticResource ReportTimeComboStyle}"/>
                    <DatePicker SelectedDate="{Binding FromDate, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                Style="{StaticResource ReportDatePickerStyle}"
                                Margin="12,0,0,0"/>
                </StackPanel>

                <TextBlock Grid.Row="1" Grid.Column="0"
                           Text="Đến giờ"
                           VerticalAlignment="Center"
                           Margin="0,0,12,16"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource ForegroundBrush}"/>
                <StackPanel Grid.Row="1" Grid.Column="1"
                            Orientation="Horizontal"
                            Margin="0,0,0,16">
                    <ComboBox ItemsSource="{Binding HourOptions}"
                              SelectedItem="{Binding ToHour, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                              Style="{StaticResource ReportTimeComboStyle}"/>
                    <TextBlock Text=":" VerticalAlignment="Center" FontSize="16" FontWeight="Bold" Margin="0,0,8,0"/>
                    <ComboBox ItemsSource="{Binding MinuteOptions}"
                              SelectedItem="{Binding ToMinute, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                              Style="{StaticResource ReportTimeComboStyle}"/>
                    <TextBlock Text=":" VerticalAlignment="Center" FontSize="16" FontWeight="Bold" Margin="0,0,8,0"/>
                    <ComboBox ItemsSource="{Binding SecondOptions}"
                              SelectedItem="{Binding ToSecond, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                              Style="{StaticResource ReportTimeComboStyle}"/>
                    <DatePicker SelectedDate="{Binding ToDate, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                Style="{StaticResource ReportDatePickerStyle}"
                                Margin="12,0,0,0"/>
                </StackPanel>

                <TextBlock Grid.Row="2" Grid.Column="0"
                           Text="Sản phẩm"
                           VerticalAlignment="Center"
                           Margin="0,0,12,16"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource ForegroundBrush}"/>
                <ComboBox Grid.Row="2" Grid.Column="1"
                          Width="440"
                          HorizontalAlignment="Left"
                          Margin="0,0,0,16"
                          Height="36"
                          Style="{StaticResource ReportLookupComboStyle}"
                          IsEditable="True"
                          IsTextSearchEnabled="False"
                          StaysOpenOnEdit="True"
                          Loaded="LookupComboBox_Loaded"
                          SelectionChanged="LookupComboBox_SelectionChanged"
                          Text="{Binding ProductSearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                          ItemsSource="{Binding ProductOptionsView}"
                          SelectedItem="{Binding SelectedProduct, Mode=TwoWay}"
                          SelectedValuePath="Code">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding DisplayName}"/>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>

                <TextBlock Grid.Row="3" Grid.Column="0"
                           Text="Khách hàng"
                           VerticalAlignment="Center"
                           Margin="0,0,12,16"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource ForegroundBrush}"/>
                <ComboBox Grid.Row="3" Grid.Column="1"
                          Width="440"
                          HorizontalAlignment="Left"
                          Margin="0,0,0,16"
                          Height="36"
                          Style="{StaticResource ReportLookupComboStyle}"
                          IsEditable="True"
                          IsTextSearchEnabled="False"
                          StaysOpenOnEdit="True"
                          Loaded="LookupComboBox_Loaded"
                          SelectionChanged="LookupComboBox_SelectionChanged"
                          Text="{Binding CustomerSearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                          ItemsSource="{Binding CustomerOptionsView}"
                          SelectedItem="{Binding SelectedCustomer, Mode=TwoWay}"
                          SelectedValuePath="Code">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding DisplayName}"/>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>

                <StackPanel Grid.Row="4" Grid.Column="1"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            Margin="0,8,20,0">
                    <Button Command="{Binding ExportCommand}"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Height="38"
                            Width="150">
                        <TextBlock Text="XUẤT BÁO CÁO" VerticalAlignment="Center" FontWeight="SemiBold"/>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
