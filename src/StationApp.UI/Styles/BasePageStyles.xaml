<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:converters="clr-namespace:StationApp.UI.Converters"
                    xmlns:helpers="clr-namespace:StationApp.UI.Helpers">

    <converters:MultiStringEqualityToBoolConverter x:Key="MultiStringEqToBool"/>
    <converters:OverweightToForegroundConverter x:Key="OverweightToFore"/>
    <converters:TransactionTypeDisplayConverter x:Key="TransactionTypeDisplayConverter"/>
    <converters:TransportMethodDisplayConverter x:Key="TransportMethodDisplayConverter"/>
    <converters:StringToVisibilityConverter x:Key="StringToVis"/>
    <converters:InverseBooleanToVisibilityConverter x:Key="InverseBoolToVis"/>
    <BooleanToVisibilityConverter x:Key="BoolToVis"/>

    <!-- 1. COLOR TOKENS -->
    <SolidColorBrush x:Key="AppNavy" Color="#203B73"/>
    <SolidColorBrush x:Key="AppNavyDark" Color="#1B3263"/>
    <SolidColorBrush x:Key="AppNavyHover" Color="#294984"/>
    
    <SolidColorBrush x:Key="SidebarBackground" Color="#1B2631"/>
    <SolidColorBrush x:Key="SidebarTopBackground" Color="#1B2631"/>
    <SolidColorBrush x:Key="SidebarFooterBackground" Color="#1B2631"/>
    <SolidColorBrush x:Key="SidebarItemBackground" Color="#1B2631"/>
    <SolidColorBrush x:Key="SidebarItemHoverBackground" Color="#263545"/>
    <SolidColorBrush x:Key="SidebarItemSelectedBackground" Color="#C5A059"/>
    <SolidColorBrush x:Key="SidebarItemSelectedForeground" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="SidebarItemForeground" Color="#CBD5E1"/>
    <SolidColorBrush x:Key="SidebarIconForeground" Color="#CBD5E1"/>
    <SolidColorBrush x:Key="SidebarDividerColor" Color="#CED6E0"/>
    
    <SolidColorBrush x:Key="HeaderBackground" Color="#203B73"/>
    <SolidColorBrush x:Key="HeaderForeground" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="HeaderInputBackground" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="HeaderInputForeground" Color="#333333"/>
    <SolidColorBrush x:Key="HeaderInputBorder" Color="#CED6E0"/>
    
    <SolidColorBrush x:Key="AppWindowBackground" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="MainContentBackground" Color="#EAF4F2"/>
    <SolidColorBrush x:Key="WorkAreaBackground" Color="#EAF4F2"/>
    <SolidColorBrush x:Key="GridAreaBackground" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="SectionBorderColor" Color="#C9D6D6"/>
    
    <SolidColorBrush x:Key="ClockBackground" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="ClockForeground" Color="#203B73"/>
    <SolidColorBrush x:Key="ClockBorderColor" Color="#D7DEE8"/>
    <SolidColorBrush x:Key="ClockIconForeground" Color="#203B73"/>

    <!-- 2. SIDEBAR STYLES -->
    <Style x:Key="SidebarContainerStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource SidebarBackground}"/>
    </Style>

    <Style x:Key="SidebarMenuPanelStyle" TargetType="StackPanel">
        <Setter Property="Background" Value="{StaticResource SidebarItemBackground}"/>
    </Style>

    <Style x:Key="SidebarMenuItemStyle" TargetType="Button">
        <Setter Property="Background" Value="{StaticResource SidebarItemBackground}"/>
        <Setter Property="Foreground" Value="{StaticResource SidebarItemForeground}"/>
        <Setter Property="FontFamily" Value="{StaticResource AppFontFamily}"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="FontWeight" Value="Normal"/>
        <Setter Property="Height" Value="48"/>
        <Setter Property="HorizontalContentAlignment" Value="Left"/>
        <Setter Property="Padding" Value="20,0,12,0"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Grid x:Name="mainGrid" Background="{TemplateBinding Background}">
                        <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="mainGrid" Property="Background" Value="{StaticResource SidebarItemHoverBackground}"/>
                        </Trigger>
                        <DataTrigger Value="True">
                            <DataTrigger.Binding>
                                <MultiBinding Converter="{StaticResource MultiStringEqToBool}">
                                    <Binding Path="CommandParameter" RelativeSource="{RelativeSource Self}"/>
                                    <Binding Path="DataContext.CurrentDestination" RelativeSource="{RelativeSource AncestorType=Window}"/>
                                </MultiBinding>
                            </DataTrigger.Binding>
                            <Setter TargetName="mainGrid" Property="Background" Value="{StaticResource SidebarItemSelectedBackground}"/>
                            <Setter Property="Foreground" Value="{StaticResource SidebarItemSelectedForeground}"/>
                        </DataTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="SidebarExpandableItemStyle" TargetType="Button" BasedOn="{StaticResource SidebarMenuItemStyle}">
        <Setter Property="FontWeight" Value="Normal"/>
    </Style>

    <!-- 3. HEADER STYLES -->
    <Style x:Key="HeaderContainerStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource HeaderBackground}"/>
        <Setter Property="Height" Value="64"/>
    </Style>

    <Style x:Key="HeaderLabelStyle" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource HeaderForeground}"/>
        <Setter Property="FontFamily" Value="{StaticResource AppFontFamily}"/>
        <Setter Property="FontSize" Value="14.5"/>
        <Setter Property="FontWeight" Value="Normal"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <Style x:Key="HeaderLabel" TargetType="TextBlock">
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="FontWeight" Value="Normal"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="FontSize" Value="13.5"/>
    </Style>

    <Style x:Key="HeaderActionButton" TargetType="Button" BasedOn="{StaticResource WorkflowButtonStyle}">
        <Setter Property="Height" Value="34"/>
        <Setter Property="MinWidth" Value="120"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="Padding" Value="14,0"/>
        <Setter Property="Background" Value="#F39C12"/>
    </Style>

    <Style x:Key="HeaderBorder" TargetType="Border" BasedOn="{StaticResource HeaderContainerStyle}">
        <Setter Property="Padding" Value="12,0"/>
    </Style>

    <!-- 4. CLOCK STYLES -->
    <Style x:Key="ClockBadgeStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource ClockBackground}"/>
        <Setter Property="BorderBrush" Value="{StaticResource ClockBorderColor}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="16"/>
        <Setter Property="Height" Value="38"/>
        <Setter Property="Width" Value="185"/>
        <Setter Property="Padding" Value="12,0"/>
        <Setter Property="HorizontalAlignment" Value="Right"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <Style x:Key="ClockTextStyle" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource ClockForeground}"/>
        <Setter Property="FontFamily" Value="{StaticResource AppFontFamily}"/>
        <Setter Property="FontSize" Value="17.5"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <!-- 5. PAGE BACKGROUND STYLES -->
    <Style x:Key="MainContentContainerStyle" TargetType="Grid">
        <Setter Property="Background" Value="{StaticResource MainContentBackground}"/>
    </Style>

    <Style x:Key="WorkAreaPanelStyle" TargetType="Grid">
        <Setter Property="Background" Value="{StaticResource WorkAreaBackground}"/>
    </Style>

    <!-- 6. SYSTEM DATAGRID STYLES (Standardized from WeighingView) -->
    <Style TargetType="DataGrid">
        <Setter Property="ClipboardCopyMode" Value="ExcludeHeader"/>
        <Setter Property="helpers:DataGridCellCopyBehavior.EnableCurrentCellCopy" Value="True"/>
        <Setter Property="EnableRowVirtualization" Value="True"/>
        <Setter Property="EnableColumnVirtualization" Value="True"/>
        <Setter Property="VirtualizingPanel.IsVirtualizing" Value="True"/>
        <Setter Property="VirtualizingPanel.VirtualizationMode" Value="Recycling"/>
        <Setter Property="ScrollViewer.CanContentScroll" Value="True"/>
    </Style>

    <Style x:Key="SystemDataGridStyle" TargetType="DataGrid">
        <Setter Property="AutoGenerateColumns" Value="False"/>
        <Setter Property="IsReadOnly" Value="True"/>
        <Setter Property="ClipboardCopyMode" Value="ExcludeHeader"/>
        <Setter Property="helpers:DataGridCellCopyBehavior.EnableCurrentCellCopy" Value="True"/>
        <Setter Property="EnableRowVirtualization" Value="True"/>
        <Setter Property="EnableColumnVirtualization" Value="True"/>
        <Setter Property="VirtualizingPanel.IsVirtualizing" Value="True"/>
        <Setter Property="VirtualizingPanel.VirtualizationMode" Value="Recycling"/>
        <Setter Property="ScrollViewer.CanContentScroll" Value="True"/>
        <Setter Property="FontSize" Value="13.5"/>
        <Setter Property="GridLinesVisibility" Value="All"/>
        <Setter Property="HorizontalGridLinesBrush" Value="#BDC3C7"/>
        <Setter Property="VerticalGridLinesBrush" Value="#BDC3C7"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="BorderBrush" Value="#BDC3C7"/>
        <Setter Property="RowHeight" Value="30"/>
        <Setter Property="CanUserResizeColumns" Value="True"/>
        <Setter Property="ColumnHeaderHeight" Value="34"/>
        <Setter Property="Background" Value="White"/>
        <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Auto"/>
        <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto"/>
    </Style>

    <Style x:Key="SystemDataGridColumnHeaderStyle" TargetType="DataGridColumnHeader">
        <Setter Property="Background" Value="#1E2A38"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="Height" Value="42"/>
        <Setter Property="Padding" Value="10,0"/>
        <Setter Property="FontSize" Value="13.5"/>
        <Setter Property="FontWeight" Value="Normal"/>
        <Setter Property="BorderThickness" Value="0,0,1,1"/>
        <Setter Property="BorderBrush" Value="#BDC3C7"/>
        <Setter Property="HorizontalContentAlignment" Value="Center"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
    </Style>

    <Style x:Key="SystemDataGridRowStyle" TargetType="DataGridRow">
        <Setter Property="Background" Value="#FFFFFF"/>
        <Setter Property="Foreground" Value="{Binding Converter={StaticResource OverweightToFore}}"/>
        <Setter Property="FontWeight" Value="Normal"/>
        <Style.Triggers>
            <DataTrigger Binding="{Binding IsSelected}" Value="True">
                <Setter Property="Background" Value="#2980B9"/>
                <Setter Property="Foreground" Value="White"/>
            </DataTrigger>
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="Background" Value="#2980B9"/>
                <Setter Property="Foreground" Value="White"/>
            </Trigger>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="#EBF5FB"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="SystemDataGridCellStyle" TargetType="DataGridCell">
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Style.Triggers>
            <DataTrigger Binding="{Binding IsSelected}" Value="True">
                <Setter Property="Background" Value="#2980B9"/>
                <Setter Property="Foreground" Value="White"/>
            </DataTrigger>
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="Background" Value="#2980B9"/>
                <Setter Property="Foreground" Value="White"/>
            </Trigger>
            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                <Setter Property="BorderBrush" Value="#F39C12"/>
                <Setter Property="BorderThickness" Value="2"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- 6.2 DETAIL DATAGRID STYLES (Light-themed, subordinate design for nested Details) -->
    <Style x:Key="DetailDataGridStyle" TargetType="DataGrid">
        <Setter Property="AutoGenerateColumns" Value="False"/>
        <Setter Property="IsReadOnly" Value="True"/>
        <Setter Property="ClipboardCopyMode" Value="ExcludeHeader"/>
        <Setter Property="helpers:DataGridCellCopyBehavior.EnableCurrentCellCopy" Value="True"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="GridLinesVisibility" Value="All"/>
        <Setter Property="HorizontalGridLinesBrush" Value="#E2E8F0"/>
        <Setter Property="VerticalGridLinesBrush" Value="#E2E8F0"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="BorderBrush" Value="#CBD5E1"/>
        <Setter Property="RowHeight" Value="30"/>
        <Setter Property="CanUserResizeColumns" Value="True"/>
        <Setter Property="ColumnHeaderHeight" Value="34"/>
        <Setter Property="Background" Value="#F8FAFC"/>
        <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Auto"/>
        <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto"/>
    </Style>

    <Style x:Key="DetailDataGridColumnHeaderStyle" TargetType="DataGridColumnHeader">
        <Setter Property="Background" Value="#F1F5F9"/>
        <Setter Property="Foreground" Value="#334155"/>
        <Setter Property="Height" Value="36"/>
        <Setter Property="Padding" Value="10,0"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="FontWeight" Value="Normal"/>
        <Setter Property="BorderThickness" Value="0,0,1,1"/>
        <Setter Property="BorderBrush" Value="#E2E8F0"/>
        <Setter Property="HorizontalContentAlignment" Value="Center"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
    </Style>

    <Style x:Key="DetailDataGridRowStyle" TargetType="DataGridRow">
        <Setter Property="Background" Value="#FFFFFF"/>
        <Setter Property="Foreground" Value="{Binding Converter={StaticResource OverweightToFore}}"/>
        <Setter Property="FontWeight" Value="Normal"/>
        <Style.Triggers>
            <DataTrigger Binding="{Binding IsSelected}" Value="True">
                <Setter Property="Background" Value="#E2E8F0"/>
                <Setter Property="Foreground" Value="#0F172A"/>
            </DataTrigger>
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="Background" Value="#E2E8F0"/>
                <Setter Property="Foreground" Value="#0F172A"/>
            </Trigger>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="#F1F5F9"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="DetailDataGridCellStyle" TargetType="DataGridCell">
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Style.Triggers>
            <DataTrigger Binding="{Binding IsSelected}" Value="True">
                <Setter Property="Background" Value="#E2E8F0"/>
                <Setter Property="Foreground" Value="#0F172A"/>
            </DataTrigger>
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="Background" Value="#E2E8F0"/>
                <Setter Property="Foreground" Value="#0F172A"/>
            </Trigger>
            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                <Setter Property="BorderBrush" Value="#F39C12"/>
                <Setter Property="BorderThickness" Value="2"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- Grid Text Alignment Styles -->
    <Style x:Key="GridTextCenter" TargetType="TextBlock">
        <Setter Property="Margin" Value="10,3"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="FontWeight" Value="Normal"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="TextAlignment" Value="Center"/>
    </Style>

    <Style x:Key="GridTextRight" TargetType="TextBlock">
        <Setter Property="Margin" Value="10,3"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="FontWeight" Value="Normal"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="TextAlignment" Value="Right"/>
    </Style>

    <Style x:Key="GridTextLeft" TargetType="TextBlock">
        <Setter Property="Margin" Value="10,3"/>
        <Setter Property="FontSize" Value="12.5"/>
        <Setter Property="FontWeight" Value="Normal"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="TextAlignment" Value="Left"/>
    </Style>

    <Style x:Key="GridCheckBoxCenter" TargetType="CheckBox">
        <Setter Property="HorizontalAlignment" Value="Center"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="Focusable" Value="False"/>
        <Setter Property="IsHitTestVisible" Value="False"/>
    </Style>

    <Style x:Key="GridCheckBoxCenterEditable" TargetType="CheckBox">
        <Setter Property="HorizontalAlignment" Value="Center"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="Focusable" Value="True"/>
        <Setter Property="IsHitTestVisible" Value="True"/>
    </Style>

    <Style x:Key="ModalOverlayStyle" TargetType="Grid">
        <Setter Property="Background" Value="#660C1424"/>
    </Style>

    <Style x:Key="ModalShellStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource CardBrush}"/>
        <Setter Property="CornerRadius" Value="10"/>
        <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="0"/>
        <Setter Property="Effect">
            <Setter.Value>
                <DropShadowEffect BlurRadius="18" Color="#55000000" ShadowDepth="3"/>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="ModalHeaderStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource SidebarBrush}"/>
        <Setter Property="CornerRadius" Value="9,9,0,0"/>
        <Setter Property="Padding" Value="18,10"/>
    </Style>

    <Style x:Key="ModalTitleStyle" TargetType="TextBlock">
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="FontSize" Value="16.5"/>
        <Setter Property="FontWeight" Value="Normal"/>
    </Style>

    <Style x:Key="ModalBodyStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource CardBrush}"/>
        <Setter Property="Padding" Value="16,14"/>
    </Style>

    <Style x:Key="ModalFooterStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource SubCardBrush}"/>
        <Setter Property="CornerRadius" Value="0,0,9,9"/>
        <Setter Property="Padding" Value="14,10"/>
    </Style>

    <Style x:Key="ModalSectionCardStyle" TargetType="Border">
        <Setter Property="Background" Value="#F8FBFD"/>
        <Setter Property="BorderBrush" Value="#D5DFE8"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="8"/>
        <Setter Property="Padding" Value="10"/>
    </Style>

    <Style x:Key="ModalMetricCardStyle" TargetType="Border" BasedOn="{StaticResource ModalSectionCardStyle}">
        <Setter Property="Padding" Value="14,12"/>
        <Setter Property="Margin" Value="0,0,10,0"/>
    </Style>

    <Style x:Key="ModalMetricLabelStyle" TargetType="TextBlock">
        <Setter Property="Foreground" Value="#5A6B85"/>
        <Setter Property="FontSize" Value="12.5"/>
        <Setter Property="FontWeight" Value="Normal"/>
        <Setter Property="TextWrapping" Value="Wrap"/>
    </Style>

    <Style x:Key="ModalMetricValueStyle" TargetType="TextBlock">
        <Setter Property="Foreground" Value="#1F355C"/>
        <Setter Property="FontSize" Value="20"/>
        <Setter Property="FontWeight" Value="Normal"/>
        <Setter Property="Margin" Value="0,6,0,0"/>
    </Style>

    <!-- 8. MODERN MINIMALIST SCROLLBAR STYLES -->
    <Style x:Key="ModernScrollThumb" TargetType="{x:Type Thumb}">
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="OverridesDefaultStyle" Value="True"/>
        <Setter Property="IsTabStop" Value="False"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Thumb}">
                    <Border x:Name="chrome"
                            Background="#BDC3C7"
                            CornerRadius="4" />
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="chrome" Property="Background" Value="#7F8C8D" />
                        </Trigger>
                        <Trigger Property="IsDragging" Value="True">
                            <Setter TargetName="chrome" Property="Background" Value="#95A5A6" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="{x:Type ScrollBar}">
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="OverridesDefaultStyle" Value="True"/>
        <Style.Triggers>
            <Trigger Property="Orientation" Value="Horizontal">
                <Setter Property="Width" Value="Auto"/>
                <Setter Property="Height" Value="8"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="{x:Type ScrollBar}">
                            <Grid x:Name="Bg" SnapsToDevicePixels="True" Background="Transparent">
                                <Track x:Name="PART_Track"
                                       IsDirectionReversed="False"
                                       IsEnabled="{TemplateBinding IsEnabled}">
                                    <Track.DecreaseRepeatButton>
                                        <RepeatButton Command="ScrollBar.PageLeftCommand" Opacity="0" Focusable="False"/>
                                    </Track.DecreaseRepeatButton>
                                    <Track.Thumb>
                                        <Thumb Style="{StaticResource ModernScrollThumb}" Margin="0,1,0,1"/>
                                    </Track.Thumb>
                                    <Track.IncreaseRepeatButton>
                                        <RepeatButton Command="ScrollBar.PageRightCommand" Opacity="0" Focusable="False"/>
                                    </Track.IncreaseRepeatButton>
                                </Track>
                            </Grid>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Trigger>
            <Trigger Property="Orientation" Value="Vertical">
                <Setter Property="Width" Value="8"/>
                <Setter Property="Height" Value="Auto"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="{x:Type ScrollBar}">
                            <Grid x:Name="Bg" SnapsToDevicePixels="True" Background="Transparent">
                                <Track x:Name="PART_Track"
                                       IsDirectionReversed="True"
                                       IsEnabled="{TemplateBinding IsEnabled}">
                                    <Track.DecreaseRepeatButton>
                                        <RepeatButton Command="ScrollBar.PageUpCommand" Opacity="0" Focusable="False"/>
                                    </Track.DecreaseRepeatButton>
                                    <Track.Thumb>
                                        <Thumb Style="{StaticResource ModernScrollThumb}" Margin="1,0,1,0"/>
                                    </Track.Thumb>
                                    <Track.IncreaseRepeatButton>
                                        <RepeatButton Command="ScrollBar.PageDownCommand" Opacity="0" Focusable="False"/>
                                    </Track.IncreaseRepeatButton>
                                </Track>
                            </Grid>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Trigger>
        </Style.Triggers>
    </Style>

</ResourceDictionary>
