<UserControl x:Class="StationApp.UI.Controls.AutocompleteTextBox"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:StationApp.UI.Converters"
             x:Name="Root">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <converters:InverseBooleanToVisibilityConverter x:Key="InverseBoolToVisibilityConverter"/>
        <converters:StringToVisibilityConverter x:Key="StringToVisibilityConverter"/>
        <Style x:Key="SuggestionListBoxStyle" TargetType="ListBox">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto"/>
            <Setter Property="MaxHeight" Value="220"/>
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Padding" Value="0"/>
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        <Setter Property="Background" Value="#FFFFFF"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListBoxItem">
                                    <Border x:Name="ItemBorder"
                                            Background="{TemplateBinding Background}"
                                            Padding="12,8"
                                            SnapsToDevicePixels="True">
                                        <ContentPresenter/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="ItemBorder" Property="Background" Value="#EEF4F8"/>
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="ItemBorder" Property="Background" Value="#DCEAF7"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <TextBox x:Name="InputTextBox"
                 Text="{Binding State.Text, ElementName=Root, UpdateSourceTrigger=PropertyChanged}"
                 Style="{Binding TextBoxStyle, ElementName=Root}"
                 IsEnabled="{Binding State.IsEnabled, ElementName=Root}"
                 PreviewKeyDown="InputTextBox_OnPreviewKeyDown"
                 LostKeyboardFocus="FocusableElement_OnLostKeyboardFocus"/>

        <Popup x:Name="SuggestionsPopup"
               Placement="Bottom"
               PlacementTarget="{Binding ElementName=InputTextBox}"
               IsOpen="{Binding State.IsDropDownOpen, ElementName=Root}"
               AllowsTransparency="True"
               StaysOpen="True"
               PopupAnimation="Fade">
            <Border MinWidth="{Binding ActualWidth, ElementName=InputTextBox}"
                    Margin="0,4,0,0"
                    Background="#FFFFFF"
                    BorderBrush="#9AA4AA"
                    BorderThickness="1"
                    CornerRadius="4"
                    SnapsToDevicePixels="True">
                <Grid>
                    <ListBox x:Name="SuggestionsList"
                             ItemsSource="{Binding State.Items, ElementName=Root}"
                             SelectedIndex="{Binding State.SelectedIndex, ElementName=Root, Mode=TwoWay}"
                             Style="{StaticResource SuggestionListBoxStyle}"
                             Visibility="{Binding State.HasNoResults, ElementName=Root, Converter={StaticResource InverseBoolToVisibilityConverter}}"
                             PreviewMouseLeftButtonUp="SuggestionsList_OnPreviewMouseLeftButtonUp"
                             PreviewKeyDown="SuggestionsList_OnPreviewKeyDown"
                             LostKeyboardFocus="FocusableElement_OnLostKeyboardFocus">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel>
                                    <TextBlock Text="{Binding DisplayText}"
                                               Foreground="#111827"
                                               FontSize="14"
                                               FontWeight="SemiBold"/>
                                    <TextBlock Text="{Binding SecondaryText}"
                                               Margin="0,2,0,0"
                                               Foreground="#6B7280"
                                               FontSize="13"
                                               Visibility="{Binding SecondaryText, Converter={StaticResource StringToVisibilityConverter}}"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <TextBlock Margin="10,8"
                               Text="Không có dữ liệu phù hợp"
                               Foreground="#6B7280"
                               FontSize="13"
                               Visibility="{Binding State.HasNoResults, ElementName=Root, Converter={StaticResource BoolToVisibilityConverter}}"/>
                </Grid>
            </Border>
        </Popup>
    </Grid>
</UserControl>
